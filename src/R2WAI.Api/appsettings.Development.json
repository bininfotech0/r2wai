{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=r2wai_dev;Username=r2wai;Password=${DB_PASSWORD:=changeme_dev}",
    "Redis": "localhost:6379",
    "Hangfire": "Host=localhost;Port=5432;Database=r2wai_hangfire_dev;Username=r2wai;Password=${DB_PASSWORD:=changeme_dev}"
  },
  "Authentication": {
    "Jwt": {
      "SecretKey": "${JWT_SECRET:=DevOnlyKey_ChangeBeforeDeployment_MinLength32Chars!}",
      "Issuer": "R2WAI",
      "Audience": "R2WAI-API",
      "ExpirationMinutes": "480"
    },
    "ApiKeys": []
  },
  "Security": {
    "EncryptionKey": "${ENCRYPTION_KEY}"
  },
  "Storage": {
    "Provider": "Local",
    "Local": {
      "Path": "App_Data/Storage"
    }
  },
  "CORS": {
