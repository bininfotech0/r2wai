{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=r2wai;Username=r2wai;Password=${DB_PASSWORD:-r2wai_secret}",
    "Redis": "localhost:6379"
  },
  "Authentication": {
    "Jwt": {
      "SecretKey": "${JWT_SECRET}",
      "Issuer": "R2WAI",
      "Audience": "R2WAI-API",
      "ExpirationMinutes": "15",
      "RefreshTokenExpirationDays": "7"
    },
    "EntraId": {
      "Instance": "https://login.microsoftonline.com",
      "TenantId": "${ENTRA_TENANT_ID:}",
      "ClientId": "${ENTRA_CLIENT_ID:}",
      "ClientSecret": "${ENTRA_CLIENT_SECRET:}"
    },
    "ApiKeys": []
  },
  "Storage": {
    "Provider": "${STORAGE_PROVIDER:-Local}",
    "MinIO": {
      "Endpoint": "${MINIO_ENDPOINT:-localhost:9000}",
      "AccessKey": "${MINIO_ACCESS_KEY:-minioadmin}",
      "SecretKey": "${MINIO_SECRET_KEY:-minioadmin}",
      "Bucket": "r2wai-documents"
    },
    "Local": {
      "Path": "App_Data/Storage"
    }
  },
  "AI": {
    "Provider": "${AI_PROVIDER:-openai}",
    "OpenAI": {
      "ApiKey": "${OPENAI_API_KEY:}",
      "ModelId": "gpt-4"
    },
    "Ollama": {
      "Endpoint": "${OLLAMA_ENDPOINT:-http://localhost:11434}",
      "ModelId": "${OLLAMA_MODEL:-llama3}",
      "EmbeddingModel": "${OLLAMA_EMBEDDING_MODEL:-nomic-embed-text}"
    },
    "AzureOpenAI": {
      "Endpoint": "${AZURE_OPENAI_ENDPOINT:}",
      "ApiKey": "${AZURE_OPENAI_API_KEY:}",
      "DeploymentName": ""
    }
  },
  "VectorStore": {
    "Provider": "pgvector",
    "VectorSize": 1536
  },
  "Cache": {
    "Redis": {
      "ConnectionString": "${REDIS_CONNECTION:-localhost:6379}",
      "InstanceName": "R2WAI:"
    }
  },
  "CORS": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "https://localhost:3000",
      "http://localhost:3001",
      "http://localhost:5000",
      "https://localhost:5143"
    ]
  },
  "Tenant": {
    "DefaultTenantId": "00000000-0000-0000-0000-000000000001"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/r2wai-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30
        }
      }
    ],
    "Enrich": ["FromLogContext", "WithMachineName", "WithThreadId"]
  },
  "AllowedHosts": "*"
}
