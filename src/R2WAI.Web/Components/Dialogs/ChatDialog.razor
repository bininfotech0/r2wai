@inject ISnackbar Snackbar
@inject AuthenticatedHttpClient Http
@inject IJSRuntime JS
@implements IAsyncDisposable

<MudDialog>
    <TitleContent>
        <div class="d-flex align-center gap-2" style="position: relative;">
            <div class="icon-container icon-container--primary" style="width: 32px; height: 32px; border-radius: 8px;">
                <MudIcon Icon="@Icons.Material.Filled.SmartToy" Color="Color.Primary" Size="Size.Small" />
            </div>
            <div>
                <MudText Typo="Typo.h6" Style="font-weight: 700;">Chat with @_assistantName</MudText>
            </div>
            @if (_streaming)
            {
                <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined"
                         Style="font-size: 0.6rem; height: 18px; animation: pulse-soft 1.5s infinite;">streaming</MudChip>
            }
            @if (_voiceChatActive)
            {
                <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Filled"
                         Style="font-size: 0.6rem; height: 18px; animation: pulse-soft 1.5s infinite;">
                    <MudIcon Icon="@Icons.Material.Filled.GraphicEq" Size="Size.Small" Style="font-size: 12px; margin-right: 2px;" />voice
                </MudChip>
            }
        </div>
    </TitleContent>
    <DialogContent>
        <MudPaper @ref="_chatContainer" Class="pa-3 mb-3 chat-scroll-mobile" Style="max-height: min(480px, 55vh); overflow-y: auto; scroll-behavior: smooth;" Elevation="0" id="chat-scroll-container">
            @foreach (var msg in _messages)
            {
                <div class="d-flex @(msg.IsUser ? "justify-end" : "justify-start") mb-3">
                    <div class="@(msg.IsUser ? "chat-message chat-message--user" : "chat-message chat-message--assistant")">
                        <MudText Typo="Typo.caption" Style="@(msg.IsUser ? "color: rgba(255,255,255,0.6);" : "")" Color="@(msg.IsUser ? Color.Inherit : Color.Secondary)" Class="mb-1">
                            @(msg.IsUser ? "You" : "Assistant")
                        </MudText>
                        <MudText Typo="Typo.body2" Style="white-space: pre-wrap; line-height: 1.6;">@msg.Content</MudText>

                        @if (!msg.IsUser && msg.Citations.Count > 0)
                        {
                            <MudDivider Class="my-2" />
                            <div class="d-flex align-center gap-1 mb-1">
                                <MudIcon Icon="@Icons.Material.Outlined.MenuBook" Size="Size.Small" Color="Color.Info" />
                                <MudText Typo="Typo.caption" Style="font-weight: 700;" Color="Color.Info">Sources</MudText>
                            </div>
                            @foreach (var citation in msg.Citations)
                            {
                                <MudPaper Class="pa-2 mb-1" Elevation="0"
                                          Style="border: 1px solid var(--mud-palette-info); border-left: 3px solid var(--mud-palette-info); border-radius: 6px; font-size: 0.75rem;">
                                    <div class="d-flex justify-space-between align-center">
                                        <MudText Typo="Typo.caption" Style="font-weight: 600;">
                                            [@citation.Index] @citation.SourceName
                                        </MudText>
                                        <MudChip T="string" Size="Size.Small" Color="Color.Default"
                                                 Style="font-size: 0.6rem; height: 16px;">
                                            @citation.Score.ToString("P0") match
                                        </MudChip>
                                    </div>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary" Style="font-size: 0.7rem;">
                                        @citation.Preview
                                    </MudText>
                                </MudPaper>
                            }
                        }

                        <div class="d-flex align-center gap-1 mt-1">
                            @if (!msg.IsUser && _ttsSupported)
                            {
                                <MudIconButton Icon="@(_speakingMessageIndex == _messages.IndexOf(msg) ? Icons.Material.Filled.StopCircle : Icons.Material.Filled.VolumeUp)"
                                               Size="Size.Small" Color="@(_speakingMessageIndex == _messages.IndexOf(msg) ? Color.Primary : Color.Default)"
                                               OnClick="@(() => ToggleSpeakMessage(msg))"
                                               Style="width: 26px; height: 26px; opacity: 0.6;"
                                               aria-label="@(_speakingMessageIndex == _messages.IndexOf(msg) ? "Stop speaking" : "Read aloud")" />
                            }
                            @if (!msg.IsUser && msg.SuggestsWorkflow)
                            {
                                <MudButton Variant="Variant.Filled" Color="Color.Success" Size="Size.Small"
                                           StartIcon="@Icons.Material.Filled.PlayArrow"
                                           OnClick="@(() => ExecuteWorkflow(msg.Content))"
                                           Style="border-radius: 8px;">
                                    Execute Workflow
                                </MudButton>
                            }
                        </div>
                    </div>
                </div>
            }

            @* Typing Indicator *@
            @if (_streaming && string.IsNullOrEmpty(_streamBuffer))
            {
                <div class="d-flex justify-start mb-3">
                    <div class="chat-message chat-message--assistant">
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2">Assistant</MudText>
                        <div class="typing-indicator">
                            <span class="typing-dot"></span>
                            <span class="typing-dot"></span>
                            <span class="typing-dot"></span>
                        </div>
                    </div>
                </div>
            }
            else if (_streaming && !string.IsNullOrEmpty(_streamBuffer))
            {
                <div class="d-flex justify-start mb-3">
                    <div class="chat-message chat-message--assistant">
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">Assistant</MudText>
                        <MudText Typo="Typo.body2" Style="white-space: pre-wrap; line-height: 1.6;">@_streamBuffer<span class="typing-cursor">|</span></MudText>
                    </div>
                </div>
            }
            else if (_sending)
            {
                <div class="d-flex justify-start mb-3">
                    <div class="chat-message chat-message--assistant">
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2">Assistant</MudText>
                        <div class="typing-indicator">
                            <span class="typing-dot"></span>
                            <span class="typing-dot"></span>
                            <span class="typing-dot"></span>
                        </div>
                    </div>
                </div>
            }
        </MudPaper>

        @* Voice Status *@
        @if (_isListening)
        {
            <div class="d-flex align-center gap-2 mb-2 pa-2" style="background: rgba(76, 175, 80, 0.08); border-radius: 8px; border: 1px solid rgba(76, 175, 80, 0.2);">
                <div class="voice-pulse-dot"></div>
                <MudText Typo="Typo.caption" Color="Color.Success" Style="font-weight: 600;">
                    @(_interimTranscript.Length > 0 ? _interimTranscript : "Listening...")
                </MudText>
            </div>
        }

        @* Input Area *@
        <div style="border: 1.5px solid var(--mud-palette-divider); border-radius: 12px; padding: 8px 12px; background: var(--r2-glass-bg, rgba(255,255,255,0.7)); backdrop-filter: blur(8px);">
            <div class="d-flex align-center gap-2">
                @if (_sttSupported)
                {
                    <MudTooltip Text="@(_voiceChatActive ? "Stop voice chat" : _isListening ? "Stop listening" : "Voice input")">
                        <MudIconButton Icon="@(_voiceChatActive ? Icons.Material.Filled.GraphicEq : _isListening ? Icons.Material.Filled.MicOff : Icons.Material.Filled.Mic)"
                                       Color="@(_voiceChatActive ? Color.Success : _isListening ? Color.Error : Color.Default)"
                                       OnClick="ToggleVoiceInput" Disabled="@(_sending || _streaming)"
                                       Size="Size.Small"
                                       Style="@(_isListening ? "animation: pulse-soft 1.5s infinite;" : "")"
                                       aria-label="@(_isListening ? "Stop voice input" : "Start voice input")" />
                    </MudTooltip>
                }
                <MudTextField @bind-Value="_input" Placeholder="@(_isListening ? "Speak now..." : "Type your message...")" Variant="Variant.Text"
                              OnKeyUp="HandleKeyUp" Disabled="@(_sending || _streaming)"
                              Margin="Margin.Dense" Style="flex: 1;" DisableUnderLine="true" />
                <MudIconButton Icon="@Icons.Material.Filled.Send" Color="Color.Primary"
                               OnClick="SendMessage" Disabled="@(_sending || _streaming || string.IsNullOrWhiteSpace(_input))"
                               Size="Size.Small" Style="background: var(--r2-gradient-primary, linear-gradient(135deg, #7C3AED, #6D28D9)); color: white; border-radius: 8px; width: 36px; height: 36px;"
                               aria-label="Send message" />
            </div>
            @if (_sttSupported && _ttsSupported)
            {
                <div class="d-flex align-center justify-end mt-1" style="padding-top: 2px; border-top: 1px solid var(--mud-palette-divider); opacity: 0.7;">
                    <MudTooltip Text="Voice Chat mode: auto-listen after each response is spoken">
                        <div class="d-flex align-center gap-1" style="cursor: pointer;" @onclick="ToggleVoiceChatMode">
                            <MudIcon Icon="@Icons.Material.Filled.RecordVoiceOver" Size="Size.Small"
                                     Color="@(_voiceChatActive ? Color.Success : Color.Default)" Style="font-size: 14px;" />
                            <MudText Typo="Typo.caption" Color="@(_voiceChatActive ? Color.Success : Color.Secondary)"
                                     Style="font-size: 0.65rem; font-weight: 600;">
                                Voice Chat @(_voiceChatActive ? "ON" : "OFF")
                            </MudText>
                        </div>
                    </MudTooltip>
                </div>
            }
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Close" Color="Color.Default">Close</MudButton>
    </DialogActions>
</MudDialog>

<style>
    .typing-indicator {
        display: flex;
        gap: 5px;
        padding: 4px 0;
        align-items: center;
    }
    .typing-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--r2-primary-light, #A78BFA);
        animation: typingBounce 1.4s ease-in-out infinite;
    }
    .typing-dot:nth-child(2) { animation-delay: 0.2s; }
    .typing-dot:nth-child(3) { animation-delay: 0.4s; }
    @@keyframes typingBounce {
        0%, 80%, 100% { transform: scale(0.6); opacity: 0.3; }
        40% { transform: scale(1.2); opacity: 1; }
    }
    .typing-cursor {
        animation: cursorBlink 1s infinite;
        color: var(--mud-palette-primary);
        font-weight: 300;
    }
    @@keyframes cursorBlink {
        0%, 100% { opacity: 1; }
        50% { opacity: 0; }
    }
</style>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public string AssistantId { get; set; } = string.Empty;
    [Parameter] public string AssistantName { get; set; } = string.Empty;

    private MudPaper? _chatContainer;
    private string _assistantName => AssistantName;
    private string _input = string.Empty;
    private bool _sending;
    private bool _streaming;
    private string _streamBuffer = string.Empty;
    private Guid? _conversationId;
    private List<ChatMessage> _messages = new();

    private IJSObjectReference? _voiceModule;
    private DotNetObjectReference<ChatDialog>? _dotNetRef;
    private bool _sttSupported;
    private bool _ttsSupported;
    private bool _isListening;
    private bool _voiceChatActive;
    private string _interimTranscript = string.Empty;
    private int _speakingMessageIndex = -1;

    private static readonly string[] WorkflowKeywords = ["workflow", "onboard", "approve", "request", "process", "submit"];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                _voiceModule = await JS.InvokeAsync<IJSObjectReference>("import", "./js/voice.js");
                _dotNetRef = DotNetObjectReference.Create(this);
                var support = await _voiceModule.InvokeAsync<VoiceSupport>("isSupported");
                _sttSupported = support.Stt;
                _ttsSupported = support.Tts;
                StateHasChanged();
            }
            catch { }
        }
    }

    private async Task ToggleVoiceInput()
    {
        if (_voiceChatActive)
        {
            await StopVoiceChatMode();
            return;
        }

        if (_isListening)
        {
            await StopListening();
        }
        else
        {
            await StartListening();
        }
    }

    private async Task StartListening()
    {
        if (_voiceModule is null || _dotNetRef is null) return;
        _interimTranscript = string.Empty;
        await _voiceModule.InvokeAsync<bool>("startListening", _dotNetRef, "OnVoiceResult", "OnVoiceStatus", "en-US");
    }

    private async Task StopListening()
    {
        if (_voiceModule is null) return;
        _isListening = false;
        _interimTranscript = string.Empty;
        await _voiceModule.InvokeVoidAsync("stopListening");
        StateHasChanged();
    }

    [JSInvokable]
    public async Task OnVoiceResult(string transcript, bool isFinal)
    {
        if (isFinal)
        {
            _input = transcript;
            _interimTranscript = string.Empty;
            _isListening = false;
            StateHasChanged();
            if (_voiceChatActive)
            {
                await SendMessage();
            }
        }
        else
        {
            _interimTranscript = transcript;
            await InvokeAsync(StateHasChanged);
        }
    }

    [JSInvokable]
    public void OnVoiceStatus(string status)
    {
        _isListening = status == "listening";
        if (status == "not-allowed")
        {
            Snackbar.Add("Microphone access denied. Please allow microphone access in your browser settings.", Severity.Warning);
        }
        else if (status == "no-speech")
        {
            _interimTranscript = string.Empty;
        }
        InvokeAsync(StateHasChanged);
    }

    private async Task ToggleSpeakMessage(ChatMessage msg)
    {
        if (_voiceModule is null || _dotNetRef is null) return;
        var idx = _messages.IndexOf(msg);

        if (_speakingMessageIndex == idx)
        {
            await _voiceModule.InvokeVoidAsync("stopSpeaking");
            _speakingMessageIndex = -1;
            StateHasChanged();
            return;
        }

        _speakingMessageIndex = idx;
        StateHasChanged();
        await _voiceModule.InvokeAsync<bool>("speak", msg.Content, "en-US", 1.0, 1.0, _dotNetRef, "OnSpeakDone");
    }

    [JSInvokable]
    public async Task OnSpeakDone()
    {
        _speakingMessageIndex = -1;
        await InvokeAsync(StateHasChanged);

        if (_voiceChatActive)
        {
            await InvokeAsync(StartListening);
        }
    }

    private async Task ToggleVoiceChatMode()
    {
        if (_voiceChatActive)
        {
            await StopVoiceChatMode();
        }
        else
        {
            await StartVoiceChatMode();
        }
    }

    private async Task StartVoiceChatMode()
    {
        if (_voiceModule is null) return;
        _voiceChatActive = true;
        await _voiceModule.InvokeVoidAsync("setVoiceChatMode", true);
        Snackbar.Add("Voice Chat mode enabled — speak naturally!", Severity.Success);
        StateHasChanged();
        await StartListening();
    }

    private async Task StopVoiceChatMode()
    {
        if (_voiceModule is null) return;
        _voiceChatActive = false;
        await _voiceModule.InvokeVoidAsync("setVoiceChatMode", false);
        _isListening = false;
        _interimTranscript = string.Empty;
        StateHasChanged();
    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !_sending && !_streaming)
            await SendMessage();
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(_input)) return;

        var userMsg = _input;
        _messages.Add(new ChatMessage { IsUser = true, Content = userMsg });
        _input = string.Empty;
        _streaming = true;
        _streamBuffer = string.Empty;
        StateHasChanged();
        await ScrollToBottom();

        try
        {
            await StreamResponseAsync(userMsg);
        }
        catch (Exception ex)
        {
            _streaming = false;
            _sending = false;

            if (!string.IsNullOrEmpty(_streamBuffer))
            {
                _messages.Add(new ChatMessage { IsUser = false, Content = _streamBuffer });
                _streamBuffer = string.Empty;
            }
            else
            {
                await FallbackToNonStreamingAsync(userMsg);
            }

            Snackbar.Add($"Streaming failed, used fallback: {ex.Message}", Severity.Warning);
        }
        finally
        {
            _streaming = false;
            _sending = false;
            StateHasChanged();
            await ScrollToBottom();
        }
    }

    private async Task StreamResponseAsync(string userMsg)
    {
        using var request = new HttpRequestMessage(HttpMethod.Post, $"/api/v1/assistants/{AssistantId}/chat/stream");
        request.Content = JsonContent.Create(new
        {
            Message = userMsg,
            ConversationId = _conversationId
        });

        using var response = await Http.SendAsync(request, HttpCompletionOption.ResponseHeadersRead);

        if (!response.IsSuccessStatusCode)
        {
            throw new HttpRequestException($"Status {(int)response.StatusCode}");
        }

        using var stream = await response.Content.ReadAsStreamAsync();
        using var reader = new System.IO.StreamReader(stream);

        var citations = new List<CitationItem>();
        string? currentEventType = null;

        while (!reader.EndOfStream)
        {
            var line = await reader.ReadLineAsync();
            if (line is null) continue;

            if (line.StartsWith("event: "))
            {
                currentEventType = line[7..].Trim();
                continue;
            }

            if (!line.StartsWith("data: ")) continue;

            var data = line[6..];
            if (data == "[DONE]") break;

            var eventType = currentEventType ?? "chunk";
            currentEventType = null;

            try
            {
                if (eventType == "chunk")
                {
                    var parsed = System.Text.Json.JsonSerializer.Deserialize<StreamChunkData>(data,
                        new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                    if (parsed?.Content is not null)
                    {
                        _streamBuffer += parsed.Content;
                        StateHasChanged();
                        await ScrollToBottom();
                    }
                }
                else if (eventType == "citations")
                {
                    var parsed = System.Text.Json.JsonSerializer.Deserialize<StreamCitationsData>(data,
                        new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                    if (parsed?.Citations is not null)
                        citations = parsed.Citations;
                }
                else if (eventType == "done")
                {
                    break;
                }
                else if (eventType == "error")
                {
                    var parsed = System.Text.Json.JsonSerializer.Deserialize<StreamErrorData>(data,
                        new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                    throw new Exception(parsed?.Message ?? "Stream error");
                }
            }
            catch (System.Text.Json.JsonException) { }
        }

        var assistantMsg = new ChatMessage
        {
            IsUser = false,
            Content = _streamBuffer,
            Citations = citations,
            SuggestsWorkflow = WorkflowKeywords.Any(kw =>
                _streamBuffer.Contains(kw, StringComparison.OrdinalIgnoreCase))
        };
        _messages.Add(assistantMsg);
        _streamBuffer = string.Empty;

        if (_voiceChatActive && _voiceModule is not null && _dotNetRef is not null)
        {
            _speakingMessageIndex = _messages.Count - 1;
            StateHasChanged();
            await _voiceModule.InvokeAsync<bool>("speak", assistantMsg.Content, "en-US", 1.0, 1.0, _dotNetRef, "OnSpeakDone");
        }
    }

    private async Task FallbackToNonStreamingAsync(string userMsg)
    {
        _sending = true;
        _streaming = false;
        StateHasChanged();

        var assistantMsg = new ChatMessage { IsUser = false, Content = string.Empty };
        _messages.Add(assistantMsg);

        try
        {
            var result = await Http.PostAsJsonAsync($"/api/v1/assistants/{AssistantId}/chat",
                new { Message = userMsg, ConversationId = _conversationId });

            if (result.IsSuccessStatusCode)
            {
                var chatResponse = await result.Content.ReadFromJsonAsync<ChatResponse>();
                if (chatResponse is not null)
                {
                    assistantMsg.Content = chatResponse.Reply;
                    assistantMsg.SuggestsWorkflow = WorkflowKeywords.Any(kw =>
                        chatResponse.Reply.Contains(kw, StringComparison.OrdinalIgnoreCase));

                    if (chatResponse.ConversationId != Guid.Empty)
                        _conversationId = chatResponse.ConversationId;

                    if (chatResponse.Citations is not null)
                        assistantMsg.Citations = chatResponse.Citations;
                }
            }
            else
            {
                var errorBody = await result.Content.ReadAsStringAsync();
                assistantMsg.Content = result.StatusCode == System.Net.HttpStatusCode.InternalServerError
                    ? "The AI service is currently unavailable. Please check that an AI provider (OpenAI or Ollama) is configured in Settings > Models."
                    : $"Request failed ({(int)result.StatusCode}). {errorBody}";
            }
        }
        catch (Exception ex)
        {
            assistantMsg.Content = $"Error: {ex.Message}";
        }

        if (_voiceChatActive && !string.IsNullOrEmpty(assistantMsg.Content) && _voiceModule is not null && _dotNetRef is not null)
        {
            _speakingMessageIndex = _messages.IndexOf(assistantMsg);
            StateHasChanged();
            await _voiceModule.InvokeAsync<bool>("speak", assistantMsg.Content, "en-US", 1.0, 1.0, _dotNetRef, "OnSpeakDone");
        }
    }

    private async Task ScrollToBottom()
    {
        try
        {
            await JS.InvokeVoidAsync("eval",
                "document.getElementById('chat-scroll-container')?.scrollTo({top: 999999, behavior: 'smooth'})");
        }
        catch { }
    }

    private async Task ExecuteWorkflow(string context)
    {
        try
        {
            var workflows = await Http.GetFromJsonAsync<WorkflowsResult>("/api/v1/workflows");
            var first = workflows?.Items?.FirstOrDefault();
            if (first is not null)
            {
                await Http.PostAsJsonAsync($"/api/v1/workflows/{first.Id}/execute", new { Context = context });
                Snackbar.Add($"Workflow '{first.Name}' started", Severity.Success);
            }
            else
            {
                Snackbar.Add("No workflows available to execute", Severity.Warning);
            }
        }
        catch (Exception ex) { Snackbar.Add($"Workflow execution failed: {ex.Message}", Severity.Error); }
    }

    private async Task DisposeVoice()
    {
        if (_voiceModule is not null)
        {
            try { await _voiceModule.InvokeVoidAsync("dispose"); } catch { }
            await _voiceModule.DisposeAsync();
        }
        _dotNetRef?.Dispose();
    }

    private void Close() => MudDialog.Close();

    public async ValueTask DisposeAsync()
    {
        await DisposeVoice();
    }

    private class VoiceSupport
    {
        public bool Stt { get; set; }
        public bool Tts { get; set; }
    }

    private class ChatMessage
    {
        public bool IsUser { get; set; }
        public string Content { get; set; } = string.Empty;
        public bool SuggestsWorkflow { get; set; }
        public List<CitationItem> Citations { get; set; } = new();
    }

    private class CitationItem
    {
        public string SourceName { get; set; } = string.Empty;
        public string Preview { get; set; } = string.Empty;
        public float Score { get; set; }
        public int Index { get; set; }
    }

    private class StreamChunkData
    {
        public string? Content { get; set; }
    }

    private class StreamCitationsData
    {
        public List<CitationItem>? Citations { get; set; }
    }

    private class StreamErrorData
    {
        public string? Message { get; set; }
    }

    private class ChatResponse
    {
        public string Reply { get; set; } = string.Empty;
        public Guid ConversationId { get; set; }
        public int TokensUsed { get; set; }
        public List<CitationItem>? Citations { get; set; }
    }

    private class WorkflowsResult { public List<WorkflowItem> Items { get; set; } = new(); }
    private class WorkflowItem { public Guid Id { get; set; } public string Name { get; set; } = string.Empty; }
}
