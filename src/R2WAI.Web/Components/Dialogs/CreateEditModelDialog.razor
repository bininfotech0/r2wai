@inject ISnackbar Snackbar
@inject AuthenticatedHttpClient Http

<MudDialog>
    <TitleContent>
        <div class="d-flex align-center gap-2">
            <MudIcon Icon="@Icons.Material.Outlined.SmartToy" Color="Color.Primary" />
            <MudText Typo="Typo.h6">@(_isEdit ? "Edit Model Configuration" : "Add AI Model")</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <MudGrid Spacing="2">
            <MudItem xs="12">
                <MudText Typo="Typo.subtitle2" Class="mb-2" Style="font-weight: 600;">Basic Information</MudText>
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="_name" Label="Display Name" Required="true" Variant="Variant.Outlined"
                              Placeholder="e.g. GPT-4o Production" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudSelect T="string" Value="_provider" Label="Provider" Required="true" Variant="Variant.Outlined"
                           ValueChanged="OnProviderChanged">
                    <MudSelectItem T="string" Value="@("OpenAI")">OpenAI</MudSelectItem>
                    <MudSelectItem T="string" Value="@("AzureOpenAI")">Azure OpenAI</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Anthropic")">Anthropic</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Google")">Google AI</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Mistral")">Mistral AI</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Cohere")">Cohere</MudSelectItem>
                    <MudSelectItem T="string" Value="@("AI21Labs")">AI21 Labs</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Cerebras")">Cerebras</MudSelectItem>
                    <MudSelectItem T="string" Value="@("DeepSeek")">DeepSeek</MudSelectItem>
                    <MudSelectItem T="string" Value="@("FireworksAI")">Fireworks AI</MudSelectItem>
                    <MudSelectItem T="string" Value="@("GitHubModels")">GitHub Models</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Groq")">Groq</MudSelectItem>
                    <MudSelectItem T="string" Value="@("HuggingFace")">HuggingFace</MudSelectItem>
                    <MudSelectItem T="string" Value="@("NovitaAI")">Novita AI</MudSelectItem>
                    <MudSelectItem T="string" Value="@("OpenRouter")">OpenRouter</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Perplexity")">Perplexity</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Replicate")">Replicate</MudSelectItem>
                    <MudSelectItem T="string" Value="@("SambaNova")">SambaNova</MudSelectItem>
                    <MudSelectItem T="string" Value="@("TogetherAI")">Together AI</MudSelectItem>
                    <MudSelectItem T="string" Value="@("xAI")">xAI (Grok)</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Ollama")">Ollama (Local)</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6">
                @if (_provider == "Ollama")
                {
                    <MudAutocomplete T="string" @bind-Value="_modelId" Label="Model ID" Required="true"
                                     Variant="Variant.Outlined" Placeholder="@GetModelIdPlaceholder()"
                                     HelperText="@GetModelIdHelperText()"
                                     SearchFunc="SearchOllamaModels" Strict="false"
                                     ResetValueOnEmptyText="false" CoerceText="true" CoerceValue="true"
                                     AdornmentIcon="@Icons.Material.Outlined.Search"
                                     Adornment="Adornment.Start" AdornmentColor="Color.Default" />
                }
                else
                {
                    <MudTextField @bind-Value="_modelId" Label="Model ID" Required="true"
                                  HelperText="@GetModelIdHelperText()" Variant="Variant.Outlined"
                                  Placeholder="@GetModelIdPlaceholder()" />
                }
            </MudItem>

            <MudItem xs="12">
                <MudDivider Class="my-1" />
                <MudText Typo="Typo.subtitle2" Class="mb-2 mt-2" Style="font-weight: 600;">Connection</MudText>
            </MudItem>

            @if (_provider != "Ollama")
            {
                <MudItem xs="12">
                    <MudTextField @bind-Value="_apiKey" Label="API Key" Variant="Variant.Outlined"
                                  InputType="@(_showApiKey ? InputType.Text : InputType.Password)"
                                  Placeholder="@(_isEdit && _existingHasKey ? "••••••••  (leave blank to keep current)" : "Enter API key")"
                                  HelperText="@(_isEdit && _existingHasKey ? "Leave blank to keep the existing key" : "Required for cloud providers")"
                                  Adornment="Adornment.End" AdornmentIcon="@(_showApiKey ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                  OnAdornmentClick="@(() => _showApiKey = !_showApiKey)" />
                </MudItem>
            }

            <MudItem xs="12">
                <MudTextField @bind-Value="_endpoint" Label="Endpoint" Variant="Variant.Outlined"
                              Placeholder="@GetEndpointPlaceholder()"
                              HelperText="@GetEndpointHelperText()" />
            </MudItem>

            @if (_provider == "Ollama")
            {
                <MudItem xs="12">
                    <MudAlert Severity="Severity.Info" Dense="true" Icon="@Icons.Material.Outlined.Info">
                        <MudText Typo="Typo.caption">
                            The endpoint must be reachable from the <strong>R2WAI server</strong>, not your browser.
                            Default: <code>http://localhost:11434</code>. The Model ID must exactly match a model
                            pulled on that server (e.g. run <code>ollama list</code> to see available names).
                            Embedding models (e.g. <code>nomic-embed-text</code>) can also be registered here for knowledge base indexing.
                        </MudText>
                    </MudAlert>
                </MudItem>
            }

            <MudItem xs="12">
                <MudDivider Class="my-1" />
                <MudText Typo="Typo.subtitle2" Class="mb-2 mt-2" Style="font-weight: 600;">Model Parameters</MudText>
            </MudItem>

            <MudItem xs="12" sm="4">
                <MudTooltip Text="Maximum number of tokens the model can generate per response.">
                    <MudNumericField @bind-Value="_maxTokens" Label="Max Tokens" Min="1" Max="200000"
                                     HelperText="1–200,000" Variant="Variant.Outlined" />
                </MudTooltip>
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudTooltip Text="Controls randomness. 0 = deterministic, 1 = balanced, 2 = creative.">
                    <MudNumericField @bind-Value="_temperature" Label="Temperature" Min="0.0" Max="2.0" Step="0.1"
                                     HelperText="0.0–2.0" Variant="Variant.Outlined" />
                </MudTooltip>
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudTooltip Text="Nucleus sampling. Controls diversity by limiting cumulative probability.">
                    <MudNumericField @bind-Value="_topP" Label="Top P" Min="0.0" Max="1.0" Step="0.05"
                                     HelperText="0.0–1.0" Variant="Variant.Outlined" />
                </MudTooltip>
            </MudItem>

            <MudItem xs="12">
                <MudCheckBox @bind-Value="_isDefault" Label="Set as default model"
                             Color="Color.Primary" />
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-8">
                    The default model is used when no specific model is selected for an assistant.
                </MudText>
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text">Cancel</MudButton>
        <MudButton OnClick="Save" Variant="Variant.Filled" Color="Color.Primary" Disabled="_saving">
            @if (_saving)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Style="width:16px;height:16px;" Class="me-2" />
            }
            @(_saving ? "Saving..." : _isEdit ? "Update Model" : "Add Model")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public string? EditId { get; set; }

    private bool _isEdit => !string.IsNullOrEmpty(EditId);
    private string _name = string.Empty;
    private string _provider = "OpenAI";
    private string _modelId = string.Empty;
    private string? _apiKey;
    private bool _showApiKey;
    private bool _existingHasKey;
    private string? _endpoint;
    private int? _maxTokens = 4096;
    private double? _temperature = 0.7;
    private double? _topP;
    private bool _isDefault;
    private bool _saving;

    protected override async Task OnInitializedAsync()
    {
        if (_isEdit)
        {
            try
            {
                var modelsResult = await Http.GetFromJsonAsync<ModelsListResult>("/api/v1/admin/models");
                var match = modelsResult?.Items?.FirstOrDefault(m => m.Id.ToString() == EditId);
                if (match is not null)
                {
                    _name = match.Name;
                    _provider = match.Provider;
                    _modelId = match.ModelId;
                    _endpoint = match.Endpoint;
                    _maxTokens = match.MaxTokens;
                    _temperature = match.Temperature;
                    _topP = match.TopP;
                    _isDefault = match.IsDefault;
                    _existingHasKey = match.HasApiKey;
                }
            }
            catch { Snackbar.Add("Failed to load model", Severity.Error); }
        }
    }

    private void OnProviderChanged(string provider)
    {
        _provider = provider;
        if (provider == "Ollama" && string.IsNullOrEmpty(_endpoint))
            _endpoint = "http://localhost:11434";
    }

    private string GetModelIdHelperText() => _provider switch
    {
        "OpenAI" => "e.g. gpt-4o, gpt-4o-mini, o1",
        "AzureOpenAI" => "Your deployment name",
        "Anthropic" => "e.g. claude-sonnet-4-6, claude-haiku-4-5-20251001",
        "Google" => "e.g. gemini-2.5-pro, gemini-2.5-flash",
        "Mistral" => "e.g. mistral-large-latest, codestral",
        "Cohere" => "e.g. command-r-plus, command-r",
        "AI21Labs" => "e.g. jamba-1.5-large, jamba-1.5-mini",
        "Cerebras" => "e.g. llama3.1-8b, llama-3.3-70b",
        "DeepSeek" => "e.g. deepseek-chat, deepseek-reasoner",
        "FireworksAI" => "e.g. accounts/fireworks/models/llama-v3p3-70b-instruct",
        "GitHubModels" => "e.g. gpt-4o, gpt-4o-mini, Llama-3.3-70B",
        "Groq" => "e.g. llama-3.3-70b-versatile, deepseek-r1-distill-llama-70b",
        "HuggingFace" => "e.g. meta-llama/Llama-3-70b",
        "NovitaAI" => "e.g. meta-llama/llama-3.1-8b-instruct",
        "OpenRouter" => "e.g. anthropic/claude-sonnet-4, openai/gpt-4o",
        "Perplexity" => "e.g. sonar-pro, sonar-deep-research",
        "Replicate" => "e.g. meta/meta-llama-3-70b-instruct",
        "SambaNova" => "e.g. Meta-Llama-3.1-405B-Instruct",
        "TogetherAI" => "e.g. meta-llama/Meta-Llama-3.1-8B-Instruct-Turbo",
        "xAI" => "e.g. grok-2, grok-3",
        "Ollama" => "e.g. llama3, mistral, codellama",
        _ => "Model identifier"
    };

    private string GetModelIdPlaceholder() => _provider switch
    {
        "OpenAI" => "gpt-4o",
        "AzureOpenAI" => "my-gpt4-deployment",
        "Anthropic" => "claude-sonnet-4-6",
        "Google" => "gemini-2.5-pro",
        "Mistral" => "mistral-large-latest",
        "Cohere" => "command-r-plus",
        "AI21Labs" => "jamba-1.5-large",
        "Cerebras" => "llama3.1-8b",
        "DeepSeek" => "deepseek-chat",
        "FireworksAI" => "accounts/fireworks/models/llama-v3p3-70b-instruct",
        "GitHubModels" => "gpt-4o",
        "Groq" => "llama-3.3-70b-versatile",
        "HuggingFace" => "meta-llama/Llama-3-70b",
        "NovitaAI" => "meta-llama/llama-3.1-8b-instruct",
        "OpenRouter" => "anthropic/claude-sonnet-4",
        "Perplexity" => "sonar-pro",
        "Replicate" => "meta/meta-llama-3-70b-instruct",
        "SambaNova" => "Meta-Llama-3.1-405B-Instruct",
        "TogetherAI" => "meta-llama/Meta-Llama-3.1-8B-Instruct-Turbo",
        "xAI" => "grok-2",
        "Ollama" => "llama3",
        _ => ""
    };

    private string GetEndpointPlaceholder() => _provider switch
    {
        "AzureOpenAI" => "https://your-resource.openai.azure.com/",
        "OpenAI" => "https://api.openai.com",
        "Anthropic" => "https://api.anthropic.com",
        "Google" => "https://generativelanguage.googleapis.com",
        "Mistral" => "https://api.mistral.ai",
        "Cohere" => "https://api.cohere.com",
        "AI21Labs" => "https://api.ai21.com",
        "Cerebras" => "https://api.cerebras.ai",
        "DeepSeek" => "https://api.deepseek.com",
        "FireworksAI" => "https://api.fireworks.ai",
        "GitHubModels" => "https://models.inference.ai.azure.com",
        "Groq" => "https://api.groq.com",
        "HuggingFace" => "https://api-inference.huggingface.co",
        "NovitaAI" => "https://api.novita.ai",
        "OpenRouter" => "https://openrouter.ai",
        "Perplexity" => "https://api.perplexity.ai",
        "Replicate" => "https://api.replicate.com",
        "SambaNova" => "https://api.sambanova.ai",
        "TogetherAI" => "https://api.together.xyz",
        "xAI" => "https://api.x.ai",
        "Ollama" => "http://localhost:11434",
        _ => "Leave blank for default endpoint"
    };

    private string GetEndpointHelperText() => _provider switch
    {
        "AzureOpenAI" => "Required. Your Azure OpenAI resource URL",
        "Ollama" => "Default: http://localhost:11434 — must be reachable from the R2WAI server",
        _ => "Optional. Leave blank for provider's default endpoint"
    };

    private static readonly string[] _ollamaModels =
    [
        // Chat / instruction models
        "llama3.2:1b", "llama3.2:3b", "llama3.2",
        "llama3.1:8b", "llama3.1:70b", "llama3.1:405b", "llama3.1",
        "llama3:8b", "llama3:70b", "llama3",
        "mistral:7b", "mistral",
        "mistral-nemo", "mistral-large",
        "codellama:7b", "codellama:13b", "codellama:34b", "codellama",
        "gemma2:2b", "gemma2:9b", "gemma2:27b", "gemma2",
        "phi3:mini", "phi3:medium", "phi3:large", "phi3",
        "phi4", "phi4-mini",
        "qwen2.5:0.5b", "qwen2.5:1.5b", "qwen2.5:3b", "qwen2.5:7b",
        "qwen2.5:14b", "qwen2.5:32b", "qwen2.5:72b", "qwen2.5",
        "qwen2.5-coder:7b", "qwen2.5-coder:32b",
        "deepseek-r1:7b", "deepseek-r1:14b", "deepseek-r1:32b", "deepseek-r1:70b", "deepseek-r1",
        "deepseek-coder-v2",
        // Embedding models
        "nomic-embed-text", "mxbai-embed-large", "all-minilm",
        "granite-embedding", "snowflake-arctic-embed",
    ];

    private Task<IEnumerable<string>> SearchOllamaModels(string value, CancellationToken _)
    {
        var results = string.IsNullOrWhiteSpace(value)
            ? _ollamaModels
            : _ollamaModels.Where(m => m.Contains(value, StringComparison.OrdinalIgnoreCase));
        return Task.FromResult(results);
    }

    private async Task Save()
    {
        if (string.IsNullOrWhiteSpace(_name) || string.IsNullOrWhiteSpace(_provider) || string.IsNullOrWhiteSpace(_modelId))
        {
            Snackbar.Add("Name, Provider, and Model ID are required", Severity.Warning);
            return;
        }

        _saving = true;
        try
        {
            var payload = new
            {
                Name = _name,
                Provider = _provider,
                ModelId = _modelId,
                ApiKey = string.IsNullOrWhiteSpace(_apiKey) ? null : _apiKey,
                Endpoint = _endpoint,
                MaxTokens = _maxTokens,
                Temperature = _temperature,
                TopP = _topP,
                IsDefault = _isDefault
            };

            if (_isEdit)
            {
                await Http.PutAsJsonAsync($"/api/v1/admin/models/{EditId}", payload);
                Snackbar.Add("Model updated", Severity.Success);
            }
            else
            {
                await Http.PostAsJsonAsync("/api/v1/admin/models", payload);
                Snackbar.Add("Model created", Severity.Success);
            }
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex) { Snackbar.Add($"Save failed: {ex.Message}", Severity.Error); }
        finally { _saving = false; }
    }

    private void Cancel() => MudDialog.Cancel();

    private class ModelsListResult { public List<ModelEditDto> Items { get; set; } = new(); }
    private class ModelEditDto
    {
        public Guid Id { get; set; }
        public string Name { get; set; } = string.Empty;
        public string Provider { get; set; } = string.Empty;
        public string ModelId { get; set; } = string.Empty;
        public string? Endpoint { get; set; }
        public int? MaxTokens { get; set; }
        public double? Temperature { get; set; }
        public double? TopP { get; set; }
        public bool IsDefault { get; set; }
        public bool HasApiKey { get; set; }
    }
}
