@inject ISnackbar Snackbar
@inject AuthenticatedHttpClient Http

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">Edit Document</MudText>
    </TitleContent>
    <DialogContent>
        <MudGrid>
            <MudItem xs="12">
                <MudTextField @bind-Value="_name" Label="Name" Variant="Variant.Outlined"
                              Required="true" RequiredError="Name is required."
                              Disabled="_saving" AutoFocus="true" />
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="_description" Label="Description (optional)" Lines="2"
                              Variant="Variant.Outlined" Disabled="_saving" />
            </MudItem>
            <MudItem xs="12">
                <MudSelect T="Guid?" @bind-Value="_knowledgeBaseId" Label="Knowledge Base (optional)"
                           Variant="Variant.Outlined" Clearable="true" Disabled="@(_saving || _loadingKnowledgeBases)">
                    @foreach (var kb in _knowledgeBases)
                    {
                        <MudSelectItem T="Guid?" Value="@((Guid?)kb.Id)">@kb.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Disabled="_saving">Cancel</MudButton>
        <MudButton OnClick="Save" Variant="Variant.Filled" Color="Color.Primary"
                   Disabled="@(_saving || string.IsNullOrWhiteSpace(_name))">
            @if (_saving)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2" />
                <span>Saving...</span>
            }
            else
            {
                <span>Save Changes</span>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public Guid DocumentId { get; set; }
    [Parameter] public string Name { get; set; } = string.Empty;
    [Parameter] public string? Description { get; set; }
    [Parameter] public Guid? KnowledgeBaseId { get; set; }

    private string _name = string.Empty;
    private string? _description;
    private Guid? _knowledgeBaseId;
    private bool _saving;
    private bool _loadingKnowledgeBases = true;
    private List<KnowledgeBaseOption> _knowledgeBases = new();

    protected override async Task OnInitializedAsync()
    {
        _name = Name;
        _description = Description;
        _knowledgeBaseId = KnowledgeBaseId;

        try
        {
            var result = await Http.GetFromJsonAsync<KbResult>("/api/v1/knowledgebases");
            _knowledgeBases = result?.Items ?? new();
        }
        catch { Snackbar.Add("Failed to load knowledge bases.", Severity.Warning); }
        finally { _loadingKnowledgeBases = false; }
    }

    private async Task Save()
    {
        if (string.IsNullOrWhiteSpace(_name)) return;

        _saving = true;
        try
        {
            var response = await Http.PatchAsJsonAsync($"/api/v1/documents/{DocumentId}", new
            {
                Name = _name,
                Description = _description,
                KnowledgeBaseId = _knowledgeBaseId
            });

            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("Document updated", Severity.Success);
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                Snackbar.Add("Failed to update document.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Update failed: {ex.Message}", Severity.Error);
        }
        finally { _saving = false; }
    }

    private void Cancel() => MudDialog.Cancel();

    private class KbResult { public List<KnowledgeBaseOption> Items { get; set; } = new(); }
    private class KnowledgeBaseOption
    {
        public Guid Id { get; set; }
        public string Name { get; set; } = string.Empty;
    }
}
