@inject ISnackbar Snackbar
@inject AuthenticatedHttpClient Http

<MudDialog>
    <TitleContent>
        <div class="d-flex align-center gap-2">
            <MudIcon Icon="@Icons.Material.Outlined.VpnKey" Color="Color.Primary" />
            <MudText Typo="Typo.h6">API Key for @ModelName</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3" Style="font-size: 0.8125rem;">
            API keys are encrypted at rest and never displayed after saving.
        </MudAlert>
        <MudTextField @bind-Value="_apiKey" Label="API Key" Variant="Variant.Outlined"
                      InputType="@(_showKey ? InputType.Text : InputType.Password)"
                      Placeholder="Enter your API key"
                      Adornment="Adornment.End" AdornmentIcon="@(_showKey ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                      OnAdornmentClick="@(() => _showKey = !_showKey)"
                      Required="true" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text">Cancel</MudButton>
        <MudButton OnClick="RemoveKey" Variant="Variant.Outlined" Color="Color.Error" Disabled="_saving">
            Remove Key
        </MudButton>
        <MudButton OnClick="SaveKey" Variant="Variant.Filled" Color="Color.Primary" Disabled="_saving || string.IsNullOrWhiteSpace(_apiKey)">
            @(_saving ? "Saving..." : "Save Key")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public Guid ModelId { get; set; }
    [Parameter] public string ModelName { get; set; } = string.Empty;

    private string _apiKey = string.Empty;
    private bool _showKey;
    private bool _saving;

    private async Task SaveKey()
    {
        if (string.IsNullOrWhiteSpace(_apiKey)) return;

        _saving = true;
        try
        {
            var response = await Http.PutAsJsonAsync($"/api/v1/admin/models/{ModelId}/api-key", new { ApiKey = _apiKey });
            response.EnsureSuccessStatusCode();
            Snackbar.Add("API key saved securely", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to save API key: {ex.Message}", Severity.Error);
        }
        finally { _saving = false; }
    }

    private async Task RemoveKey()
    {
        _saving = true;
        try
        {
            var response = await Http.DeleteAsync($"/api/v1/admin/models/{ModelId}/api-key");
            response.EnsureSuccessStatusCode();
            Snackbar.Add("API key removed", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to remove API key: {ex.Message}", Severity.Error);
        }
        finally { _saving = false; }
    }

    private void Cancel() => MudDialog.Cancel();
}
