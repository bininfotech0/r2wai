<ErrorBoundary @ref="_errorBoundary">
    <ChildContent>
        <CascadingAuthenticationState>
            <Routes />
        </CascadingAuthenticationState>
    </ChildContent>
    <ErrorContent Context="ex">
        <div style="min-height: 100vh; display: flex; align-items: center; justify-content: center; background: var(--r2-gradient-surface, linear-gradient(180deg, rgba(124,58,237,0.02) 0%, transparent 60%)); font-family: 'Inter', sans-serif; padding: 24px;">
            <div class="error-shake" style="text-align: center; max-width: 480px;">
                <div class="empty-state-icon" style="width: 80px; height: 80px; margin: 0 auto 24px;">
                    <MudIcon Icon="@Icons.Material.Outlined.ErrorOutline" Size="Size.Large" Color="Color.Error" />
                </div>
                <MudText Typo="Typo.h5" Style="font-weight: 800; letter-spacing: -0.03em;" Class="gradient-text">Something went wrong</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-2" Style="line-height: 1.6;">
                    An unexpected error occurred. This has been logged and our team will look into it.
                </MudText>
                <div class="d-flex gap-2 justify-center mt-6">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="btn-gradient"
                               StartIcon="@Icons.Material.Filled.Refresh" OnClick="Recover"
                               Style="border-radius: 10px; padding: 8px 24px;">
                        Try Again
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Default"
                               StartIcon="@Icons.Material.Filled.Home" Href="/"
                               Style="border-radius: 10px;">
                        Go Home
                    </MudButton>
                </div>
            </div>
        </div>
    </ErrorContent>
</ErrorBoundary>

@code {
    private ErrorBoundary? _errorBoundary;

    private void Recover()
    {
        _errorBoundary?.Recover();
    }
}
