@page "/assistant-studio/playground/{AssistantId}"
@attribute [Authorize]
@inject AuthenticatedHttpClient Http
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<PageTitle>R2WAI - Assistant Playground</PageTitle>

<div class="d-flex justify-space-between align-center mb-4">
    <div>
        <MudText Typo="Typo.h4">Assistant Playground</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">Test and tune your assistant before publishing</MudText>
    </div>
    <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Small"
               StartIcon="@Icons.Material.Filled.ArrowBack"
               OnClick="@(() => Navigation.NavigateTo("/assistant-studio"))">
        Back to Studio
    </MudButton>
</div>

<MudGrid>
    <MudItem xs="12" md="4">
        <MudPaper Elevation="0" Style="border: 1px solid var(--mud-palette-divider);" Class="pa-4">
            <MudText Typo="Typo.h6" Class="mb-3">@_assistantName</MudText>
            @if (_assistant is not null)
            {
                <MudSimpleTable Dense="true" Elevation="0">
                    <tbody>
                        <tr><td><strong>Type</strong></td><td>@_assistant.Type</td></tr>
                        <tr><td><strong>Status</strong></td>
                            <td><MudChip T="string" Size="Size.Small" Color="@(_assistant.IsActive ? Color.Success : Color.Warning)">
                                @(_assistant.IsActive ? "Published" : "Draft")</MudChip></td></tr>
                        <tr><td><strong>Knowledge Base</strong></td><td>@(_assistant.KnowledgeBaseId.HasValue ? "Linked" : "None")</td></tr>
                    </tbody>
                </MudSimpleTable>
            }

            <MudDivider Class="my-3" />
            <MudText Typo="Typo.subtitle2" Class="mb-2" Style="font-weight: 600;">System Prompt</MudText>
            <MudTextField @bind-Value="_systemPromptOverride" Label="Override system prompt (optional)"
                          Lines="4" Variant="Variant.Outlined" Margin="Margin.Dense" />

            <MudDivider Class="my-3" />
            <MudText Typo="Typo.subtitle2" Class="mb-2" Style="font-weight: 600;">
                <MudIcon Icon="@Icons.Material.Outlined.Tune" Size="Size.Small" Style="vertical-align: middle;" />
                Model Parameters
            </MudText>

            <MudSelect T="string" @bind-Value="_selectedModel" Label="Model" Variant="Variant.Outlined"
                       Margin="Margin.Dense" Class="mb-3" Dense="true">
                @foreach (var model in _availableModels)
                {
                    <MudSelectItem T="string" Value="@model.Id">@model.Name (@model.Provider)</MudSelectItem>
                }
            </MudSelect>

            <div class="d-flex justify-space-between align-center mb-1">
                <MudText Typo="Typo.caption" Color="Color.Secondary">Temperature</MudText>
                <MudText Typo="Typo.caption" Style="font-weight: 600; font-family: monospace;">@_temperature.ToString("F1")</MudText>
            </div>
            <MudSlider T="double" @bind-Value="_temperature" Min="0" Max="2" Step="0.1"
                       Color="Color.Primary" Class="mb-3" />
            <div class="d-flex justify-space-between">
                <MudText Typo="Typo.caption" Color="Color.Secondary" Style="font-size: 0.6rem;">Precise</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary" Style="font-size: 0.6rem;">Creative</MudText>
            </div>

            <div class="d-flex justify-space-between align-center mb-1 mt-2">
                <MudText Typo="Typo.caption" Color="Color.Secondary">Max Tokens</MudText>
                <MudText Typo="Typo.caption" Style="font-weight: 600; font-family: monospace;">@_maxTokens</MudText>
            </div>
            <MudSlider T="int" @bind-Value="_maxTokens" Min="256" Max="8192" Step="256"
                       Color="Color.Secondary" Class="mb-3" />

            <div class="d-flex justify-space-between align-center mb-1">
                <MudText Typo="Typo.caption" Color="Color.Secondary">Top P</MudText>
                <MudText Typo="Typo.caption" Style="font-weight: 600; font-family: monospace;">@_topP.ToString("F2")</MudText>
            </div>
            <MudSlider T="double" @bind-Value="_topP" Min="0" Max="1" Step="0.05"
                       Color="Color.Tertiary" Class="mb-2" />

            <MudDivider Class="my-3" />
            <div class="d-flex gap-2">
                <MudButton Variant="Variant.Text" Color="Color.Default" Size="Size.Small" FullWidth="true"
                           OnClick="ResetDefaults" StartIcon="@Icons.Material.Filled.RestartAlt">
                    Reset Defaults
                </MudButton>
                <MudButton Variant="Variant.Text" Color="Color.Error" Size="Size.Small" FullWidth="true"
                           OnClick="ClearConversation" StartIcon="@Icons.Material.Filled.Delete">
                    Clear Chat
                </MudButton>
            </div>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="8">
        <MudPaper Elevation="0" Style="border: 1px solid var(--mud-palette-divider); height: 75vh; display: flex; flex-direction: column;">
            @* Token Counter *@
            <div class="d-flex justify-space-between align-center pa-2 px-3" style="border-bottom: 1px solid var(--mud-palette-divider); min-height: 36px;">
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    @_messages.Count messages
                    @if (_totalTokens > 0) { <text> · ~@_totalTokens tokens</text> }
                </MudText>
                <div class="d-flex align-center gap-2">
                    <MudChip T="string" Size="Size.Small" Color="Color.Default" Style="font-size: 0.6rem; height: 18px;">
                        @(_selectedModel ?? "default")
                    </MudChip>
                    <MudChip T="string" Size="Size.Small" Color="Color.Default" Style="font-size: 0.6rem; height: 18px;">
                        T=@_temperature.ToString("F1")
                    </MudChip>
                </div>
            </div>

            <div style="flex: 1; overflow-y: auto; padding: 16px;" id="playground-messages">
                @if (_messages.Count == 0)
                {
                    <div class="d-flex flex-column align-center justify-center" style="height: 100%;">
                        <MudIcon Icon="@Icons.Material.Filled.Chat" Size="Size.Large" Color="Color.Secondary" />
                        <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mt-2">
                            Start a conversation to test your assistant
                        </MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">
                            Adjust model parameters on the left to see how responses change
                        </MudText>
                    </div>
                }
                else
                {
                    @foreach (var msg in _messages)
                    {
                        <MudPaper Class="pa-3 mb-2" Elevation="@(msg.IsUser ? 0 : 1)"
                                  Style="@(msg.IsUser ? "background-color: var(--mud-palette-primary-lighten); margin-left: 20%;" : "margin-right: 20%;")">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                @(msg.IsUser ? "You" : _assistantName)
                                <span style="float:right;">@msg.Timestamp.ToString("HH:mm:ss")</span>
                            </MudText>
                            @if (msg.IsUser)
                            {
                                <MudText Typo="Typo.body2" Style="white-space: pre-wrap;">@msg.Content</MudText>
                            }
                            else
                            {
                                <MarkdownRenderer Content="@msg.Content" Style="font-size: 0.875rem;" />
                            }
                            @if (!msg.IsUser && msg.TokenCount > 0)
                            {
                                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1" Style="font-size: 0.6rem;">
                                    ~@msg.TokenCount tokens · @msg.ResponseTime
                                </MudText>
                            }
                        </MudPaper>
                    }

                    @if (_sending)
                    {
                        <MudPaper Class="pa-3 mb-2" Elevation="1" Style="margin-right: 20%;">
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">@_assistantName</MudText>
                            <MudProgressLinear Indeterminate="true" Color="Color.Primary" Size="Size.Small" />
                        </MudPaper>
                    }
                }
            </div>

            <MudDivider />
            <div class="pa-3">
                <MudGrid>
                    <MudItem xs="10">
                        <MudTextField @bind-Value="_input" Label="Type a message..." Variant="Variant.Outlined"
                                      Margin="Margin.Dense" OnKeyUp="HandleKeyUp" Disabled="_sending" />
                    </MudItem>
                    <MudItem xs="2" Class="d-flex align-center">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                                   OnClick="SendMessage" Disabled="_sending">
                            Send
                        </MudButton>
                    </MudItem>
                </MudGrid>
            </div>
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    [Parameter] public string AssistantId { get; set; } = string.Empty;

    private AssistantDto? _assistant;
    private string _assistantName = "Assistant";
    private string _input = string.Empty;
    private string _systemPromptOverride = string.Empty;
    private bool _sending;
    private List<ChatMessage> _messages = new();
    private int _totalTokens;

    private string _selectedModel = string.Empty;
    private double _temperature = 0.7;
    private int _maxTokens = 4096;
    private double _topP = 1.0;
    private List<ModelOption> _availableModels = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        try
        {
            var assistantTask = Http.GetFromJsonAsync<AssistantDto>($"/api/v1/assistants/{AssistantId}");
            var modelsTask = Http.GetFromJsonAsync<ModelsResult>("/api/v1/admin/models");

            await Task.WhenAll(assistantTask, modelsTask);

            _assistant = assistantTask.Result;
            _assistantName = _assistant?.Name ?? "Assistant";

            var models = modelsTask.Result?.Items ?? new();
            _availableModels = models.Select(m => new ModelOption
            {
                Id = m.ModelId,
                Name = m.Name,
                Provider = m.Provider
            }).ToList();

            if (_availableModels.Count > 0)
                _selectedModel = _availableModels.First().Id;
        }
        catch
        {
            Snackbar.Add("Failed to load assistant or models.", Severity.Warning);
        }
        StateHasChanged();
    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !_sending) await SendMessage();
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(_input)) return;

        var userMsg = _input;
        _messages.Add(new ChatMessage { IsUser = true, Content = userMsg, Timestamp = DateTime.Now });
        _input = string.Empty;
        _sending = true;
        StateHasChanged();

        var sw = System.Diagnostics.Stopwatch.StartNew();

        try
        {
            var result = await Http.PostAsJsonAsync($"/api/v1/assistants/{AssistantId}/chat",
                new { Message = userMsg });

            sw.Stop();

            if (result.IsSuccessStatusCode)
            {
                var response = await result.Content.ReadFromJsonAsync<ChatResponse>();
                var tokenEstimate = (response?.Reply?.Length ?? 0) / 4;
                _totalTokens += tokenEstimate;

                _messages.Add(new ChatMessage
                {
                    IsUser = false,
                    Content = response?.Reply ?? "No response",
                    Timestamp = DateTime.Now,
                    TokenCount = tokenEstimate,
                    ResponseTime = $"{sw.ElapsedMilliseconds}ms"
                });
            }
            else
            {
                _messages.Add(new ChatMessage
                {
                    IsUser = false,
                    Content = result.StatusCode == System.Net.HttpStatusCode.InternalServerError
                        ? "The AI service is currently unavailable. Please check that an AI provider (OpenAI or Ollama) is configured in Settings > AI Models."
                        : $"Error: {result.StatusCode}",
                    Timestamp = DateTime.Now
                });
            }
        }
        catch (Exception ex)
        {
            _messages.Add(new ChatMessage { IsUser = false, Content = $"Error: {ex.Message}", Timestamp = DateTime.Now });
        }
        finally { _sending = false; StateHasChanged(); }
    }

    private void ClearConversation()
    {
        _messages.Clear();
        _totalTokens = 0;
        Snackbar.Add("Conversation cleared", Severity.Info);
    }

    private void ResetDefaults()
    {
        _temperature = 0.7;
        _maxTokens = 4096;
        _topP = 1.0;
        _systemPromptOverride = string.Empty;
        if (_availableModels.Count > 0)
            _selectedModel = _availableModels.First().Id;
        Snackbar.Add("Parameters reset to defaults", Severity.Info);
    }

    private class ChatMessage
    {
        public bool IsUser { get; set; }
        public string Content { get; set; } = string.Empty;
        public DateTime Timestamp { get; set; }
        public int TokenCount { get; set; }
        public string ResponseTime { get; set; } = string.Empty;
    }

    private class ChatResponse { public string Reply { get; set; } = string.Empty; }
    private class AssistantDto
    {
        public string Name { get; set; } = string.Empty;
        public string? Type { get; set; }
        public bool IsActive { get; set; }
        public Guid? KnowledgeBaseId { get; set; }
    }
    private class ModelOption
    {
        public string Id { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public string Provider { get; set; } = string.Empty;
    }
    private class ModelsResult { public List<ModelItem> Items { get; set; } = new(); }
    private class ModelItem
    {
        public string Name { get; set; } = string.Empty;
        public string Provider { get; set; } = string.Empty;
        public string ModelId { get; set; } = string.Empty;
    }
}
