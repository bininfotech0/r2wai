@page "/templates"
@attribute [Authorize]
@inject AuthenticatedHttpClient Http
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<PageTitle>R2WAI - Template Library</PageTitle>

<PageHeader Title="Template Library" Subtitle="Pre-built workflows and assistants to get started quickly" />

@* Search & Filters *@
<MudPaper Class="pa-4 mb-4" Elevation="0" Style="border: 1px solid var(--mud-palette-divider); border-radius: 12px;">
    <MudGrid>
        <MudItem xs="12" sm="6">
            <MudTextField @bind-Value="_searchTerm" Placeholder="Search templates..."
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                          Variant="Variant.Outlined" Margin="Margin.Dense" Immediate="true" />
        </MudItem>
        <MudItem xs="12" sm="6" Class="d-flex align-center justify-end">
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                @FilteredItems.Count template(s) found
            </MudText>
        </MudItem>
    </MudGrid>
</MudPaper>

@* Tab Bar *@
<MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" @bind-ActivePanelIndex="_activeTab"
         Style="border: 1px solid var(--mud-palette-divider); border-radius: 12px;">

    @* ──────────────── Workflow Templates ──────────────── *@
    <MudTabPanel Text="Workflows" Icon="@Icons.Material.Outlined.AccountTree"
                 BadgeData="@_workflowTemplates.Count" BadgeColor="Color.Primary">
        <div class="pa-4">
            <div class="d-flex gap-2 flex-wrap mb-4">
                @foreach (var cat in _workflowCategories)
                {
                    <MudChip T="string" Size="Size.Small"
                             Color="@(_workflowCategoryFilter == cat ? Color.Primary : Color.Default)"
                             Variant="@(_workflowCategoryFilter == cat ? Variant.Filled : Variant.Outlined)"
                             OnClick="@(() => _workflowCategoryFilter = cat)">
                        @cat
                    </MudChip>
                }
            </div>

            <MudGrid Spacing="3" Class="stagger-in">
                @foreach (var tmpl in FilteredWorkflowTemplates)
                {
                    <MudItem xs="12" sm="6" md="4">
                        <MudPaper Elevation="0" Style="@($"border: 1px solid var(--mud-palette-divider); border-left: 4px solid {GetWorkflowCategoryColor(tmpl.Category)}; border-radius: 12px; height: 100%; display: flex; flex-direction: column;")">
                            <div class="pa-4" style="flex: 1; display: flex; flex-direction: column;">
                                <div class="d-flex align-center gap-3 mb-2">
                                    <MudIcon Icon="@GetWorkflowCategoryIcon(tmpl.Category)"
                                             Style="@($"color: {GetWorkflowCategoryColor(tmpl.Category)};")" />
                                    <div style="flex: 1; min-width: 0;">
                                        <MudText Typo="Typo.subtitle2" Style="font-weight: 600;">@tmpl.Name</MudText>
                                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                                                 Style="@($"color: {GetWorkflowCategoryColor(tmpl.Category)}; border-color: {GetWorkflowCategoryColor(tmpl.Category)}; font-size: 0.625rem; height: 20px;")">
                                            @tmpl.Category
                                        </MudChip>
                                    </div>
                                </div>

                                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-3"
                                         Style="flex: 1; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                                    @tmpl.Description
                                </MudText>

                                <div class="d-flex justify-space-between align-center">
                                    <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Text"
                                             Style="font-size: 0.6875rem;">
                                        @tmpl.StepCount steps
                                    </MudChip>

                                    @if (_usedWorkflowTemplates.Contains(tmpl.Name))
                                    {
                                        <MudButton Variant="Variant.Filled" Color="Color.Success" Size="Size.Small"
                                                   StartIcon="@Icons.Material.Filled.Check" Disabled="true">
                                            Created
                                        </MudButton>
                                    }
                                    else
                                    {
                                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" Class="btn-gradient"
                                                   StartIcon="@Icons.Material.Filled.Add"
                                                   OnClick="@(() => UseWorkflowTemplate(tmpl))"
                                                   Disabled="@(_creatingTemplate == tmpl.Name)">
                                            @(_creatingTemplate == tmpl.Name ? "Creating..." : "Use Template")
                                        </MudButton>
                                    }
                                </div>
                            </div>
                        </MudPaper>
                    </MudItem>
                }
            </MudGrid>

            @if (FilteredWorkflowTemplates.Count == 0)
            {
                <div class="pa-8 text-center">
                    <MudIcon Icon="@Icons.Material.Outlined.SearchOff" Size="Size.Large" Color="Color.Secondary" Style="opacity: 0.3;" />
                    <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mt-2">No workflow templates match your search.</MudText>
                </div>
            }
        </div>
    </MudTabPanel>

    @* ──────────────── Assistant Templates ──────────────── *@
    <MudTabPanel Text="Assistants" Icon="@Icons.Material.Outlined.SmartToy"
                 BadgeData="@_assistantTemplates.Count" BadgeColor="Color.Secondary">
        <div class="pa-4">
            <div class="d-flex gap-2 flex-wrap mb-4">
                @foreach (var cat in _assistantCategories)
                {
                    <MudChip T="string" Size="Size.Small"
                             Color="@(_assistantCategoryFilter == cat ? Color.Primary : Color.Default)"
                             Variant="@(_assistantCategoryFilter == cat ? Variant.Filled : Variant.Outlined)"
                             OnClick="@(() => _assistantCategoryFilter = cat)">
                        @cat
                    </MudChip>
                }
            </div>

            <MudGrid Spacing="3" Class="stagger-in">
                @foreach (var tmpl in FilteredAssistantTemplates)
                {
                    <MudItem xs="12" sm="6" md="4">
                        <MudPaper Elevation="0" Style="@($"border: 1px solid var(--mud-palette-divider); border-left: 4px solid {GetAssistantTypeColor(tmpl.Type)}; border-radius: 12px; height: 100%; display: flex; flex-direction: column;")">
                            <div class="pa-4" style="flex: 1; display: flex; flex-direction: column;">
                                <div class="d-flex align-center gap-3 mb-2">
                                    <MudAvatar Size="Size.Medium" Style="@($"background-color: {GetAssistantTypeColor(tmpl.Type)}; color: white;")">
                                        <MudIcon Icon="@GetAssistantTypeIcon(tmpl.Type)" Size="Size.Small" />
                                    </MudAvatar>
                                    <div style="flex: 1; min-width: 0;">
                                        <MudText Typo="Typo.subtitle2" Style="font-weight: 600;">@tmpl.Name</MudText>
                                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                                                 Style="@($"color: {GetAssistantTypeColor(tmpl.Type)}; border-color: {GetAssistantTypeColor(tmpl.Type)}; font-size: 0.625rem; height: 20px;")">
                                            @tmpl.Type
                                        </MudChip>
                                    </div>
                                </div>

                                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-3"
                                         Style="flex: 1; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                                    @tmpl.Description
                                </MudText>

                                <div class="d-flex justify-space-between align-center">
                                    <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Text"
                                             Style="font-size: 0.6875rem;">
                                        @tmpl.Type type
                                    </MudChip>

                                    @if (_usedAssistantTemplates.Contains(tmpl.Name))
                                    {
                                        <MudButton Variant="Variant.Filled" Color="Color.Success" Size="Size.Small"
                                                   StartIcon="@Icons.Material.Filled.Check" Disabled="true">
                                            Created
                                        </MudButton>
                                    }
                                    else
                                    {
                                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" Class="btn-gradient"
                                                   StartIcon="@Icons.Material.Filled.Add"
                                                   OnClick="@(() => UseAssistantTemplate(tmpl))"
                                                   Disabled="@(_creatingTemplate == tmpl.Name)">
                                            @(_creatingTemplate == tmpl.Name ? "Creating..." : "Use Template")
                                        </MudButton>
                                    }
                                </div>
                            </div>
                        </MudPaper>
                    </MudItem>
                }
            </MudGrid>

            @if (FilteredAssistantTemplates.Count == 0)
            {
                <div class="pa-8 text-center">
                    <MudIcon Icon="@Icons.Material.Outlined.SearchOff" Size="Size.Large" Color="Color.Secondary" Style="opacity: 0.3;" />
                    <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mt-2">No assistant templates match your search.</MudText>
                </div>
            }
        </div>
    </MudTabPanel>
</MudTabs>

