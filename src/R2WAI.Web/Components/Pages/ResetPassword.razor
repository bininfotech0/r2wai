@page "/reset-password"
@attribute [AllowAnonymous]
@layout R2WAI.Web.Components.Layout.AuthLayout
@inject HttpClient HttpClient
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<PageTitle>R2WAI - Reset Password</PageTitle>

<div class="login-container">
    <div class="auth-content">
        <AuthShowcase />

        <MudPaper Class="pa-10 login-card" Elevation="0">
        <div class="d-flex flex-column align-center mb-8">
            <div style="width: 48px; height: 48px; border-radius: 14px; background: linear-gradient(135deg, #7C3AED, #6D28D9); display: flex; align-items: center; justify-content: center; margin-bottom: 16px; box-shadow: 0 4px 14px rgba(124, 58, 237, 0.3);">
                <MudIcon Icon="@Icons.Material.Filled.Password" Style="color: white; font-size: 1.5rem;" />
            </div>
            <MudText Typo="Typo.h4" Align="Align.Center" Style="font-weight: 700; letter-spacing: -0.02em;" Class="gradient-text">New Password</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center" Class="mt-1">
                Enter the reset code and your new password.
            </MudText>
        </div>

        @if (_success)
        {
            <div tabindex="-1" @ref="_successRef" role="status" aria-live="polite">
                <MudAlert Severity="Severity.Success" Class="mb-4" Style="border-radius: 10px;">
                    Your password has been reset successfully.
                </MudAlert>
            </div>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                       Class="btn-gradient"
                       Style="height: 48px; border-radius: 10px; font-weight: 600;"
                       OnClick="@(() => Navigation.NavigateTo("/login"))">
                Go to Login
            </MudButton>
        }
        else
        {
            <EditForm Model="_model" OnValidSubmit="HandleReset">
                <DataAnnotationsValidator />

                <MudTextField @bind-Value="_model.Email" Label="Email address" Variant="Variant.Outlined"
                              InputType="InputType.Email" Class="mb-4" Required="true" AutoFocus="true"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.MailOutline" />

                <MudTextField @bind-Value="_model.Token" Label="Reset code" Variant="Variant.Outlined"
                              Class="mb-4" Required="true"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.VpnKey" />

                <MudTextField @bind-Value="_model.NewPassword" Label="New password" Variant="Variant.Outlined"
                              InputType="@(_showPassword ? InputType.Text : InputType.Password)"
                              Adornment="Adornment.End"
                              AdornmentIcon="@(_showPassword ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                              OnAdornmentClick="@(() => _showPassword = !_showPassword)"
                              Immediate="true"
                              Class="mb-2" Required="true" />

                @if (!string.IsNullOrEmpty(_model.NewPassword))
                {
                    <div class="d-flex align-center gap-2 mb-4">
                        <MudProgressLinear Color="@PasswordStrengthColor" Value="@PasswordStrengthPercent"
                                           Class="flex-grow-1" Rounded="true" Size="Size.Small" />
                        <MudText Typo="Typo.caption" Style="min-width: 48px;" Color="@PasswordStrengthColor">@PasswordStrengthLabel</MudText>
                    </div>
                }

                <MudTextField @bind-Value="_model.ConfirmPassword" Label="Confirm password" Variant="Variant.Outlined"
                              InputType="@(_showPassword ? InputType.Text : InputType.Password)"
                              Class="mb-5" Required="true" />

                @if (!string.IsNullOrEmpty(_error))
                {
                    <MudAlert Severity="Severity.Error" Class="mb-4" Style="border-radius: 10px;" role="alert" aria-live="assertive">@_error</MudAlert>
                }

                <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                           Size="Size.Large" Disabled="_loading"
                           Class="btn-gradient"
                           Style="height: 48px; border-radius: 10px; font-weight: 600;">
                    @if (_loading)
                    {
                        <MudProgressCircular Class="ms-n1 me-2" Size="Size.Small" Indeterminate="true"
                                             Color="Color.Surface" />
                        <span>Resetting...</span>
                    }
                    else
                    {
                        <span>Reset Password</span>
                    }
                </MudButton>
            </EditForm>

            <div class="d-flex justify-center mt-5">
                <MudLink Href="/login" Typo="Typo.body2" Color="Color.Primary" Style="font-weight: 500;">
                    Back to Login
                </MudLink>
            </div>
        }
        </MudPaper>
    </div>
</div>

@code {
    private ResetPasswordModel _model = new();
    private string? _error;
    private bool _loading;
    private bool _success;
    private bool _showPassword;
    private bool _successFocused;
    private ElementReference _successRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_success && !_successFocused)
        {
            _successFocused = true;
            await _successRef.FocusAsync();
        }
    }

    private int PasswordStrengthScore
    {
        get
        {
            var password = _model.NewPassword;
            var score = 0;
            if (password.Length >= 8) score++;
            if (password.Length >= 12) score++;
            if (password.Any(char.IsUpper) && password.Any(char.IsLower)) score++;
            if (password.Any(char.IsDigit)) score++;
            if (password.Any(c => !char.IsLetterOrDigit(c))) score++;
            return score;
        }
    }

    private double PasswordStrengthPercent => PasswordStrengthScore / 5.0 * 100;

    private string PasswordStrengthLabel => PasswordStrengthScore switch
    {
        <= 1 => "Weak",
        2 or 3 => "Fair",
        4 => "Good",
        _ => "Strong",
    };

    private Color PasswordStrengthColor => PasswordStrengthScore switch
    {
        <= 1 => Color.Error,
        2 or 3 => Color.Warning,
        4 => Color.Info,
        _ => Color.Success,
    };

    private async Task HandleReset()
    {
        _error = null;

        if (_model.NewPassword != _model.ConfirmPassword)
        {
            _error = "Passwords do not match.";
            return;
        }

        if (_model.NewPassword.Length < 8)
        {
            _error = "Password must be at least 8 characters.";
            return;
        }

        _loading = true;
        try
        {
            var response = await HttpClient.PostAsJsonAsync("/api/v1/auth/reset-password", new
            {
                _model.Email,
                _model.Token,
                _model.NewPassword
            });

            if (response.IsSuccessStatusCode)
            {
                _success = true;
                Snackbar.Add("Password reset successfully!", Severity.Success);
            }
            else
            {
                var result = await response.Content.ReadFromJsonAsync<ErrorResponse>();
                _error = result?.Error ?? "Failed to reset password. Check your reset code.";
            }
        }
        catch
        {
            _error = "Unable to connect to server.";
        }
        finally { _loading = false; }
    }

    public class ResetPasswordModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Email is required.")]
        [System.ComponentModel.DataAnnotations.EmailAddress(ErrorMessage = "Please enter a valid email address.")]
        public string Email { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Reset code is required.")]
        public string Token { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "New password is required.")]
        public string NewPassword { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Please confirm your password.")]
        public string ConfirmPassword { get; set; } = string.Empty;
    }

    private class ErrorResponse { public string? Error { get; set; } }
}
