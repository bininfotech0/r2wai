@page "/forgot-password"
@attribute [AllowAnonymous]
@layout R2WAI.Web.Components.Layout.AuthLayout
@inject HttpClient HttpClient
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<PageTitle>R2WAI - Forgot Password</PageTitle>

<div class="login-container">
    <div class="auth-content">
        <AuthShowcase />

        <MudPaper Class="pa-10 login-card" Elevation="0">
        <div class="d-flex flex-column align-center mb-8">
            <div style="width: 48px; height: 48px; border-radius: 14px; background: linear-gradient(135deg, #7C3AED, #6D28D9); display: flex; align-items: center; justify-content: center; margin-bottom: 16px; box-shadow: 0 4px 14px rgba(124, 58, 237, 0.3);">
                <MudIcon Icon="@Icons.Material.Filled.LockReset" Style="color: white; font-size: 1.5rem;" />
            </div>
            <MudText Typo="Typo.h4" Align="Align.Center" Style="font-weight: 700; letter-spacing: -0.02em;" Class="gradient-text">Reset Password</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center" Class="mt-1">
                Enter your email and we'll send you a reset code.
            </MudText>
        </div>

        @if (_submitted)
        {
            <div tabindex="-1" @ref="_successRef" role="status" aria-live="polite">
                <MudAlert Severity="Severity.Success" Class="mb-4" Style="border-radius: 10px;">
                    If an account with that email exists, a password reset code has been sent.
                </MudAlert>
            </div>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                       Class="btn-gradient"
                       Style="height: 48px; border-radius: 10px; font-weight: 600;"
                       OnClick="@(() => Navigation.NavigateTo("/reset-password"))">
                Enter Reset Code
            </MudButton>
            <MudButton Variant="Variant.Text" Color="Color.Default" FullWidth="true" Class="mt-2"
                       OnClick="@(() => Navigation.NavigateTo("/login"))">
                Back to Login
            </MudButton>
        }
        else
        {
            <EditForm Model="_model" OnValidSubmit="HandleSubmit">
                <DataAnnotationsValidator />

                <MudTextField @bind-Value="_model.Email" Label="Email address" Variant="Variant.Outlined"
                              InputType="InputType.Email" Class="mb-5" Required="true"
                              RequiredError="Email is required."
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.MailOutline"
                              AutoFocus="true"
                              aria-label="Email address" />

                <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                           Size="Size.Large" Disabled="_loading"
                           Class="btn-gradient"
                           Style="height: 48px; border-radius: 10px; font-weight: 600;">
                    @if (_loading)
                    {
                        <MudProgressCircular Class="ms-n1 me-2" Size="Size.Small" Indeterminate="true"
                                             Color="Color.Surface" />
                        <span>Sending...</span>
                    }
                    else
                    {
                        <span>Send Reset Code</span>
                    }
                </MudButton>
            </EditForm>

            <div class="d-flex justify-center mt-5">
                <MudLink Href="/login" Typo="Typo.body2" Color="Color.Primary" Style="font-weight: 500;">
                    Back to Login
                </MudLink>
            </div>
        }
        </MudPaper>
    </div>
</div>

@code {
    private ForgotPasswordModel _model = new();
    private bool _loading;
    private bool _submitted;
    private bool _successFocused;
    private ElementReference _successRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_submitted && !_successFocused)
        {
            _successFocused = true;
            await _successRef.FocusAsync();
        }
    }

    private async Task HandleSubmit()
    {
        _loading = true;
        try
        {
            await HttpClient.PostAsJsonAsync("/api/v1/auth/forgot-password", new { _model.Email });
            _submitted = true;
        }
        catch
        {
            Snackbar.Add("Unable to connect to server.", Severity.Error);
        }
        finally { _loading = false; }
    }

    public class ForgotPasswordModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Email is required.")]
        [System.ComponentModel.DataAnnotations.EmailAddress(ErrorMessage = "Please enter a valid email address.")]
        public string Email { get; set; } = string.Empty;
    }
}
