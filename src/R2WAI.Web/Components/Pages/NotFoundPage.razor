<div class="d-flex flex-column align-center justify-center" style="min-height: 60vh;">
    <div class="empty-state-icon" style="width: 96px; height: 96px; margin-bottom: 24px;">
        <MudIcon Icon="@Icons.Material.Outlined.SearchOff" Style="font-size: 2.5rem; color: var(--mud-palette-primary);" />
    </div>
    <div style="font-size: 6rem; font-weight: 800; letter-spacing: -0.03em; line-height: 1;" class="gradient-text">404</div>
    <MudText Typo="Typo.h5" Class="mt-2 gradient-text" Style="font-weight: 700;">Page Not Found</MudText>
    <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mt-1 mb-6" Style="max-width: 400px;" Align="Align.Center">
        The page you're looking for doesn't exist or has been moved.
    </MudText>
    <div class="d-flex gap-2">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/" StartIcon="@Icons.Material.Filled.Home" Class="btn-gradient">
            Go Home
        </MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Default" Href="/assistant-studio" StartIcon="@Icons.Material.Filled.SmartToy">
            Assistants
        </MudButton>
    </div>
</div>
