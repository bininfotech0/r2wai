@page "/admin/permissions"
@page "/settings/permissions"
@attribute [Authorize]
@inject AuthenticatedHttpClient Http
@inject ISnackbar Snackbar

<PageTitle>R2WAI - Permission Matrix</PageTitle>

<PageHeader Title="Permission Matrix" Subtitle="Manage role-based access control across the platform">
    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
               StartIcon="@Icons.Material.Filled.Save" OnClick="SaveChanges"
               Disabled="_saving">
        @if (_saving)
        {
            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2" />
            <span>Saving...</span>
        }
        else
        {
            <span>Save Changes</span>
        }
    </MudButton>
</PageHeader>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mt-4" />
}
else
{
    <MudPaper Elevation="0" Style="border: 1px solid var(--mud-palette-divider); overflow-x: auto;">
        <MudSimpleTable Dense="true" Hover="true" Elevation="0" Style="min-width: 700px;">
            <thead>
                <tr>
                    <th style="min-width: 220px; font-weight: 600; position: sticky; left: 0; background: var(--mud-palette-surface); z-index: 1;">
                        Permission
                    </th>
                    @foreach (var role in _roles)
                    {
                        <th style="text-align: center; font-weight: 600; min-width: 110px;">@role</th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var category in _permissionCategories)
                {
                    <tr style="background-color: var(--mud-palette-background-gray);">
                        <td colspan="@(1 + _roles.Count)" style="position: sticky; left: 0; z-index: 1;">
                            <MudText Typo="Typo.subtitle2" Style="font-weight: 700; padding: 4px 0;">
                                @category.Name
                            </MudText>
                        </td>
                    </tr>
                    @foreach (var permission in category.Permissions)
                    {
                        var permKey = $"{category.Name}.{permission}";
                        <tr>
                            <td style="padding-left: 24px; position: sticky; left: 0; background: var(--mud-palette-surface); z-index: 1;">
                                <MudText Typo="Typo.body2">@permission</MudText>
                            </td>
                            @foreach (var role in _roles)
                            {
                                <td style="text-align: center;">
                                    <MudCheckBox T="bool"
                                                 Value="@(GetPermission(role, permKey))"
                                                 ValueChanged="@((bool v) => SetPermission(role, permKey, v))"
                                                 Color="Color.Primary"
                                                 Dense="true" />
                                </td>
                            }
                        </tr>
                    }
                }
            </tbody>
        </MudSimpleTable>
    </MudPaper>

    @if (_hasChanges)
    {
        <MudAlert Severity="Severity.Info" Class="mt-3" Dense="true">
            You have unsaved changes.
        </MudAlert>
    }
}

@code {
    private bool _loading = true;
    private bool _saving;
    private bool _hasChanges;

    private List<string> _roles = new() { "Admin", "Business User", "Approver", "Operator", "Viewer" };
    private Dictionary<string, HashSet<string>> _rolePermissions = new();

    private static readonly List<PermissionCategory> _permissionCategories = new()
    {
        new("Assistants", new() { "Create", "Edit", "Delete", "Publish", "Chat", "ViewAll" }),
        new("Workflows", new() { "Create", "Edit", "Delete", "Execute", "ViewRuns" }),
        new("Knowledge", new() { "Create", "Edit", "Delete", "Search", "Upload" }),
        new("Documents", new() { "Upload", "Download", "Delete", "ViewAll" }),
        new("Operations", new() { "ViewDashboard", "ViewAuditLogs", "ExportLogs" }),
        new("Admin", new() { "ManageUsers", "ManageRoles", "ManageModels", "ManageSettings", "ManageTenants" }),
    };

    private static readonly HashSet<string> _viewerPermissions = new()
    {
        "Assistants.Chat", "Assistants.ViewAll",
        "Workflows.ViewRuns",
        "Knowledge.Search",
        "Documents.Download", "Documents.ViewAll",
        "Operations.ViewDashboard",
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) await LoadData();
    }

    private async Task LoadData()
    {
        _loading = true;
        StateHasChanged();
        try
        {
            var result = await Http.GetFromJsonAsync<RolesResult>("/api/v1/admin/roles");
            var loadedRoles = result?.Items ?? new();

            if (loadedRoles.Count > 0)
            {
                _roles = loadedRoles.Select(r => r.Name).ToList();
            }

            InitializePermissions();
        }
        catch
        {
            Snackbar.Add("Failed to load roles. Using default role list.", Severity.Warning);
            InitializePermissions();
        }
        finally { _loading = false; StateHasChanged(); }
    }

    private void InitializePermissions()
    {
        _rolePermissions.Clear();

        var allPermKeys = _permissionCategories
            .SelectMany(c => c.Permissions.Select(p => $"{c.Name}.{p}"))
            .ToList();

        foreach (var role in _roles)
        {
            var perms = new HashSet<string>();

            if (role.Equals("Admin", StringComparison.OrdinalIgnoreCase))
            {
                foreach (var key in allPermKeys)
                    perms.Add(key);
            }
            else if (role.Equals("Viewer", StringComparison.OrdinalIgnoreCase))
            {
                foreach (var key in _viewerPermissions)
                    perms.Add(key);
            }

            _rolePermissions[role] = perms;
        }
    }

    private bool GetPermission(string role, string permKey)
    {
        return _rolePermissions.TryGetValue(role, out var perms) && perms.Contains(permKey);
    }

    private void SetPermission(string role, string permKey, bool enabled)
    {
        if (!_rolePermissions.ContainsKey(role))
            _rolePermissions[role] = new HashSet<string>();

        if (enabled)
            _rolePermissions[role].Add(permKey);
        else
            _rolePermissions[role].Remove(permKey);

        _hasChanges = true;
    }

    private async Task SaveChanges()
    {
        _saving = true;
        StateHasChanged();

        try
        {
            var payload = _rolePermissions.ToDictionary(
                kvp => kvp.Key,
                kvp => kvp.Value.ToList()
            );

            var response = await Http.PostAsJsonAsync("/api/v1/admin/permissions", payload);
            response.EnsureSuccessStatusCode();

            _hasChanges = false;
            Snackbar.Add("Permissions saved successfully", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to save permissions: {ex.Message}", Severity.Error);
        }
        finally { _saving = false; StateHasChanged(); }
    }

    private record PermissionCategory(string Name, List<string> Permissions);

    private class RolesResult { public List<RoleDto> Items { get; set; } = new(); }
    private class RoleDto
    {
        public Guid Id { get; set; }
        public string Name { get; set; } = string.Empty;
    }
}
