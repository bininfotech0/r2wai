@page "/admin/permissions"
@page "/settings/permissions"
@attribute [Authorize]
@inject AuthenticatedHttpClient Http
@inject ISnackbar Snackbar

<PageTitle>R2WAI - Permission Matrix</PageTitle>

<PageHeader Title="Permission Matrix" Subtitle="Manage role-based access control across the platform">
    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
               StartIcon="@Icons.Material.Filled.Save" OnClick="SaveChanges"
               Disabled="@(_saving || !_hasChanges)">
        @if (_saving)
        {
            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2" />
            <span>Saving...</span>
        }
        else
        {
            <span>Save Changes</span>
        }
    </MudButton>
</PageHeader>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mt-4" />
}
else if (_roles.Count == 0)
{
    <MudAlert Severity="Severity.Warning" Class="mt-4">
        No roles found. Create roles in Admin → Roles before configuring permissions.
    </MudAlert>
}
else
{
    <MudPaper Elevation="0" Style="border: 1px solid var(--mud-palette-divider); overflow-x: auto;">
        <MudSimpleTable Dense="true" Hover="true" Elevation="0" Style="min-width: 700px;">
            <thead>
                <tr>
                    <th style="min-width: 220px; font-weight: 600; position: sticky; left: 0; background: var(--mud-palette-surface); z-index: 1;">
                        Permission
                    </th>
                    @foreach (var role in _roles)
                    {
                        <th style="text-align: center; font-weight: 600; min-width: 110px;">
                            <div>@role.Name</div>
                            @if (role.IsSystem)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined"
                                         Style="font-size: 0.55rem; height: 16px; margin-top: 2px;">system</MudChip>
                            }
                        </th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var category in _permissionCategories)
                {
                    <tr style="background-color: var(--mud-palette-background-gray);">
                        <td colspan="@(1 + _roles.Count)" style="position: sticky; left: 0; z-index: 1;">
                            <MudText Typo="Typo.subtitle2" Style="font-weight: 700; padding: 4px 0;">
                                @category.Name
                            </MudText>
                        </td>
                    </tr>
                    @foreach (var permission in category.Permissions)
                    {
                        var permKey = $"{category.Name}.{permission}";
                        <tr>
                            <td style="padding-left: 24px; position: sticky; left: 0; background: var(--mud-palette-surface); z-index: 1;">
                                <MudText Typo="Typo.body2">@permission</MudText>
                            </td>
                            @foreach (var role in _roles)
                            {
                                var roleName = role.Name;
                                <td style="text-align: center;">
                                    <MudCheckBox T="bool"
                                                 Value="@(GetPermission(roleName, permKey))"
                                                 ValueChanged="@((bool v) => SetPermission(roleName, permKey, v))"
                                                 Color="Color.Primary"
                                                 Dense="true" />
                                </td>
                            }
                        </tr>
                    }
                }
            </tbody>
        </MudSimpleTable>
    </MudPaper>

    @if (_hasChanges)
    {
        <MudAlert Severity="Severity.Info" Class="mt-3" Dense="true"
                  Icon="@Icons.Material.Outlined.Info">
            You have unsaved changes. Click <strong>Save Changes</strong> to apply them.
        </MudAlert>
    }
}

@code {
    private bool _loading = true;
    private bool _saving;
    private bool _hasChanges;

    private List<RoleItem> _roles = new();
    private Dictionary<string, HashSet<string>> _rolePermissions = new();

    private static readonly List<PermissionCategory> _permissionCategories = new()
    {
        new("Assistants", new() { "Create", "Edit", "Delete", "Publish", "Chat", "ViewAll" }),
        new("Workflows",  new() { "Create", "Edit", "Delete", "Execute", "ViewRuns" }),
        new("Knowledge",  new() { "Create", "Edit", "Delete", "Search", "Upload" }),
        new("Documents",  new() { "Upload", "Download", "Delete", "ViewAll" }),
        new("Operations", new() { "ViewDashboard", "ViewAuditLogs", "ExportLogs" }),
        new("Admin",      new() { "ManageUsers", "ManageRoles", "ManageModels", "ManageSettings", "ManageTenants" }),
    };

    // Sensible defaults used when a role has no saved permissions yet
    private static readonly Dictionary<string, HashSet<string>> _defaults = new(StringComparer.OrdinalIgnoreCase)
    {
        ["Admin"] = new HashSet<string>(
            _permissionCategories.SelectMany(c => c.Permissions.Select(p => $"{c.Name}.{p}"))),
        ["Viewer"] = new HashSet<string>
        {
            "Assistants.Chat", "Assistants.ViewAll",
            "Workflows.ViewRuns",
            "Knowledge.Search",
            "Documents.Download", "Documents.ViewAll",
            "Operations.ViewDashboard",
        },
        ["Approver"] = new HashSet<string>
        {
            "Assistants.Chat", "Assistants.ViewAll",
            "Workflows.ViewRuns",
            "Knowledge.Search",
            "Documents.Download", "Documents.ViewAll",
            "Operations.ViewDashboard",
        },
        ["Operator"] = new HashSet<string>
        {
            "Assistants.ViewAll",
            "Workflows.ViewRuns",
            "Documents.ViewAll",
            "Operations.ViewDashboard", "Operations.ViewAuditLogs", "Operations.ExportLogs",
        },
        ["Business User"] = new HashSet<string>
        {
            "Assistants.Create", "Assistants.Edit", "Assistants.Publish", "Assistants.Chat", "Assistants.ViewAll",
            "Workflows.Create", "Workflows.Edit", "Workflows.Execute", "Workflows.ViewRuns",
            "Knowledge.Create", "Knowledge.Edit", "Knowledge.Search", "Knowledge.Upload",
            "Documents.Upload", "Documents.Download", "Documents.ViewAll",
            "Operations.ViewDashboard",
        },
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) await LoadData();
    }

    private async Task LoadData()
    {
        _loading = true;
        StateHasChanged();
        try
        {
            var result = await Http.GetFromJsonAsync<RolesResult>("/api/v1/admin/roles?pageSize=100");
            var loaded = result?.Items ?? new();

            _roles = loaded.Select(r => new RoleItem(r.Id, r.Name, r.IsSystem, r.Description, r.Permissions)).ToList();
            _rolePermissions.Clear();

            foreach (var role in _roles)
            {
                var saved = ParsePermissions(role.Permissions);
                // Use saved permissions if present, otherwise fall back to defaults
                _rolePermissions[role.Name] = saved.Count > 0
                    ? saved
                    : _defaults.TryGetValue(role.Name, out var def) ? new HashSet<string>(def) : new HashSet<string>();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load roles: {ex.Message}", Severity.Warning);
        }
        finally { _loading = false; StateHasChanged(); }
    }

    private static HashSet<string> ParsePermissions(string? json)
    {
        if (string.IsNullOrWhiteSpace(json)) return new();
        try
        {
            // Support JSON array: ["Assistants.Create", "Workflows.Execute"]
            using var doc = System.Text.Json.JsonDocument.Parse(json);
            if (doc.RootElement.ValueKind == System.Text.Json.JsonValueKind.Array)
                return new HashSet<string>(doc.RootElement.EnumerateArray()
                    .Where(e => e.ValueKind == System.Text.Json.JsonValueKind.String)
                    .Select(e => e.GetString()!)
                    .Where(s => !string.IsNullOrWhiteSpace(s)));
        }
        catch { }
        return new();
    }

    private bool GetPermission(string role, string permKey) =>
        _rolePermissions.TryGetValue(role, out var perms) && perms.Contains(permKey);

    private void SetPermission(string role, string permKey, bool enabled)
    {
        if (!_rolePermissions.ContainsKey(role))
            _rolePermissions[role] = new HashSet<string>();

        if (enabled) _rolePermissions[role].Add(permKey);
        else _rolePermissions[role].Remove(permKey);

        _hasChanges = true;
    }

    private async Task SaveChanges()
    {
        _saving = true;
        StateHasChanged();

        var errors = new List<string>();

        foreach (var role in _roles)
        {
            if (role.IsSystem) continue; // don't overwrite system roles

            var perms = _rolePermissions.TryGetValue(role.Name, out var p) ? p : new HashSet<string>();
            var permJson = System.Text.Json.JsonSerializer.Serialize(perms.OrderBy(x => x).ToList());

            try
            {
                var response = await Http.PutAsJsonAsync($"/api/v1/admin/roles/{role.Id}", new
                {
                    Name = role.Name,
                    Description = role.Description,
                    Permissions = permJson
                });

                if (!response.IsSuccessStatusCode)
                {
                    var err = await response.Content.ReadAsStringAsync();
                    errors.Add($"{role.Name}: {response.StatusCode}");
                }
            }
            catch (Exception ex)
            {
                errors.Add($"{role.Name}: {ex.Message}");
            }
        }

        if (errors.Count == 0)
        {
            _hasChanges = false;
            Snackbar.Add("Permissions saved successfully", Severity.Success);
        }
        else
        {
            Snackbar.Add($"Some roles failed to save: {string.Join("; ", errors)}", Severity.Error);
        }

        _saving = false;
        StateHasChanged();
    }

    private record PermissionCategory(string Name, List<string> Permissions);

    private record RoleItem(Guid Id, string Name, bool IsSystem, string? Description, string? Permissions);

    private class RolesResult { public List<RoleDto> Items { get; set; } = new(); }
    private class RoleDto
    {
        public Guid Id { get; set; }
        public string Name { get; set; } = string.Empty;
        public string? Description { get; set; }
        public string? Permissions { get; set; }
        public bool IsSystem { get; set; }
    }
}
