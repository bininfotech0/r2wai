        "Execute" => Icons.Material.Filled.PlayArrow,
        _ => Icons.Material.Filled.Info,
    };

    private Color GetActivityColor(string action) => action switch
    {
        "Create" => Color.Success,
        "Update" => Color.Primary,
        "Delete" => Color.Error,
        "Publish" => Color.Info,
        "Execute" => Color.Secondary,
        _ => Color.Default,
    };

