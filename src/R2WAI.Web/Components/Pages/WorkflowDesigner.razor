    private static bool HasStepConfig(StepItem step)
    {
        var c = step.Config;
        return !string.IsNullOrEmpty(c.AiPrompt) || !string.IsNullOrEmpty(c.ApiUrl) ||
               !string.IsNullOrEmpty(c.EmailTo) || !string.IsNullOrEmpty(c.ConditionExpression) ||
               !string.IsNullOrEmpty(c.ApproverRoles) || !string.IsNullOrEmpty(c.ActionDescription) ||
               c.TimeoutMinutes > 0 || c.RetryCount > 0 || c.DelayDuration > 0 ||
               !string.IsNullOrEmpty(c.TransformInput);
    }

    // ── Undo / Redo ──
    private void PushUndo()
    {
        _undoStack.Push(_steps.Select(s => s.Clone()).ToList());
        if (_undoStack.Count > MaxUndoDepth)
        {
            var temp = _undoStack.ToArray();
            _undoStack = new Stack<List<StepItem>>(temp.Reverse().Skip(1));
        }
        _redoStack.Clear();
    }

    private void Undo()
    {
        if (_undoStack.Count == 0) return;
        _redoStack.Push(_steps.Select(s => s.Clone()).ToList());
        _steps = _undoStack.Pop();
        _editingStep = null;
        _hasChanges = true;
    }

    private void Redo()
    {
        if (_redoStack.Count == 0) return;
        _undoStack.Push(_steps.Select(s => s.Clone()).ToList());
        _steps = _redoStack.Pop();
        _editingStep = null;
        _hasChanges = true;
    }

    // ── Step operations ──
    private void SelectStep(StepItem step)
    {
        _editingStep = _editingStep == step ? null : step;
        _showVariables = false;
    }

    private void OnStepTypeChanged(string newType)
    {
        if (_editingStep is not null)
            _editingStep.Action = newType;
        _hasChanges = true;
    }

    private void QuickAddStep(string action, string name)
    {
        PushUndo();
        var step = new StepItem { Name = name, Action = action };
        _steps.Add(step);
        _editingStep = step;
        _showVariables = false;
        _hasChanges = true;
    }

    private void InsertStep(int beforeIndex)
    {
        PushUndo();
        var step = new StepItem { Name = "New Step", Action = "Action" };
        _steps.Insert(beforeIndex, step);
        _editingStep = step;
        _showVariables = false;
        _hasChanges = true;
    }

    private void MoveStep(int index, int direction)
    {
        var newIndex = index + direction;
        if (newIndex < 0 || newIndex >= _steps.Count) return;
        (_steps[index], _steps[newIndex]) = (_steps[newIndex], _steps[index]);
        _hasChanges = true;
    }

    // ── Drag-and-drop ──
    private void OnDragStart(int index) { _dragFromIndex = index; _dropTargetIndex = null; }
    private void OnDragOver(int index) { if (_dragFromIndex is not null && _dragFromIndex != index) _dropTargetIndex = index; }
    private void OnDragLeave() { _dropTargetIndex = null; }

    private void OnDrop(int index)
    {
        if (_dragFromIndex is null) return;
        var from = _dragFromIndex.Value;
        if (from == index) { _dragFromIndex = null; _dropTargetIndex = null; return; }

        PushUndo();
        var moving = _steps[from];
        _steps.RemoveAt(from);
        var insertAt = from < index ? index - 1 : index;
        if (insertAt < 0) insertAt = 0;
        if (insertAt > _steps.Count) insertAt = _steps.Count;
        _steps.Insert(insertAt, moving);

        _hasChanges = true;
        _dragFromIndex = null;
        _dropTargetIndex = null;
    }

    private void OnDragEnd() { _dragFromIndex = null; _dropTargetIndex = null; }

    // ── Keyboard shortcuts ──
    private void OnCanvasKeyDown(KeyboardEventArgs e)
    {
        if (e.CtrlKey && e.Key == "z") { Undo(); return; }
        if (e.CtrlKey && (e.Key == "y" || (e.ShiftKey && e.Key == "z"))) { Redo(); return; }

        if (_editingStep is null) return;
        if (e.Key != "Delete" && e.Key != "Backspace") return;

        PushUndo();
        var step = _editingStep;
        _editingStep = null;
        _steps.Remove(step);
        _hasChanges = true;
    }

    private void HandleAiStepKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(_aiStepPrompt))
            GenerateStep();
    }

    private void GenerateStep()
    {
        if (string.IsNullOrWhiteSpace(_aiStepPrompt)) return;

        PushUndo();
        var prompt = _aiStepPrompt.ToLowerInvariant();
        string action = "Action";
        string name = _aiStepPrompt;
        string? role = null;

        if (prompt.Contains("approv") || prompt.Contains("review") || prompt.Contains("sign off"))
        {
            action = "Approval";
            name = prompt.Contains("manager") ? "Manager Approval" : prompt.Contains("finance") ? "Finance Approval" : "Approval Step";
            if (prompt.Contains("manager")) role = "Manager";
            else if (prompt.Contains("finance")) role = "Finance";
            else if (prompt.Contains("director")) role = "Director";
        }
        else if (prompt.Contains("email") || prompt.Contains("notify") || prompt.Contains("send"))
        {
            action = "Email";
            name = prompt.Contains("approv") ? "Approval Notification" : prompt.Contains("reject") ? "Rejection Notification" : "Send Notification";
        }
        else if (prompt.Contains("ai") || prompt.Contains("generate") || prompt.Contains("analyze") || prompt.Contains("summarize"))
        {
            action = "AI Generate";
            name = prompt.Contains("summarize") ? "AI Summary" : prompt.Contains("analyze") ? "AI Analysis" : "AI Processing";
        }
        else if (prompt.Contains("api") || prompt.Contains("call") || prompt.Contains("webhook") || prompt.Contains("integrat"))
        {
            action = "API Call";
            name = prompt.Contains("webhook") ? "Webhook Call" : "API Integration";
        }
        else if (prompt.Contains("condition") || prompt.Contains("check") || prompt.Contains("if"))
        {
            action = "Condition";
            name = "Condition Check";
        }
        else if (prompt.Contains("wait") || prompt.Contains("delay") || prompt.Contains("pause"))
        {
            action = "Delay";
            name = prompt.Contains("event") ? "Wait for Event" : "Delay";
        }
        else if (prompt.Contains("transform") || prompt.Contains("convert") || prompt.Contains("map"))
        {
            action = "Transform";
            name = "Transform Data";
        }

        var step = new StepItem { Name = name, Action = action, AssignedRole = role };
        _steps.Add(step);
        _editingStep = step;
        _showVariables = false;
        _aiStepPrompt = string.Empty;
        _hasChanges = true;
    }

    // ── Execution mode ──
    private async Task ExecuteWorkflow()
    {
        if (_steps.Count == 0 || _hasChanges) return;

        _executionMode = true;
        _executionCompleted = false;
        _executionFailed = false;
        _executionError = null;
        _stepStatuses = new Dictionary<int, string>();

        for (int i = 0; i < _steps.Count; i++)
            _stepStatuses[i] = "Pending";

        _executionProgress = $"Starting execution... (0 of {_steps.Count})";
        _executionPercent = 0;

        try
        {
            var response = await Http.PostAsync($"/api/v1/workflows/{WorkflowId}/execute", null);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<ExecuteResultDto>();
                if (result is not null)
                {
                    _instanceId = result.InstanceId;
                    Snackbar.Add("Workflow execution started", Severity.Info);
                    StartPolling();
                }
                else
                    FinishExecution(true, "No instance ID returned");
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                FinishExecution(true, $"Failed to start execution: {error}");
            }
        }
        catch (Exception ex)
        {
            FinishExecution(true, $"Execution error: {ex.Message}");
        }
    }

    private void StartPolling()
    {
        _pollTimer?.Dispose();
        _pollTimer = new System.Threading.Timer(
            async _ => await PollStepStatuses(),
            null,
            TimeSpan.FromSeconds(1),
            TimeSpan.FromSeconds(3));
    }

    private async Task PollStepStatuses()
    {
        if (_isPolling || _instanceId is null) return;
        _isPolling = true;
        try
        {
            var stepsResult = await Http.GetFromJsonAsync<ExecutionStepsResult>(
                $"/api/v1/workflows/instances/{_instanceId}/steps");

            if (stepsResult?.Items is not null)
            {
                var completedCount = 0;
                var hasFailure = false;
                string? failureError = null;

                foreach (var step in stepsResult.Items)
                {
                    _stepStatuses[step.StepIndex] = step.Status;
                    if (step.Status == "Completed") completedCount++;
                    if (step.Status == "Failed") { hasFailure = true; failureError = step.Error; }
                }

                var runningCount = stepsResult.Items.Count(s => s.Status == "Running");
                var total = _steps.Count;
                _executionPercent = total > 0 ? (double)completedCount / total * 100 : 0;
                _executionProgress = $"Step {completedCount + runningCount} of {total}";

                if (hasFailure) FinishExecution(true, failureError ?? "A step failed");
                else if (completedCount == total) FinishExecution(false, null);
            }
            await InvokeAsync(StateHasChanged);
        }
        catch { }
        finally { _isPolling = false; }
    }

    private void FinishExecution(bool failed, string? error)
    {
        _pollTimer?.Dispose();
        _pollTimer = null;
        _executionMode = false;
        _executionCompleted = true;
        _executionFailed = failed;
        _executionError = error;
        _executionPercent = failed ? _executionPercent : 100;
        _executionProgress = failed ? "Execution failed" : $"All {_steps.Count} steps completed";

        if (failed) Snackbar.Add(error ?? "Execution failed", Severity.Error);
        else Snackbar.Add("Workflow execution completed successfully!", Severity.Success);

        InvokeAsync(StateHasChanged);
    }

    private void StopExecution()
    {
        _pollTimer?.Dispose();
        _pollTimer = null;
        _executionMode = false;
        _executionCompleted = true;
        _executionFailed = true;
        _executionError = "Execution monitoring stopped by user";
        Snackbar.Add("Execution monitoring stopped", Severity.Warning);
    }

    private void ClearExecutionState()
    {
        _executionCompleted = false;
        _executionFailed = false;
        _executionError = null;
        _stepStatuses.Clear();
        _instanceId = null;
        _executionPercent = 0;
        _executionProgress = string.Empty;
    }

    private string GetStepExecutionStatus(int index)
    {
        if (!_executionMode && !_executionCompleted) return string.Empty;
        return _stepStatuses.TryGetValue(index, out var status) ? status : "Pending";
    }

    private bool IsExecPending(int index) => _executionMode && GetStepExecutionStatus(index) == "Pending";

    private string NodeStroke(int index, bool selected)
    {
        var status = GetStepExecutionStatus(index);
        return status switch
        {
            "Running" => "#3B82F6",
            "Completed" => "#10B981",
            "Failed" => "#EF4444",
            "Pending" when _executionMode => "#9CA3AF",
            _ => selected ? "#7C3AED" : "#E5E7EB"
        };
    }

    private string NodeStrokeWidth(int index, bool selected) =>
        GetStepExecutionStatus(index) switch
        {
            "Running" => "2.5",
            "Completed" or "Failed" => "2",
            _ => selected ? "2.5" : "1"
        };

    private string NodeDash(int index) => IsExecPending(index) ? "6 3" : "none";

    private string NodeFilter(int index, bool selected) =>
        GetStepExecutionStatus(index) switch
        {
            "Running" => "url(#wf-glow-running)",
            "Completed" => "url(#wf-glow-completed)",
            "Failed" => "url(#wf-glow-failed)",
            _ => selected ? "url(#wf-shadow-sel)" : "url(#wf-shadow)"
        };

    private string ExecStatusColor(int index) =>
        GetStepExecutionStatus(index) switch
        {
            "Running" => "#3B82F6",
            "Completed" => "#10B981",
            "Failed" => "#EF4444",
            _ => "#9CA3AF"
        };

    public void Dispose() { _pollTimer?.Dispose(); }

    private async Task SaveWorkflow()
    {
        _saving = true;
        try
        {
            var stepsJson = System.Text.Json.JsonSerializer.Serialize(
                _steps.Select((s, i) => new
                {
                    Name = s.Name,
                    Action = s.Action,
                    AssignedRole = s.AssignedRole,
                    Order = i,
                    Config = s.Config
                }));

            await Http.PutAsJsonAsync($"/api/v1/workflows/{WorkflowId}", new
            {
                Name = _workflow!.Name,
                Description = _workflow.Description,
                Steps = stepsJson
            });
            Snackbar.Add("Workflow saved", Severity.Success);
            _hasChanges = false;
        }
        catch (Exception ex) { Snackbar.Add($"Save failed: {ex.Message}", Severity.Error); }
        finally { _saving = false; }
    }

