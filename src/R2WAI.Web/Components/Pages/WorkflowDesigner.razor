@page "/workflow-studio/designer/{WorkflowId}"
@attribute [Authorize]
@implements IDisposable
@inject AuthenticatedHttpClient Http
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<PageTitle>R2WAI - Workflow Designer</PageTitle>

<div class="d-flex justify-space-between align-center mb-3">
    <div class="d-flex align-center gap-3">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Color="Color.Default"
                       OnClick="@(() => Navigation.NavigateTo("/workflow-studio"))" aria-label="Back" />
        <div>
            @if (_editingName)
            {
                <MudTextField @bind-Value="_workflow!.Name" Variant="Variant.Text" Margin="Margin.Dense"
                              Style="font-size: 1.25rem; font-weight: 700;"
                              OnBlur="@(() => { _editingName = false; _hasChanges = true; })"
                              Immediate="true" AutoFocus="true" />
            }
            else
            {
                <MudText Typo="Typo.h5" Style="font-weight: 700; cursor: pointer;"
                         @onclick="@(() => _editingName = true)">
                    @(_workflow?.Name ?? "Workflow Designer")
                    <MudIcon Icon="@Icons.Material.Outlined.Edit" Size="Size.Small"
                             Style="opacity: 0.4; margin-left: 4px; font-size: 14px;" />
                </MudText>
            }
            <MudText Typo="Typo.caption" Color="Color.Secondary">@(_workflow?.Description ?? "Design your workflow steps")</MudText>
        </div>
    </div>
    <div class="d-flex gap-2 align-center">
        @if (_executionMode)
        {
            <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Filled"
                     Style="animation: pulse-chip 1.5s ease-in-out infinite;">
                @_executionProgress
            </MudChip>
            <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.Stop" OnClick="StopExecution">
                Stop
            </MudButton>
        }
        else
        {
            @if (_executionCompleted)
            {
                <MudChip T="string" Size="Size.Small"
                         Color="@(_executionFailed ? Color.Error : Color.Success)"
                         Variant="Variant.Filled">
                    @(_executionFailed ? "Execution Failed" : "Execution Completed")
                </MudChip>
                <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                               OnClick="ClearExecutionState" aria-label="Clear execution" />
            }
            @if (_hasChanges)
            {
                <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined">Unsaved</MudChip>
            }

            @* Undo / Redo *@
            <MudTooltip Text="Undo (Ctrl+Z)">
                <MudIconButton Icon="@Icons.Material.Filled.Undo" Size="Size.Small"
                               Disabled="@(_undoStack.Count == 0)" OnClick="Undo" aria-label="Undo" />
            </MudTooltip>
            <MudTooltip Text="Redo (Ctrl+Y)">
                <MudIconButton Icon="@Icons.Material.Filled.Redo" Size="Size.Small"
                               Disabled="@(_redoStack.Count == 0)" OnClick="Redo" aria-label="Redo" />
            </MudTooltip>

            <MudDivider Vertical="true" FlexItem="true" Style="height: 24px;" />

            @* Variables *@
            <MudTooltip Text="Workflow Variables">
                <MudIconButton Icon="@Icons.Material.Outlined.DataObject" Size="Size.Small"
                               Color="@(_showVariables ? Color.Primary : Color.Default)"
                               OnClick="@(() => { _showVariables = !_showVariables; _editingStep = null; })"
                               aria-label="Variables" />
            </MudTooltip>

            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveWorkflow"
                       Disabled="_saving" StartIcon="@Icons.Material.Filled.Save" Size="Size.Small">
                @(_saving ? "Saving..." : "Save")
            </MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="ExecuteWorkflow"
                       Disabled="@(_saving || _steps.Count == 0 || _hasChanges)"
                       StartIcon="@Icons.Material.Filled.PlayCircle" Size="Size.Small">
                Execute
            </MudButton>
        }
    </div>
</div>

@* Execution Status Bar *@
@if (_executionMode || _executionCompleted)
{
    <MudPaper Elevation="0" Class="pa-3 mb-3" Style="border: 1px solid var(--mud-palette-divider); border-radius: 8px;">
        <div class="d-flex justify-space-between align-center mb-2">
            <div class="d-flex align-center gap-2">
                <MudIcon Icon="@(_executionMode ? Icons.Material.Filled.PlayCircle : (_executionFailed ? Icons.Material.Filled.ErrorOutline : Icons.Material.Filled.CheckCircle))"
                         Color="@(_executionMode ? Color.Info : (_executionFailed ? Color.Error : Color.Success))" Size="Size.Small" />
                <MudText Typo="Typo.subtitle2" Style="font-weight: 600;">
                    @(_executionMode ? "Executing Workflow..." : (_executionFailed ? "Execution Failed" : "Execution Complete"))
                </MudText>
            </div>
            <MudText Typo="Typo.caption" Color="Color.Secondary">@_executionProgress</MudText>
        </div>
        <MudProgressLinear Value="@_executionPercent" Color="@(_executionFailed ? Color.Error : Color.Success)"
                          Striped="@_executionMode" Size="Size.Medium" Rounded="true"
                          Style="height: 8px;" />
        @if (_executionCompleted && !_executionFailed)
        {
            <div class="d-flex justify-end mt-2">
                <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.OpenInNew"
                           OnClick="@(() => Navigation.NavigateTo($"/workflow-studio/runs/{_instanceId}"))">
                    View Full Details
                </MudButton>
            </div>
        }
        @if (_executionCompleted && _executionFailed && !string.IsNullOrEmpty(_executionError))
        {
            <MudAlert Severity="Severity.Error" Dense="true" Class="mt-2">@_executionError</MudAlert>
        }
    </MudPaper>
}

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_workflow is null)
{
    <MudAlert Severity="Severity.Error">Workflow not found.</MudAlert>
}
else
{
    <MudGrid Spacing="3">
        @* ── Left Panel: Steps, Inspector, Variables ── *@
        <MudItem xs="12" md="4">
            <MudPaper Elevation="0" Class="pa-4" Style="border: 1px solid var(--mud-palette-divider); max-height: 780px; overflow-y: auto;">

                @if (_showVariables)
                {
                    @* ── Workflow Variables Panel ── *@
                    <div class="d-flex justify-space-between align-center mb-3">
                        <div class="d-flex align-center gap-2">
                            <MudIcon Icon="@Icons.Material.Outlined.DataObject" Size="Size.Small" Color="Color.Primary" />
                            <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">Variables</MudText>
                        </div>
                        <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                                       OnClick="@(() => _showVariables = false)" aria-label="Close variables" />
                    </div>
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-3">
                        Define input parameters and variables for this workflow. These can be referenced in step configurations.
                    </MudText>

                    @for (var i = 0; i < _variables.Count; i++)
                    {
                        var idx = i;
                        <MudPaper Class="pa-3 mb-2" Elevation="0" Style="border: 1px solid var(--mud-palette-divider); border-radius: 8px;">
                            <MudGrid Spacing="2">
                                <MudItem xs="5">
                                    <MudTextField @bind-Value="_variables[idx].Name" Label="Name" Variant="Variant.Outlined"
                                                  Margin="Margin.Dense" Placeholder="e.g. amount" />
                                </MudItem>
                                <MudItem xs="4">
                                    <MudSelect T="string" @bind-Value="_variables[idx].Type" Label="Type" Variant="Variant.Outlined"
                                               Margin="Margin.Dense">
                                        <MudSelectItem T="string" Value="@("string")">String</MudSelectItem>
                                        <MudSelectItem T="string" Value="@("number")">Number</MudSelectItem>
                                        <MudSelectItem T="string" Value="@("boolean")">Boolean</MudSelectItem>
                                        <MudSelectItem T="string" Value="@("date")">Date</MudSelectItem>
                                        <MudSelectItem T="string" Value="@("object")">Object</MudSelectItem>
                                    </MudSelect>
                                </MudItem>
                                <MudItem xs="2">
                                    <MudCheckBox T="bool" @bind-Value="_variables[idx].Required" Label="Req" Dense="true"
                                                 Style="margin-top: 8px;" />
                                </MudItem>
                                <MudItem xs="1" Class="d-flex align-center justify-center">
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                                   OnClick="@(() => { _variables.RemoveAt(idx); _hasChanges = true; })" />
                                </MudItem>
                                <MudItem xs="9">
                                    <MudTextField @bind-Value="_variables[idx].DefaultValue" Label="Default" Variant="Variant.Outlined"
                                                  Margin="Margin.Dense" Placeholder="Default value" />
                                </MudItem>
                                <MudItem xs="3">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary" Style="margin-top: 14px;">
                                        @($"{{{{{_variables[idx].Name}}}}}")
                                    </MudText>
                                </MudItem>
                            </MudGrid>
                        </MudPaper>
                    }

                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small" FullWidth="true"
                               StartIcon="@Icons.Material.Filled.Add"
                               OnClick="@(() => { _variables.Add(new VariableItem()); _hasChanges = true; })">
                        Add Variable
                    </MudButton>
                }
                else if (_editingStep is not null)
                {
                    @* ── Full Step Inspector ── *@
                    <div class="d-flex justify-space-between align-center mb-3">
                        <div class="d-flex align-center gap-2">
                            <div style="width: 8px; height: 24px; border-radius: 4px; background: @StepHexColor(_editingStep.Action);"></div>
                            <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">Step Configuration</MudText>
                        </div>
                        <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                                       OnClick="@(() => _editingStep = null)" aria-label="Close step editor" />
                    </div>

                    @* Basic Info *@
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Style="font-weight: 600;" Class="mb-1">BASIC</MudText>
                    <MudTextField @bind-Value="_editingStep.Name" Label="Step Name" Variant="Variant.Outlined"
                                  Margin="Margin.Dense" Class="mb-2" />
                    <MudSelect T="string" Value="_editingStep.Action" Label="Type" Variant="Variant.Outlined"
                               Margin="Margin.Dense" Class="mb-2" ValueChanged="OnStepTypeChanged">
                        <MudSelectItem T="string" Value="@("Action")">
                            <div class="d-flex align-center gap-2">
                                <MudIcon Icon="@Icons.Material.Filled.PlayArrow" Size="Size.Small" />
                                Action
                            </div>
                        </MudSelectItem>
                        <MudSelectItem T="string" Value="@("Approval")">
                            <div class="d-flex align-center gap-2">
                                <MudIcon Icon="@Icons.Material.Filled.Approval" Size="Size.Small" />
                                Approval
                            </div>
                        </MudSelectItem>
                        <MudSelectItem T="string" Value="@("AI Generate")">
                            <div class="d-flex align-center gap-2">
                                <MudIcon Icon="@Icons.Material.Filled.SmartToy" Size="Size.Small" />
                                AI Generate
                            </div>
                        </MudSelectItem>
                        <MudSelectItem T="string" Value="@("Email")">
                            <div class="d-flex align-center gap-2">
                                <MudIcon Icon="@Icons.Material.Filled.Email" Size="Size.Small" />
                                Email
                            </div>
                        </MudSelectItem>
                        <MudSelectItem T="string" Value="@("API Call")">
                            <div class="d-flex align-center gap-2">
                                <MudIcon Icon="@Icons.Material.Filled.Api" Size="Size.Small" />
                                API Call
                            </div>
                        </MudSelectItem>
                        <MudSelectItem T="string" Value="@("Condition")">
                            <div class="d-flex align-center gap-2">
                                <MudIcon Icon="@Icons.Material.Filled.CallSplit" Size="Size.Small" />
                                Condition
                            </div>
                        </MudSelectItem>
                        <MudSelectItem T="string" Value="@("Delay")">
                            <div class="d-flex align-center gap-2">
                                <MudIcon Icon="@Icons.Material.Filled.HourglassBottom" Size="Size.Small" />
                                Delay / Wait
                            </div>
                        </MudSelectItem>
                        <MudSelectItem T="string" Value="@("Transform")">
                            <div class="d-flex align-center gap-2">
                                <MudIcon Icon="@Icons.Material.Filled.Transform" Size="Size.Small" />
                                Transform Data
                            </div>
                        </MudSelectItem>
                    </MudSelect>
                    <MudTextField @bind-Value="_editingStep.AssignedRole" Label="Assigned Role (optional)"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-3" />

                    <MudDivider Class="mb-3" />

                    @* Type-Specific Configuration *@
                    @switch ((_editingStep.Action ?? "").ToLowerInvariant())
                    {
                        case "approval":
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Style="font-weight: 600;" Class="mb-1">APPROVAL SETTINGS</MudText>
                            <MudSelect T="string" @bind-Value="_editingStep.Config.ApprovalType" Label="Approval Type"
                                       Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-2">
                                <MudSelectItem T="string" Value="@("single")">Single Approver</MudSelectItem>
                                <MudSelectItem T="string" Value="@("any")">Any One of Group</MudSelectItem>
                                <MudSelectItem T="string" Value="@("all")">All Must Approve</MudSelectItem>
                                <MudSelectItem T="string" Value="@("majority")">Majority Vote</MudSelectItem>
                            </MudSelect>
                            <MudTextField @bind-Value="_editingStep.Config.ApproverRoles" Label="Approver Roles (comma-separated)"
                                          Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-2"
                                          Placeholder="Manager, Director, Finance" />
                            <MudNumericField T="int" @bind-Value="_editingStep.Config.EscalationHours" Label="Escalation After (hours)"
                                             Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-2" Min="0" Max="720" />
                            <MudTextField @bind-Value="_editingStep.Config.EscalationTo" Label="Escalate To"
                                          Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-2"
                                          Placeholder="Director" />
                            <MudCheckBox T="bool" @bind-Value="_editingStep.Config.RequireComments" Label="Require comments on reject"
                                         Dense="true" Class="mb-2" />
                            break;

                        case "email":
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Style="font-weight: 600;" Class="mb-1">EMAIL SETTINGS</MudText>
                            <MudTextField @bind-Value="_editingStep.Config.EmailTo" Label="To"
                                          Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-2"
                                          Placeholder="{{requester_email}} or role:Manager" />
                            <MudTextField @bind-Value="_editingStep.Config.EmailCc" Label="CC (optional)"
                                          Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-2" />
                            <MudTextField @bind-Value="_editingStep.Config.EmailSubject" Label="Subject"
                                          Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-2"
                                          Placeholder="{{workflow_name}} - Action Required" />
                            <MudTextField @bind-Value="_editingStep.Config.EmailBody" Label="Body Template"
                                          Variant="Variant.Outlined" Margin="Margin.Dense" Lines="4" Class="mb-2"
                                          Placeholder="Dear {{approver_name}},&#10;&#10;Please review..." />
                            <MudSelect T="string" @bind-Value="_editingStep.Config.EmailTemplate" Label="Template"
                                       Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-2" Clearable="true">
                                <MudSelectItem T="string" Value="@("approval_request")">Approval Request</MudSelectItem>
                                <MudSelectItem T="string" Value="@("approval_result")">Approval Result</MudSelectItem>
                                <MudSelectItem T="string" Value="@("notification")">General Notification</MudSelectItem>
                                <MudSelectItem T="string" Value="@("welcome")">Welcome</MudSelectItem>
                            </MudSelect>
                            break;

                        case "ai generate":
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Style="font-weight: 600;" Class="mb-1">AI SETTINGS</MudText>
                            <MudTextField @bind-Value="_editingStep.Config.AiPrompt" Label="Prompt"
                                          Variant="Variant.Outlined" Margin="Margin.Dense" Lines="4" Class="mb-2"
                                          Placeholder="Summarize the document content and extract key entities..." />
                            <MudSelect T="string" @bind-Value="_editingStep.Config.AiModel" Label="Model"
                                       Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-2">
                                <MudSelectItem T="string" Value="@("default")">Default Model</MudSelectItem>
                                <MudSelectItem T="string" Value="@("gpt-4o")">GPT-4o</MudSelectItem>
                                <MudSelectItem T="string" Value="@("gpt-4o-mini")">GPT-4o Mini</MudSelectItem>
                                <MudSelectItem T="string" Value="@("claude-sonnet")">Claude Sonnet</MudSelectItem>
                            </MudSelect>
                            <MudNumericField T="int" @bind-Value="_editingStep.Config.AiMaxTokens" Label="Max Tokens"
                                             Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-2"
                                             Min="100" Max="32000" />
                            <MudNumericField T="double" @bind-Value="_editingStep.Config.AiTemperature" Label="Temperature"
                                             Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-2"
                                             Min="0.0" Max="2.0" Step="0.1" />
                            <MudTextField @bind-Value="_editingStep.Config.AiOutputVariable" Label="Save Output To Variable"
                                          Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-2"
                                          Placeholder="ai_result" />
                            break;

                        case "api call":
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Style="font-weight: 600;" Class="mb-1">API SETTINGS</MudText>
                            <MudGrid Spacing="2" Class="mb-2">
                                <MudItem xs="4">
                                    <MudSelect T="string" @bind-Value="_editingStep.Config.ApiMethod" Label="Method"
                                               Variant="Variant.Outlined" Margin="Margin.Dense">
                                        <MudSelectItem T="string" Value="@("GET")">GET</MudSelectItem>
                                        <MudSelectItem T="string" Value="@("POST")">POST</MudSelectItem>
                                        <MudSelectItem T="string" Value="@("PUT")">PUT</MudSelectItem>
                                        <MudSelectItem T="string" Value="@("PATCH")">PATCH</MudSelectItem>
                                        <MudSelectItem T="string" Value="@("DELETE")">DELETE</MudSelectItem>
                                    </MudSelect>
                                </MudItem>
                                <MudItem xs="8">
                                    <MudTextField @bind-Value="_editingStep.Config.ApiUrl" Label="URL"
                                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                                  Placeholder="https://api.example.com/endpoint" />
                                </MudItem>
                            </MudGrid>
                            <MudTextField @bind-Value="_editingStep.Config.ApiHeaders" Label="Headers (JSON)"
                                          Variant="Variant.Outlined" Margin="Margin.Dense" Lines="2" Class="mb-2"
                                          Placeholder='{"Authorization": "Bearer {{api_key}}"}' />
                            <MudTextField @bind-Value="_editingStep.Config.ApiBody" Label="Request Body (JSON)"
                                          Variant="Variant.Outlined" Margin="Margin.Dense" Lines="3" Class="mb-2"
                                          Placeholder='{"data": "{{input}}"}' />
                            <MudTextField @bind-Value="_editingStep.Config.ApiOutputVariable" Label="Save Response To"
                                          Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-2"
                                          Placeholder="api_response" />
                            <MudSelect T="string" @bind-Value="_editingStep.Config.ApiAuth" Label="Authentication"
                                       Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-2" Clearable="true">
                                <MudSelectItem T="string" Value="@("none")">None</MudSelectItem>
                                <MudSelectItem T="string" Value="@("bearer")">Bearer Token</MudSelectItem>
                                <MudSelectItem T="string" Value="@("basic")">Basic Auth</MudSelectItem>
                                <MudSelectItem T="string" Value="@("api_key")">API Key</MudSelectItem>
                                <MudSelectItem T="string" Value="@("integration")">Use Integration</MudSelectItem>
                            </MudSelect>
                            break;

                        case "condition":
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Style="font-weight: 600;" Class="mb-1">CONDITION SETTINGS</MudText>
                            <MudTextField @bind-Value="_editingStep.Config.ConditionExpression" Label="Expression"
                                          Variant="Variant.Outlined" Margin="Margin.Dense" Lines="2" Class="mb-2"
                                          Placeholder="{{amount}} > 100000" />
                            <MudAlert Severity="Severity.Info" Dense="true" Class="mb-2" Style="font-size: 0.75rem;">
                                Use variables like <code>@("{{amount}}")</code> in expressions. Supports <code>&gt;</code>, <code>&lt;</code>, <code>==</code>, <code>!=</code>, <code>contains</code>, <code>&&</code>, <code>||</code>
                            </MudAlert>
                            <MudTextField @bind-Value="_editingStep.Config.TrueBranch" Label="If True → Go To Step"
                                          Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-2"
                                          Placeholder="Next step name or number" />
                            <MudTextField @bind-Value="_editingStep.Config.FalseBranch" Label="If False → Go To Step"
                                          Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-2"
                                          Placeholder="Step name or 'skip'" />
                            break;

                        case "delay":
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Style="font-weight: 600;" Class="mb-1">DELAY SETTINGS</MudText>
                            <MudGrid Spacing="2" Class="mb-2">
                                <MudItem xs="6">
                                    <MudNumericField T="int" @bind-Value="_editingStep.Config.DelayDuration" Label="Duration"
                                                     Variant="Variant.Outlined" Margin="Margin.Dense" Min="1" />
                                </MudItem>
                                <MudItem xs="6">
                                    <MudSelect T="string" @bind-Value="_editingStep.Config.DelayUnit" Label="Unit"
                                               Variant="Variant.Outlined" Margin="Margin.Dense">
                                        <MudSelectItem T="string" Value="@("minutes")">Minutes</MudSelectItem>
                                        <MudSelectItem T="string" Value="@("hours")">Hours</MudSelectItem>
                                        <MudSelectItem T="string" Value="@("days")">Days</MudSelectItem>
                                    </MudSelect>
                                </MudItem>
                            </MudGrid>
                            <MudCheckBox T="bool" @bind-Value="_editingStep.Config.WaitForEvent" Label="Wait for external event instead"
                                         Dense="true" Class="mb-2" />
                            @if (_editingStep.Config.WaitForEvent)
                            {
                                <MudTextField @bind-Value="_editingStep.Config.WaitEventName" Label="Event Name"
                                              Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-2"
                                              Placeholder="payment_received" />
                            }
                            break;

                        case "transform":
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Style="font-weight: 600;" Class="mb-1">TRANSFORM SETTINGS</MudText>
                            <MudTextField @bind-Value="_editingStep.Config.TransformInput" Label="Input Variable"
                                          Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-2"
                                          Placeholder="api_response" />
                            <MudSelect T="string" @bind-Value="_editingStep.Config.TransformOperation" Label="Operation"
                                       Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-2">
                                <MudSelectItem T="string" Value="@("extract")">Extract Field</MudSelectItem>
                                <MudSelectItem T="string" Value="@("map")">Map / Rename Fields</MudSelectItem>
                                <MudSelectItem T="string" Value="@("filter")">Filter Array</MudSelectItem>
                                <MudSelectItem T="string" Value="@("aggregate")">Aggregate (sum/count/avg)</MudSelectItem>
                                <MudSelectItem T="string" Value="@("format")">Format / Template</MudSelectItem>
                            </MudSelect>
                            <MudTextField @bind-Value="_editingStep.Config.TransformExpression" Label="Expression / JSONPath"
                                          Variant="Variant.Outlined" Margin="Margin.Dense" Lines="2" Class="mb-2"
                                          Placeholder="$.data.items[*].name" />
                            <MudTextField @bind-Value="_editingStep.Config.TransformOutput" Label="Output Variable"
                                          Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-2"
                                          Placeholder="transformed_data" />
                            break;

                        default:
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Style="font-weight: 600;" Class="mb-1">ACTION SETTINGS</MudText>
                            <MudTextField @bind-Value="_editingStep.Config.ActionDescription" Label="Description"
                                          Variant="Variant.Outlined" Margin="Margin.Dense" Lines="2" Class="mb-2"
                                          Placeholder="Describe what this action does..." />
                            break;
                    }

                    @* Common: Timeout & Retry *@
                    <MudDivider Class="my-3" />
                    <MudExpansionPanels Elevation="0" Dense="true">
                        <MudExpansionPanel Text="Timeout & Retry" MaxHeight="400" Dense="true"
                                           Style="border: 1px solid var(--mud-palette-divider); border-radius: 8px;">
                            <MudNumericField T="int" @bind-Value="_editingStep.Config.TimeoutMinutes" Label="Timeout (minutes)"
                                             Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-2"
                                             Min="0" Max="10080" />
                            <MudNumericField T="int" @bind-Value="_editingStep.Config.RetryCount" Label="Max Retries"
                                             Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-2"
                                             Min="0" Max="10" />
                            <MudNumericField T="int" @bind-Value="_editingStep.Config.RetryDelaySeconds" Label="Retry Delay (seconds)"
                                             Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-2"
                                             Min="0" Max="3600" />
                            <MudSelect T="string" @bind-Value="_editingStep.Config.OnFailure" Label="On Failure"
                                       Variant="Variant.Outlined" Margin="Margin.Dense">
                                <MudSelectItem T="string" Value="@("stop")">Stop Workflow</MudSelectItem>
                                <MudSelectItem T="string" Value="@("skip")">Skip & Continue</MudSelectItem>
                                <MudSelectItem T="string" Value="@("retry")">Auto-Retry</MudSelectItem>
                                <MudSelectItem T="string" Value="@("fallback")">Run Fallback Step</MudSelectItem>
                            </MudSelect>
                        </MudExpansionPanel>
                    </MudExpansionPanels>

                    @* Actions *@
                    <div class="d-flex gap-2 mt-3">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" FullWidth="true"
                                   OnClick="@(() => { _editingStep = null; _hasChanges = true; })">
                            Done
                        </MudButton>
                        <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Delete"
                                   OnClick="@(() => { PushUndo(); _steps.Remove(_editingStep); _editingStep = null; _hasChanges = true; })">
                            Delete
                        </MudButton>
                    </div>
                }
                else
                {
                    @* ── Step List ── *@
                    <div class="d-flex justify-space-between align-center mb-2">
                        <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">
                            Steps (@_steps.Count)
                        </MudText>
                        @if (_steps.Count > 0)
                        {
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Click to configure</MudText>
                        }
                    </div>

                    @for (var i = 0; i < _steps.Count; i++)
                    {
                        var step = _steps[i];
                        var index = i;
                        var isDragging = _dragFromIndex == index;
                        var isDropTarget = _dropTargetIndex == index;
                        var rowStyle = $"border: 1px solid var(--mud-palette-divider); border-left: 4px solid {StepHexColor(step.Action)}; border-radius: 8px; cursor: grab; transition: all 0.15s ease;"
                            + (isDragging ? " opacity: 0.4;" : "")
                            + (isDropTarget ? " border-top: 2px solid var(--mud-palette-primary); margin-top: 6px;" : "");

                        <div draggable="true"
                             @ondragstart="@(() => OnDragStart(index))"
                             @ondragover="@(() => OnDragOver(index))"
                             @ondragover:preventDefault="true"
                             @ondragleave="OnDragLeave"
                             @ondrop="@(() => OnDrop(index))"
                             @ondragend="OnDragEnd">
                            <MudPaper Class="pa-3 mb-2" Elevation="0"
                                      Style="@rowStyle"
                                      @onclick="@(() => { _editingStep = step; _showVariables = false; })">
                                <div class="d-flex justify-space-between align-center">
                                    <div class="d-flex align-center gap-2" style="min-width: 0; flex: 1;">
                                        <MudIcon Icon="@Icons.Material.Filled.DragIndicator" Size="Size.Small"
                                                 Color="Color.Secondary" Style="opacity: 0.5; flex-shrink: 0;" />
                                        <MudText Typo="Typo.caption" Color="Color.Secondary" Style="min-width: 18px; font-weight: 600; flex-shrink: 0;">@(index + 1)</MudText>
                                        <div style="min-width: 0; overflow: hidden;">
                                            <MudText Typo="Typo.body2" Style="font-weight: 500; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">@step.Name</MudText>
                                            <div class="d-flex align-center gap-1">
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">@step.Action</MudText>
                                                @if (HasStepConfig(step))
                                                {
                                                    <MudIcon Icon="@Icons.Material.Filled.Settings" Size="Size.Small"
                                                             Style="font-size: 11px; color: var(--mud-palette-text-secondary); opacity: 0.5;" />
                                                }
                                            </div>
                                        </div>
                                    </div>
                                    <div class="d-flex flex-shrink-0">
                                        <MudIconButton Icon="@Icons.Material.Filled.ArrowUpward" Size="Size.Small"
                                                       Disabled="@(index == 0)" OnClick="@(() => { PushUndo(); MoveStep(index, -1); })"
                                                       aria-label="Move up" />
                                        <MudIconButton Icon="@Icons.Material.Filled.ArrowDownward" Size="Size.Small"
                                                       Disabled="@(index == _steps.Count - 1)" OnClick="@(() => { PushUndo(); MoveStep(index, 1); })"
                                                       aria-label="Move down" />
                                    </div>
                                </div>
                                @if (!string.IsNullOrEmpty(step.AssignedRole))
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Info" Class="mt-1"
                                             Style="font-size: 0.65rem;">@step.AssignedRole</MudChip>
                                }
                            </MudPaper>
                        </div>
                    }

                    @* Quick Add Palette *@
                    <MudDivider Class="my-3" />
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2" Style="font-weight: 600;">QUICK ADD</MudText>
                    <div class="d-flex gap-1 flex-wrap mb-3">
                        <MudButton Variant="Variant.Outlined" Size="Size.Small" Color="Color.Default"
                                   StartIcon="@Icons.Material.Filled.PlayArrow"
                                   OnClick="@(() => QuickAddStep("Action", "New Action"))">Action</MudButton>
                        <MudButton Variant="Variant.Outlined" Size="Size.Small" Color="Color.Warning"
                                   StartIcon="@Icons.Material.Filled.Approval"
                                   OnClick="@(() => QuickAddStep("Approval", "Approval Step"))">Approval</MudButton>
                        <MudButton Variant="Variant.Outlined" Size="Size.Small" Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.SmartToy"
                                   OnClick="@(() => QuickAddStep("AI Generate", "AI Processing"))">AI</MudButton>
                        <MudButton Variant="Variant.Outlined" Size="Size.Small" Color="Color.Info"
                                   StartIcon="@Icons.Material.Filled.Email"
                                   OnClick="@(() => QuickAddStep("Email", "Send Notification"))">Email</MudButton>
                        <MudButton Variant="Variant.Outlined" Size="Size.Small" Color="Color.Secondary"
                                   StartIcon="@Icons.Material.Filled.Api"
                                   OnClick="@(() => QuickAddStep("API Call", "API Integration"))">API</MudButton>
                        <MudButton Variant="Variant.Outlined" Size="Size.Small" Color="Color.Tertiary"
                                   StartIcon="@Icons.Material.Filled.CallSplit"
                                   OnClick="@(() => QuickAddStep("Condition", "Condition Check"))">Condition</MudButton>
                        <MudButton Variant="Variant.Outlined" Size="Size.Small" Color="Color.Default"
                                   StartIcon="@Icons.Material.Filled.HourglassBottom"
                                   OnClick="@(() => QuickAddStep("Delay", "Wait"))">Delay</MudButton>
                    </div>

                    @* AI Step Suggestion *@
                    <MudDivider Class="my-3" />
                    <div class="d-flex align-center gap-2 mb-2">
                        <MudIcon Icon="@Icons.Material.Outlined.AutoAwesome" Color="Color.Primary" Size="Size.Small" />
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Style="font-weight: 600;">AI SUGGEST</MudText>
                    </div>
                    <MudTextField @bind-Value="_aiStepPrompt" Placeholder="e.g. 'Send email when approved'"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-2"
                                  Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Add"
                                  AdornmentColor="Color.Primary" OnAdornmentClick="GenerateStep"
                                  OnKeyUp="HandleAiStepKeyUp" />
                }
            </MudPaper>
        </MudItem>

        @* ── Right Panel: SVG Visual Canvas ── *@
        <MudItem xs="12" md="8">
            <MudPaper Elevation="0" Style="border: 1px solid var(--mud-palette-divider); overflow: hidden;">
                <div class="d-flex justify-space-between align-center pa-3" style="border-bottom: 1px solid var(--mud-palette-divider);">
                    <div class="d-flex align-center gap-2">
                        <MudIcon Icon="@Icons.Material.Outlined.AccountTree" Size="Size.Small" Color="Color.Primary" />
                        <MudText Typo="Typo.subtitle2" Style="font-weight: 600;">Visual Canvas</MudText>
                        <MudChip T="string" Size="Size.Small" Color="Color.Default" Style="font-size: 0.65rem; height: 20px;">
                            @_steps.Count step@(_steps.Count != 1 ? "s" : "")
                        </MudChip>
                    </div>
                    <div class="d-flex align-center gap-1">
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="me-2 d-none d-md-inline">
                            Click node · Drag to reorder · <kbd style="background:#F3F4F6;padding:1px 4px;border-radius:3px;font-size:0.7rem;">Del</kbd> remove ·
                            <kbd style="background:#F3F4F6;padding:1px 4px;border-radius:3px;font-size:0.7rem;">Ctrl+Z</kbd> undo
                        </MudText>
                        <MudIconButton Icon="@Icons.Material.Filled.Remove" Size="Size.Small"
                                       OnClick="ZoomOut" Disabled="@(_zoom <= MinZoom)" aria-label="Zoom out" />
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Style="min-width: 38px; text-align: center; font-weight: 600;">
                            @($"{(int)(_zoom * 100)}%")
                        </MudText>
                        <MudIconButton Icon="@Icons.Material.Filled.Add" Size="Size.Small"
                                       OnClick="ZoomIn" Disabled="@(_zoom >= MaxZoom)" aria-label="Zoom in" />
                        <MudIconButton Icon="@Icons.Material.Filled.CenterFocusStrong" Size="Size.Small"
                                       OnClick="ZoomReset" Disabled="@(_zoom == 1.0)" aria-label="Reset zoom" />
                    </div>
                </div>

                <div tabindex="0" @onkeydown="OnCanvasKeyDown"
                     style="overflow: auto; max-height: 700px; background: var(--mud-palette-background); outline: none;">
                    <svg viewBox="0 0 600 @CanvasHeight"
                         xmlns="http://www.w3.org/2000/svg"
                         style="@($"width: 100%; display: block; min-height: 400px; transform: scale({_zoom.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture)}); transform-origin: top center; transition: transform 0.15s ease;")">
                        <defs>
                            <marker id="wf-arrow" markerWidth="8" markerHeight="6" refX="7" refY="3" orient="auto">
                                <polygon points="0 0, 8 3, 0 6" fill="#9CA3AF" />
                            </marker>
                            <filter id="wf-shadow" x="-20%" y="-20%" width="140%" height="140%">
                                <feDropShadow dx="0" dy="2" stdDeviation="3" flood-color="#000000" flood-opacity="0.07" />
                            </filter>
                            <filter id="wf-shadow-sel" x="-30%" y="-30%" width="160%" height="160%">
                                <feDropShadow dx="0" dy="0" stdDeviation="6" flood-color="#7C3AED" flood-opacity="0.25" />
                            </filter>
                            <filter id="wf-glow-running" x="-40%" y="-40%" width="180%" height="180%">
                                <feDropShadow dx="0" dy="0" stdDeviation="6" flood-color="#3B82F6" flood-opacity="0.5">
                                    <animate attributeName="stdDeviation" values="4;8;4" dur="1.5s" repeatCount="indefinite" />
                                    <animate attributeName="flood-opacity" values="0.3;0.6;0.3" dur="1.5s" repeatCount="indefinite" />
                                </feDropShadow>
                            </filter>
                            <filter id="wf-glow-completed" x="-30%" y="-30%" width="160%" height="160%">
                                <feDropShadow dx="0" dy="0" stdDeviation="4" flood-color="#10B981" flood-opacity="0.3" />
                            </filter>
                            <filter id="wf-glow-failed" x="-30%" y="-30%" width="160%" height="160%">
                                <feDropShadow dx="0" dy="0" stdDeviation="4" flood-color="#EF4444" flood-opacity="0.3" />
                            </filter>
                        </defs>

                        @* — START NODE — *@
                        <ellipse cx="300" cy="@StartCY" rx="56" ry="22" fill="#10B981" filter="url(#wf-shadow)" />
                        @((MarkupString)$"<text x=\"300\" y=\"{StartCY + 5}\" text-anchor=\"middle\" fill=\"white\" font-size=\"12\" font-weight=\"700\" font-family=\"Inter,sans-serif\">START</text>")

                        @for (int i = 0; i < _steps.Count; i++)
                        {
                            var step = _steps[i];
                            var idx = i;
                            var selected = _editingStep == step;
                            var ny = NodeTop(i);
                            var prevBottom = i == 0 ? StartCY + 22 : NodeTop(i - 1) + NodeH;
                            var connMidY = (prevBottom + ny) / 2;
                            var isCondition = (step.Action ?? "").Equals("Condition", StringComparison.OrdinalIgnoreCase);

                            @* Connector line *@
                            <path d="M 300,@prevBottom C 300,@(prevBottom + 36) 300,@(ny - 36) 300,@ny"
                                  stroke="#9CA3AF" stroke-width="1.5" fill="none" stroke-opacity="0.6"
                                  marker-end="url(#wf-arrow)" />

                            @* + Insert button on connector *@
                            <g @onclick="@(() => InsertStep(idx))" style="cursor:pointer;" title="Insert step here">
                                <circle cx="300" cy="@connMidY" r="12" fill="white"
                                        stroke="#7C3AED" stroke-width="1.5" filter="url(#wf-shadow)" />
                                @((MarkupString)$"<text x=\"300\" y=\"{connMidY + 5}\" text-anchor=\"middle\" fill=\"#7C3AED\" font-size=\"17\" font-weight=\"300\" font-family=\"Inter,sans-serif\">+</text>")
                            </g>

                            @* Step Node *@
                            <g @onclick="@(() => SelectStep(step))" style="cursor:pointer;">
                                @if (isCondition)
                                {
                                    @* Diamond shape for conditions *@
                                    var cx = 300;
                                    var cy = ny + NodeH / 2;
                                    var hw = 120;
                                    var hh = NodeH / 2;
                                    <polygon points="@($"{cx},{cy - hh} {cx + hw},{cy} {cx},{cy + hh} {cx - hw},{cy}")"
                                             fill="white"
                                             stroke="@NodeStroke(idx, selected)"
                                             stroke-width="@NodeStrokeWidth(idx, selected)"
                                             stroke-dasharray="@NodeDash(idx)"
                                             filter="@NodeFilter(idx, selected)" />
                                    @((MarkupString)$"<text x=\"{cx}\" y=\"{cy - 6}\" text-anchor=\"middle\" font-size=\"11\" font-weight=\"600\" fill=\"#111827\" font-family=\"Inter,sans-serif\">{System.Net.WebUtility.HtmlEncode(TruncateLabel(step.Name, 20))}</text>")
                                    @((MarkupString)$"<text x=\"{cx}\" y=\"{cy + 10}\" text-anchor=\"middle\" font-size=\"9\" fill=\"#0EA5E9\" font-family=\"Inter,sans-serif\">Condition</text>")

                                    @* Branch labels *@
                                    @((MarkupString)$"<text x=\"{cx + hw + 12}\" y=\"{cy + 4}\" font-size=\"9\" font-weight=\"600\" fill=\"#10B981\" font-family=\"Inter,sans-serif\">True</text>")
                                    @((MarkupString)$"<text x=\"{cx - hw - 12}\" y=\"{cy + 4}\" font-size=\"9\" font-weight=\"600\" fill=\"#EF4444\" font-family=\"Inter,sans-serif\" text-anchor=\"end\">False</text>")
                                }
                                else
                                {
                                    <rect x="180" y="@ny" width="240" height="@NodeH" rx="10"
                                          fill="white"
                                          stroke="@NodeStroke(idx, selected)"
                                          stroke-width="@NodeStrokeWidth(idx, selected)"
                                          stroke-dasharray="@NodeDash(idx)"
                                          filter="@NodeFilter(idx, selected)" />
                                    @if (GetStepExecutionStatus(idx) == "Running")
                                    {
                                        <rect x="180" y="@ny" width="240" height="@NodeH" rx="10"
                                              fill="none" stroke="#3B82F6" stroke-width="2">
                                            <animate attributeName="stroke-opacity" values="1;0.3;1" dur="1.2s" repeatCount="indefinite" />
                                        </rect>
                                    }
                                    <rect x="180" y="@ny" width="5" height="@NodeH" rx="2"
                                          fill="@StepHexColor(step.Action)" />
                                    <circle cx="207" cy="@(ny + NodeH / 2)" r="15"
                                            fill="@StepHexBg(step.Action)" />
                                    @((MarkupString)GetStepIconSvg(step.Action, 207, ny + NodeH / 2))
                                    @((MarkupString)$"<text x=\"228\" y=\"{ny + 27}\" font-size=\"12\" font-weight=\"600\" fill=\"#111827\" font-family=\"Inter,sans-serif\">{System.Net.WebUtility.HtmlEncode(TruncateLabel(step.Name, 22))}</text>")
                                    @((MarkupString)$"<text x=\"228\" y=\"{ny + 45}\" font-size=\"10.5\" fill=\"#6B7280\" font-family=\"Inter,sans-serif\">{System.Net.WebUtility.HtmlEncode(step.Action + (!string.IsNullOrEmpty(step.AssignedRole) ? $" · {step.AssignedRole}" : ""))}</text>")
                                }

                                @* Status overlay or step number *@
                                @if (GetStepExecutionStatus(idx) == "Completed")
                                {
                                    <circle cx="396" cy="@(ny + NodeH / 2)" r="13" fill="#10B981" />
                                    @((MarkupString)$"<text x=\"396\" y=\"{ny + NodeH / 2 + 5}\" text-anchor=\"middle\" font-size=\"14\" font-weight=\"700\" fill=\"white\" font-family=\"Inter,sans-serif\">&#x2713;</text>")
                                }
                                else if (GetStepExecutionStatus(idx) == "Failed")
                                {
                                    <circle cx="396" cy="@(ny + NodeH / 2)" r="13" fill="#EF4444" />
                                    @((MarkupString)$"<text x=\"396\" y=\"{ny + NodeH / 2 + 5}\" text-anchor=\"middle\" font-size=\"14\" font-weight=\"700\" fill=\"white\" font-family=\"Inter,sans-serif\">&#x2717;</text>")
                                }
                                else if (GetStepExecutionStatus(idx) == "Running")
                                {
                                    <circle cx="396" cy="@(ny + NodeH / 2)" r="13" fill="#3B82F6">
                                        <animate attributeName="fill-opacity" values="1;0.5;1" dur="1s" repeatCount="indefinite" />
                                    </circle>
                                    @((MarkupString)$"<text x=\"396\" y=\"{ny + NodeH / 2 + 4}\" text-anchor=\"middle\" font-size=\"10\" font-weight=\"700\" fill=\"white\" font-family=\"Inter,sans-serif\">&#9654;</text>")
                                }
                                else if (!isCondition)
                                {
                                    <circle cx="396" cy="@(ny + NodeH / 2)" r="13" fill="@(selected ? "#7C3AED" : (IsExecPending(idx) ? "#E5E7EB" : "#F3F4F6"))" />
                                    @((MarkupString)$"<text x=\"396\" y=\"{ny + NodeH / 2 + 4}\" text-anchor=\"middle\" font-size=\"10\" font-weight=\"700\" fill=\"{(selected ? "white" : (IsExecPending(idx) ? "#9CA3AF" : "#7C3AED"))}\" font-family=\"Inter,sans-serif\">{i + 1}</text>")
                                }

                                @if (HasStepConfig(step) && !isCondition)
                                {
                                    <circle cx="195" cy="@(ny + 8)" r="5" fill="#7C3AED" />
                                    @((MarkupString)$"<text x=\"195\" y=\"{ny + 11}\" text-anchor=\"middle\" font-size=\"7\" fill=\"white\" font-family=\"Inter,sans-serif\">&#9881;</text>")
                                }

                                @* Status label below node in execution mode *@
                                @if (_executionMode || _executionCompleted)
                                {
                                    @((MarkupString)$"<text x=\"300\" y=\"{ny + NodeH + 16}\" text-anchor=\"middle\" font-size=\"9\" font-weight=\"600\" fill=\"{ExecStatusColor(idx)}\" font-family=\"Inter,sans-serif\">{GetStepExecutionStatus(idx)}</text>")
                                }
                            </g>
                        }

                        @* — Connector to END — *@
                        @{
                            var lastBottom = _steps.Count == 0 ? StartCY + 22 : NodeTop(_steps.Count - 1) + NodeH;
                            var endCY = EndCY;
                            var endConnMidY = (lastBottom + endCY - 22) / 2;
                        }
                        <path d="M 300,@lastBottom C 300,@(lastBottom + 36) 300,@(endCY - 22 - 36) 300,@(endCY - 22)"
                              stroke="#9CA3AF" stroke-width="1.5" fill="none" stroke-opacity="0.6"
                              marker-end="url(#wf-arrow)" />

                        @* + Append button before End *@
                        <g @onclick="@(() => QuickAddStep("Action", "New Step"))" style="cursor:pointer;">
                            <circle cx="300" cy="@endConnMidY" r="12" fill="white"
                                    stroke="#7C3AED" stroke-width="1.5" filter="url(#wf-shadow)" />
                            @((MarkupString)$"<text x=\"300\" y=\"{endConnMidY + 5}\" text-anchor=\"middle\" fill=\"#7C3AED\" font-size=\"17\" font-weight=\"300\" font-family=\"Inter,sans-serif\">+</text>")
                        </g>

                        @* — END NODE — *@
                        <ellipse cx="300" cy="@endCY" rx="56" ry="22" fill="#EF4444" filter="url(#wf-shadow)" />
                        @((MarkupString)$"<text x=\"300\" y=\"{endCY + 5}\" text-anchor=\"middle\" fill=\"white\" font-size=\"12\" font-weight=\"700\" font-family=\"Inter,sans-serif\">END</text>")

                        @* Empty state *@
                        @if (_steps.Count == 0)
                        {
                            <rect x="170" y="@(StartCY + 48)" width="260" height="72" rx="10"
                                  fill="none" stroke="#D1D5DB" stroke-width="1.5" stroke-dasharray="6 4" />
                            @((MarkupString)$"<text x=\"300\" y=\"{StartCY + 83}\" text-anchor=\"middle\" font-size=\"12\" fill=\"#9CA3AF\" font-family=\"Inter,sans-serif\">Click + to add your first step</text>")
                            @((MarkupString)$"<text x=\"300\" y=\"{StartCY + 101}\" text-anchor=\"middle\" font-size=\"10\" fill=\"#D1D5DB\" font-family=\"Inter,sans-serif\">or use Quick Add on the left panel</text>")
                        }
                    </svg>
                </div>

                @* Minimap *@
                @if (_steps.Count > 4)
                {
                    <div style="position: relative;">
                        <div class="wf-minimap">
                            <MudText Typo="Typo.caption" Style="font-size: 0.6rem; opacity: 0.7; margin-bottom: 2px;">@_steps.Count steps</MudText>
                            @for (int i = 0; i < _steps.Count; i++)
                            {
                                var step = _steps[i];
                                var status = GetStepExecutionStatus(i);
                                var miniColor = status switch
                                {
                                    "Completed" => "#10B981",
                                    "Running" => "#3B82F6",
                                    "Failed" => "#EF4444",
                                    _ => StepHexColor(step.Action)
                                };
                                <div style="@($"height: 4px; background: {miniColor}; border-radius: 2px; opacity: {(_editingStep == step ? "1" : "0.5")};")"
                                     title="@step.Name"></div>
                            }
                        </div>
                    </div>
                }
            </MudPaper>
        </MudItem>
    </MudGrid>
}

@code {
    [Parameter] public string WorkflowId { get; set; } = string.Empty;

    private WorkflowDetailDto? _workflow;
    private List<StepItem> _steps = new();
    private List<VariableItem> _variables = new();
    private StepItem? _editingStep;
    private bool _loading = true;
    private bool _saving;
    private bool _hasChanges;
    private bool _editingName;
    private bool _showVariables;
    private string _aiStepPrompt = string.Empty;

    // Undo/Redo
    private Stack<List<StepItem>> _undoStack = new();
    private Stack<List<StepItem>> _redoStack = new();
    private const int MaxUndoDepth = 30;

    // Execution mode state
    private bool _executionMode;
    private bool _executionCompleted;
    private bool _executionFailed;
    private Guid? _instanceId;
    private Dictionary<int, string> _stepStatuses = new();
    private string _executionProgress = string.Empty;
    private string? _executionError;
    private double _executionPercent;
    private System.Threading.Timer? _pollTimer;
    private bool _isPolling;

    // Drag-and-drop state
    private int? _dragFromIndex;
    private int? _dropTargetIndex;

    // Canvas zoom
    private double _zoom = 1.0;
    private const double MinZoom = 0.5;
    private const double MaxZoom = 1.5;

    private void ZoomIn() { _zoom = Math.Min(MaxZoom, Math.Round(_zoom + 0.1, 2)); }
    private void ZoomOut() { _zoom = Math.Max(MinZoom, Math.Round(_zoom - 0.1, 2)); }
    private void ZoomReset() { _zoom = 1.0; }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var raw = await Http.GetFromJsonAsync<WorkflowRawDto>($"/api/v1/workflows/{WorkflowId}");
                if (raw is not null)
                {
                    _workflow = new WorkflowDetailDto { Id = raw.Id, Name = raw.Name, Description = raw.Description };

                    if (!string.IsNullOrEmpty(raw.Steps))
                    {
                        var parsedSteps = System.Text.Json.JsonSerializer.Deserialize<List<StepDto>>(
                            raw.Steps, new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });

                        if (parsedSteps is not null)
                            _steps = parsedSteps.OrderBy(s => s.Order).Select(s => new StepItem
                            {
                                Name = s.Name,
                                Action = s.Action ?? "Action",
                                AssignedRole = s.AssignedRole,
                                Config = s.Config ?? new StepConfig()
                            }).ToList();
                    }
                }
            }
            catch (Exception ex) { Snackbar.Add($"Failed to load: {ex.Message}", Severity.Error); }
            finally { _loading = false; StateHasChanged(); }
        }
    }

