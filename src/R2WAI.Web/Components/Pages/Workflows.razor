@page "/workflow-studio"
@page "/workflows"
@attribute [Authorize]
@inject AuthenticatedHttpClient Http
@inject ISnackbar Snackbar
@inject IDialogService Dialog
@inject NavigationManager Navigation

<PageTitle>R2WAI - Workflow Studio</PageTitle>

<PageHeader Title="Workflow Studio" Subtitle="Design, execute, and monitor business workflows" />

@* ── Analytics Summary Bar ── *@
@if (!_loadingWorkflows && _workflows.Count > 0)
{
    <MudGrid Class="mb-4 stagger-in" Spacing="3">
        <MudItem xs="6" sm="3">
            <MudPaper Elevation="0" Class="pa-3 wf-stat-card">
                <div class="d-flex align-center gap-2">
                    <div class="wf-stat-icon wf-stat-icon--primary">
                        <MudIcon Icon="@Icons.Material.Outlined.AccountTree" Size="Size.Small" />
                    </div>
                    <div>
                        <MudText Typo="Typo.h5" Style="font-weight: 700; line-height: 1;">@_workflows.Count</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Total Workflows</MudText>
                    </div>
                </div>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudPaper Elevation="0" Class="pa-3 wf-stat-card">
                <div class="d-flex align-center gap-2">
                    <div class="wf-stat-icon wf-stat-icon--success">
                        <MudIcon Icon="@Icons.Material.Outlined.CheckCircle" Size="Size.Small" />
                    </div>
                    <div>
                        <MudText Typo="Typo.h5" Style="font-weight: 700; line-height: 1;">@_workflows.Count(w => w.IsActive && !w.IsArchived)</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Active</MudText>
                    </div>
                </div>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudPaper Elevation="0" Class="pa-3 wf-stat-card">
                <div class="d-flex align-center gap-2">
                    <div class="wf-stat-icon wf-stat-icon--info">
                        <MudIcon Icon="@Icons.Material.Outlined.PlaylistPlay" Size="Size.Small" />
                    </div>
                    <div>
                        <MudText Typo="Typo.h5" Style="font-weight: 700; line-height: 1;">@_instances.Count</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Total Runs</MudText>
                    </div>
                </div>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudPaper Elevation="0" Class="pa-3 wf-stat-card">
                <div class="d-flex align-center gap-2">
                    <div class="wf-stat-icon wf-stat-icon--warning">
                        <MudIcon Icon="@Icons.Material.Outlined.PendingActions" Size="Size.Small" />
                    </div>
                    <div>
                        <MudText Typo="Typo.h5" Style="font-weight: 700; line-height: 1;">@_pendingApprovals.Count</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Pending Approvals</MudText>
                    </div>
                </div>
            </MudPaper>
        </MudItem>
    </MudGrid>
}

@* AI Workflow Generator *@
@if (_showGenerator)
{
    <MudPaper Elevation="0" Class="pa-4 mb-4 ai-command-bar">
        <div class="d-flex justify-space-between align-center mb-3">
            <div class="d-flex align-center gap-2">
                <div class="icon-container icon-container--primary">
                    <MudIcon Icon="@Icons.Material.Outlined.AutoAwesome" Color="Color.Primary" Size="Size.Small" />
                </div>
                <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">AI Workflow Generator</MudText>
            </div>
            <MudIconButton Icon="@Icons.Material.Outlined.Close" Size="Size.Small" OnClick="@(() => _showGenerator = false)" aria-label="Close generator" />
        </div>

        @if (!_generating)
        {
            <MudTextField @bind-Value="_generatorPrompt" Lines="3" Variant="Variant.Outlined"
                          Placeholder="Describe your workflow... e.g. 'Create an invoice approval workflow above ₹100,000 requiring manager and finance approval'"
                          Class="mb-3" />
            <div class="d-flex justify-space-between align-center">
                <div class="d-flex gap-2 flex-wrap">
                    <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined"
                             OnClick="@(() => ApplyTemplate("invoice"))">Invoice Approval</MudChip>
                    <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Outlined"
                             OnClick="@(() => ApplyTemplate("leave"))">Leave Request</MudChip>
                    <MudChip T="string" Size="Size.Small" Color="Color.Tertiary" Variant="Variant.Outlined"
                             OnClick="@(() => ApplyTemplate("expense"))">Expense Report</MudChip>
                    <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined"
                             OnClick="@(() => ApplyTemplate("onboarding"))">Employee Onboarding</MudChip>
                </div>
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.AutoAwesome" OnClick="GenerateWorkflow"
                           Disabled="@string.IsNullOrWhiteSpace(_generatorPrompt)">
                    Generate
                </MudButton>
            </div>
        }
        else
        {
            <div class="d-flex flex-column gap-3 py-4">
                <div class="d-flex align-center gap-3">
                    @if (_genStep >= 1)
                    { <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" /> }
                    else
                    { <MudProgressCircular Size="Size.Small" Color="Color.Primary" Indeterminate="true" /> }
                    <MudText Typo="Typo.body2" Color="@(_genStep >= 1 ? Color.Default : Color.Primary)">Analyzing requirements...</MudText>
                </div>
                <div class="d-flex align-center gap-3">
                    @if (_genStep >= 2)
                    { <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" /> }
                    else if (_genStep == 1)
                    { <MudProgressCircular Size="Size.Small" Color="Color.Primary" Indeterminate="true" /> }
                    else
                    { <MudIcon Icon="@Icons.Material.Outlined.RadioButtonUnchecked" Color="Color.Default" Size="Size.Small" /> }
                    <MudText Typo="Typo.body2" Color="@(_genStep >= 2 ? Color.Default : _genStep == 1 ? Color.Primary : Color.Secondary)">Designing workflow steps...</MudText>
                </div>
                <div class="d-flex align-center gap-3">
                    @if (_genStep >= 3)
                    { <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" /> }
                    else if (_genStep == 2)
                    { <MudProgressCircular Size="Size.Small" Color="Color.Primary" Indeterminate="true" /> }
                    else
                    { <MudIcon Icon="@Icons.Material.Outlined.RadioButtonUnchecked" Color="Color.Default" Size="Size.Small" /> }
                    <MudText Typo="Typo.body2" Color="@(_genStep >= 3 ? Color.Default : _genStep == 2 ? Color.Primary : Color.Secondary)">Creating workflow...</MudText>
                </div>
            </div>
        }
    </MudPaper>
}

<MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" @bind-ActivePanelIndex="_activeTab"
         Style="border: 1px solid var(--mud-palette-divider); border-radius: 10px;">

    @* Workflows Tab *@
    <MudTabPanel Text="Workflows" Icon="@Icons.Material.Outlined.AccountTree"
                 BadgeData="@(_workflows.Count > 0 ? _workflows.Count.ToString() : null)" BadgeColor="Color.Primary">
        <div class="d-flex justify-space-between align-center pa-4 animate-slide-in flex-wrap gap-2">
            <div class="d-flex align-center gap-3 flex-wrap">
                <MudTextField @bind-Value="_workflowSearch" Placeholder="Search workflows..."
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                              Variant="Variant.Outlined" Margin="Margin.Dense" Style="min-width: 240px; max-width: 300px;"
                              Immediate="true" DebounceInterval="300" />
                <MudSelect T="string" @bind-Value="_statusFilter" Label="Status" Clearable="true"
                           Variant="Variant.Outlined" Margin="Margin.Dense" Style="min-width: 140px; max-width: 160px;">
                    <MudSelectItem T="string" Value="@("All")">All</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Active")">Active</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Draft")">Draft</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Archived")">Archived</MudSelectItem>
                </MudSelect>
                <MudSelect T="string" @bind-Value="_typeFilter" Label="Type" Clearable="true"
                           Variant="Variant.Outlined" Margin="Margin.Dense" Style="min-width: 140px; max-width: 160px;">
                    <MudSelectItem T="string" Value="@("All")">All Types</MudSelectItem>
                    <MudSelectItem T="string" Value="@("sequential")">Sequential</MudSelectItem>
                    <MudSelectItem T="string" Value="@("parallel")">Parallel</MudSelectItem>
                    <MudSelectItem T="string" Value="@("conditional")">Conditional</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Finance")">Finance</MudSelectItem>
                    <MudSelectItem T="string" Value="@("HR")">HR</MudSelectItem>
                </MudSelect>
                <MudToggleIconButton @bind-Toggled="_viewAsList"
                                     Icon="@Icons.Material.Outlined.ViewModule"
                                     ToggledIcon="@Icons.Material.Outlined.ViewList"
                                     Size="Size.Small" aria-label="Toggle view" />
            </div>
            <div class="d-flex gap-2">
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.AutoAwesome"
                           OnClick="@(() => _showGenerator = true)">
                    AI Generate
                </MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreateWorkflowDialog">
                    New Workflow
                </MudButton>
            </div>
        </div>

        @if (_loadingWorkflows)
        {
            <div class="pa-4"><LoadingSkeleton Variant="LoadingSkeleton.SkeletonVariant.Table" /></div>
        }
        else if (_hasError)
        {
            <div class="pa-4">
                <ErrorState ErrorMessage="@_error" OnRetry="LoadWorkflows" />
            </div>
        }
        else if (FilteredWorkflows.Count == 0)
        {
            <EmptyState Icon="@Icons.Material.Outlined.AccountTree"
                        Title="No workflows yet"
                        Description="Create your first workflow manually or use AI to generate one."
                        ActionText="AI Generate"
                        OnAction="@(() => _showGenerator = true)"
                        MinHeight="300px" />
        }
        else if (_viewAsList)
        {
            @* ── List View ── *@
            <div class="pa-4 animate-slide-in">
                <MudDataGrid T="WorkflowDto" Items="FilteredWorkflows" Hover="true" Dense="true" Elevation="0"
                             Style="border: 1px solid var(--mud-palette-divider); border-radius: 12px; overflow: hidden;"
                             RowClick="@((DataGridRowClickEventArgs<WorkflowDto> args) => Navigation.NavigateTo($"/workflow-studio/designer/{args.Item.Id}"))">
                    <Columns>
                        <TemplateColumn Title="Workflow" SortBy="x => x.Name">
                            <CellTemplate>
                                <div class="d-flex align-center gap-2">
                                    <MudIcon Icon="@GetWorkflowTypeIcon(context.Item.Type)" Size="Size.Small"
                                             Color="@GetWorkflowTypeColor(context.Item.Type)" />
                                    <div>
                                        <MudText Typo="Typo.body2" Style="font-weight: 600;">@context.Item.Name</MudText>
                                        @if (!string.IsNullOrEmpty(context.Item.Description))
                                        {
                                            <MudText Typo="Typo.caption" Color="Color.Secondary"
                                                     Style="max-width: 300px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; display: block;">
                                                @context.Item.Description
                                            </MudText>
                                        }
                                    </div>
                                </div>
                            </CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn Title="Status">
                            <CellTemplate>
                                <MudChip T="string" Size="Size.Small" Color="@GetWorkflowStatusColor(context.Item)"
                                         Variant="@(!context.Item.IsActive && !context.Item.IsArchived ? Variant.Outlined : Variant.Filled)">
                                    @GetWorkflowStatusLabel(context.Item)
                                </MudChip>
                            </CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn Title="Type">
                            <CellTemplate>
                                @if (!string.IsNullOrEmpty(context.Item.Type))
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">@context.Item.Type</MudChip>
                                }
                            </CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn Title="Steps">
                            <CellTemplate>
                                <MudText Typo="Typo.body2">@context.Item.StepCount steps</MudText>
                            </CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn Title="Last Run">
                            <CellTemplate>
                                @{ var stats = GetWorkflowStats(context.Item.Id); }
                                @if (stats.LastRun.HasValue)
                                {
                                    <MudTooltip Text="@stats.LastRun.Value.ToString("yyyy-MM-dd HH:mm:ss")">
                                        <MudText Typo="Typo.caption">@FormatRelativeTime(stats.LastRun.Value)</MudText>
                                    </MudTooltip>
                                }
                                else
                                {
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Never</MudText>
                                }
                            </CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn Title="Success Rate">
                            <CellTemplate>
                                @{ var s = GetWorkflowStats(context.Item.Id); }
                                @if (s.TotalRuns > 0)
                                {
                                    <div class="d-flex align-center gap-2">
                                        <MudProgressLinear Value="@s.SuccessRate" Color="@(s.SuccessRate >= 80 ? Color.Success : s.SuccessRate >= 50 ? Color.Warning : Color.Error)"
                                                          Size="Size.Small" Rounded="true" Style="width: 60px; height: 6px;" />
                                        <MudText Typo="Typo.caption">@($"{s.SuccessRate:F0}%")</MudText>
                                    </div>
                                }
                                else
                                {
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">--</MudText>
                                }
                            </CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn Title="" Sortable="false" Filterable="false">
                            <CellTemplate>
                                <div class="d-flex gap-1" @onclick:stopPropagation="true">
                                    @if (!context.Item.IsArchived)
                                    {
                                        <MudIconButton Icon="@Icons.Material.Filled.PlayArrow" Size="Size.Small" Color="Color.Success"
                                                       OnClick="@(() => ExecuteWorkflow(context.Item))" aria-label="Execute" />
                                    }
                                    <MudIconButton Icon="@Icons.Material.Filled.ContentCopy" Size="Size.Small"
                                                   OnClick="@(() => CloneWorkflow(context.Item))" aria-label="Clone" />
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                                   OnClick="@(() => DeleteWorkflow(context.Item))" aria-label="Delete" />
                                </div>
                            </CellTemplate>
                        </TemplateColumn>
                    </Columns>
                </MudDataGrid>
            </div>
        }
        else
        {
            @* ── Card Grid View ── *@
            <MudGrid Class="pa-4 stagger-in" Spacing="3">
                @foreach (var wf in FilteredWorkflows)
                {
                    var wfStats = GetWorkflowStats(wf.Id);
                    <MudItem xs="12" sm="6" md="4">
                        <MudPaper Elevation="0" Class="pa-0 workflow-card" Style="display: flex; flex-direction: column; height: 100%;">
                            @* Card Header with gradient accent *@
                            <div class="wf-card-header" style="@($"border-left: 4px solid {GetWorkflowTypeHex(wf.Type)};")">
                                <div class="d-flex justify-space-between align-center">
                                    <div class="d-flex align-center gap-2" style="min-width: 0; flex: 1;">
                                        <MudIcon Icon="@GetWorkflowTypeIcon(wf.Type)" Size="Size.Small"
                                                 Style="@($"color: {GetWorkflowTypeHex(wf.Type)}; flex-shrink: 0;")" />
                                        <MudText Typo="Typo.subtitle1" Style="font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                                            @wf.Name
                                        </MudText>
                                    </div>
                                    <div class="d-flex align-center gap-1 flex-shrink-0">
                                        <MudChip T="string" Size="Size.Small"
                                                 Color="@GetWorkflowStatusColor(wf)"
                                                 Variant="@(!wf.IsActive && !wf.IsArchived ? Variant.Outlined : Variant.Filled)">
                                            @GetWorkflowStatusLabel(wf)
                                        </MudChip>
                                        <MudMenu Icon="@Icons.Material.Filled.MoreVert" Size="Size.Small" Dense="true"
                                                 AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                                            <MudMenuItem Icon="@Icons.Material.Outlined.ContentCopy" IconColor="Color.Primary"
                                                         OnClick="@(() => CloneWorkflow(wf))">
                                                Clone
                                            </MudMenuItem>
                                            @if (wf.IsArchived)
                                            {
                                                <MudMenuItem Icon="@Icons.Material.Outlined.Restore" IconColor="Color.Primary"
                                                             OnClick="@(() => RestoreWorkflow(wf))">
                                                    Restore
                                                </MudMenuItem>
                                            }
                                            else if (!wf.IsActive)
                                            {
                                                <MudMenuItem Icon="@Icons.Material.Outlined.Publish" IconColor="Color.Success"
                                                             OnClick="@(() => PublishWorkflow(wf))">
                                                    Publish
                                                </MudMenuItem>
                                                <MudMenuItem Icon="@Icons.Material.Outlined.Archive" IconColor="Color.Default"
                                                             OnClick="@(() => ArchiveWorkflow(wf))">
                                                    Archive
                                                </MudMenuItem>
                                            }
                                            else
                                            {
                                                <MudMenuItem Icon="@Icons.Material.Outlined.Unpublished" IconColor="Color.Warning"
                                                             OnClick="@(() => UnpublishWorkflow(wf))">
                                                    Unpublish
                                                </MudMenuItem>
                                                <MudMenuItem Icon="@Icons.Material.Outlined.Archive" IconColor="Color.Default"
                                                             OnClick="@(() => ArchiveWorkflow(wf))">
                                                    Archive
                                                </MudMenuItem>
                                            }
                                            <MudDivider />
                                            <MudMenuItem Icon="@Icons.Material.Outlined.Delete" IconColor="Color.Error"
                                                         OnClick="@(() => DeleteWorkflow(wf))">
                                                Delete
                                            </MudMenuItem>
                                        </MudMenu>
                                    </div>
                                </div>
                            </div>

                            @* Card Body *@
                            <div class="pa-4 pt-0" style="flex: 1; display: flex; flex-direction: column;">
                                @if (!string.IsNullOrEmpty(wf.Description))
                                {
                                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2"
                                             Style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                                        @wf.Description
                                    </MudText>
                                }

                                @* Tags Row *@
                                <div class="d-flex gap-1 flex-wrap mb-3">
                                    @if (!string.IsNullOrEmpty(wf.Type))
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined"
                                                 Style="font-size: 0.65rem; height: 22px;">
                                            @wf.Type
                                        </MudChip>
                                    }
                                    <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined"
                                             Style="font-size: 0.65rem; height: 22px;">
                                        @wf.StepCount step@(wf.StepCount != 1 ? "s" : "")
                                    </MudChip>
                                </div>

                                @* Run Stats Mini Row *@
                                <div class="wf-card-stats">
                                    <div class="d-flex justify-space-between align-center">
                                        <div class="d-flex align-center gap-3">
                                            <MudTooltip Text="Total Runs">
                                                <div class="d-flex align-center gap-1">
                                                    <MudIcon Icon="@Icons.Material.Outlined.PlayCircle" Size="Size.Small" Color="Color.Secondary" />
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary" Style="font-weight: 600;">@wfStats.TotalRuns</MudText>
                                                </div>
                                            </MudTooltip>
                                            @if (wfStats.TotalRuns > 0)
                                            {
                                                <MudTooltip Text="@($"Success: {wfStats.SuccessRate:F0}%")">
                                                    <div class="d-flex align-center gap-1">
                                                        <MudIcon Icon="@Icons.Material.Outlined.CheckCircle" Size="Size.Small"
                                                                 Color="@(wfStats.SuccessRate >= 80 ? Color.Success : wfStats.SuccessRate >= 50 ? Color.Warning : Color.Error)" />
                                                        <MudText Typo="Typo.caption" Style="font-weight: 600;"
                                                                 Color="@(wfStats.SuccessRate >= 80 ? Color.Success : wfStats.SuccessRate >= 50 ? Color.Warning : Color.Error)">
                                                            @($"{wfStats.SuccessRate:F0}%")
                                                        </MudText>
                                                    </div>
                                                </MudTooltip>
                                            }
                                        </div>
                                        @if (wfStats.LastRun.HasValue)
                                        {
                                            <MudTooltip Text="@($"Last run: {wfStats.LastRun.Value:yyyy-MM-dd HH:mm}")">
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                    @FormatRelativeTime(wfStats.LastRun.Value)
                                                </MudText>
                                            </MudTooltip>
                                        }
                                    </div>
                                    @if (wfStats.TotalRuns > 0)
                                    {
                                        <MudProgressLinear Value="@wfStats.SuccessRate"
                                                          Color="@(wfStats.SuccessRate >= 80 ? Color.Success : wfStats.SuccessRate >= 50 ? Color.Warning : Color.Error)"
                                                          Size="Size.Small" Rounded="true" Class="mt-1"
                                                          Style="height: 4px; opacity: 0.6;" />
                                    }
                                </div>

                                @* Action Bar *@
                                <div class="d-flex gap-1 mt-3">
                                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                                               StartIcon="@Icons.Material.Filled.DesignServices"
                                               OnClick="@(() => Navigation.NavigateTo($"/workflow-studio/designer/{wf.Id}"))"
                                               Style="flex: 1;">
                                        Design
                                    </MudButton>
                                    @if (!wf.IsArchived)
                                    {
                                        <MudTooltip Text="Execute">
                                            <MudIconButton Icon="@Icons.Material.Filled.PlayArrow" Size="Size.Small" Color="Color.Success"
                                                           OnClick="@(() => ExecuteWorkflow(wf))" aria-label="Execute"
                                                           Style="border: 1px solid var(--mud-palette-lines-default); border-radius: 6px;" />
                                        </MudTooltip>
                                    }
                                    <MudTooltip Text="Edit">
                                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                                       OnClick="@(() => OpenEditWorkflowDialog(wf))" aria-label="Edit"
                                                       Style="border: 1px solid var(--mud-palette-lines-default); border-radius: 6px;" />
                                    </MudTooltip>
                                </div>
                            </div>
                        </MudPaper>
                    </MudItem>
                }
            </MudGrid>
        }
    </MudTabPanel>

    @* Runs Tab *@
    <MudTabPanel Text="Runs" Icon="@Icons.Material.Outlined.PlaylistPlay"
                 BadgeData="@(_instances.Count(i => i.Status == "Running") > 0 ? _instances.Count(i => i.Status == "Running").ToString() : null)"
                 BadgeColor="Color.Info">
        <div class="pa-4 animate-slide-in">
            @* Runs Filters *@
            <div class="d-flex justify-space-between align-center mb-3 flex-wrap gap-2">
                <div class="d-flex align-center gap-3 flex-wrap">
                    <MudTextField @bind-Value="_runSearch" Placeholder="Search runs..."
                                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" Style="min-width: 200px; max-width: 260px;"
                                  Immediate="true" DebounceInterval="300" />
                    <MudSelect T="string" @bind-Value="_runStatusFilter" Label="Status" Clearable="true"
                               Variant="Variant.Outlined" Margin="Margin.Dense" Style="min-width: 130px; max-width: 150px;">
                        <MudSelectItem T="string" Value="@("All")">All</MudSelectItem>
                        <MudSelectItem T="string" Value="@("Running")">Running</MudSelectItem>
                        <MudSelectItem T="string" Value="@("Completed")">Completed</MudSelectItem>
                        <MudSelectItem T="string" Value="@("Failed")">Failed</MudSelectItem>
                        <MudSelectItem T="string" Value="@("Pending")">Pending</MudSelectItem>
                    </MudSelect>
                </div>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.Refresh" OnClick="LoadInstances">
                    Refresh
                </MudButton>
            </div>

            @* Runs Summary Chips *@
            @if (_instances.Count > 0)
            {
                <div class="d-flex gap-2 mb-3">
                    <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined"
                             OnClick="@(() => _runStatusFilter = "All")">
                        All (@_instances.Count)
                    </MudChip>
                    @if (_instances.Count(i => i.Status == "Running") > 0)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Filled"
                                 OnClick="@(() => _runStatusFilter = "Running")"
                                 Style="animation: pulse-chip 2s ease-in-out infinite;">
                            Running (@_instances.Count(i => i.Status == "Running"))
                        </MudChip>
                    }
                    @if (_instances.Count(i => i.Status == "Completed") > 0)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Outlined"
                                 OnClick="@(() => _runStatusFilter = "Completed")">
                            Completed (@_instances.Count(i => i.Status == "Completed"))
                        </MudChip>
                    }
                    @if (_instances.Count(i => i.Status == "Failed") > 0)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Outlined"
                                 OnClick="@(() => _runStatusFilter = "Failed")">
                            Failed (@_instances.Count(i => i.Status == "Failed"))
                        </MudChip>
                    }
                </div>
            }

            <MudDataGrid T="WorkflowInstanceDto" Items="FilteredInstances" Hover="true" Dense="true"
                         Loading="_loadingInstances" Elevation="0"
                         Style="border: 1px solid var(--mud-palette-divider); border-radius: 12px; overflow: hidden;"
                         RowClick="@((DataGridRowClickEventArgs<WorkflowInstanceDto> args) => Navigation.NavigateTo($"/workflow-studio/runs/{args.Item.Id}"))">
                <Columns>
                    <TemplateColumn Title="Workflow" SortBy="x => x.WorkflowName">
                        <CellTemplate>
                            <div class="d-flex align-center gap-2">
                                <MudIcon Icon="@Icons.Material.Outlined.AccountTree" Size="Size.Small" Color="Color.Secondary" />
                                <MudText Typo="Typo.body2" Style="font-weight: 500;">@context.Item.WorkflowName</MudText>
                            </div>
                        </CellTemplate>
                    </TemplateColumn>
                    <TemplateColumn Title="Status" SortBy="x => x.Status">
                        <CellTemplate>
                            <StatusBadge Status="@context.Item.Status" />
                        </CellTemplate>
                    </TemplateColumn>
                    <TemplateColumn Title="Progress">
                        <CellTemplate>
                            @if (context.Item.TotalSteps > 0)
                            {
                                var pct = context.Item.TotalSteps > 0 ? (double)context.Item.CurrentStep / context.Item.TotalSteps * 100 : 0;
                                <div class="d-flex align-center gap-2">
                                    <MudProgressLinear Value="@pct" Color="@(context.Item.Status == "Failed" ? Color.Error : Color.Primary)"
                                                      Size="Size.Small" Rounded="true" Style="width: 60px; height: 6px;" />
                                    <MudText Typo="Typo.caption">@context.Item.CurrentStep/@context.Item.TotalSteps</MudText>
                                </div>
                            }
                            else
                            {
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Step @context.Item.CurrentStep</MudText>
                            }
                        </CellTemplate>
                    </TemplateColumn>
                    <TemplateColumn Title="Started" SortBy="x => x.StartedAt">
                        <CellTemplate>
                            @if (context.Item.StartedAt.HasValue)
                            {
                                <MudTooltip Text="@context.Item.StartedAt.Value.ToString("yyyy-MM-dd HH:mm:ss")">
                                    <MudText Typo="Typo.body2">@FormatRelativeTime(context.Item.StartedAt.Value)</MudText>
                                </MudTooltip>
                            }
                        </CellTemplate>
                    </TemplateColumn>
                    <TemplateColumn Title="Duration">
                        <CellTemplate>
                            <MudText Typo="Typo.body2">@FormatDuration(context.Item.StartedAt, context.Item.CompletedAt)</MudText>
                        </CellTemplate>
                    </TemplateColumn>
                    <TemplateColumn Title="" Sortable="false" Filterable="false">
                        <CellTemplate>
                            <MudTooltip Text="View Details">
                                <MudIconButton Icon="@Icons.Material.Filled.OpenInNew" Size="Size.Small" Color="Color.Primary"
                                               OnClick="@(() => Navigation.NavigateTo($"/workflow-studio/runs/{context.Item.Id}"))"
                                               aria-label="View Details" />
                            </MudTooltip>
                        </CellTemplate>
                    </TemplateColumn>
                </Columns>
                <NoRecordsContent>
                    <EmptyState Icon="@Icons.Material.Outlined.PlaylistPlay" Title="No workflow runs"
                                Description="Execute a workflow to see runs here." MinHeight="200px" />
                </NoRecordsContent>
            </MudDataGrid>
        </div>
    </MudTabPanel>

    @* Approvals Tab *@
    <MudTabPanel Text="Approvals" Icon="@Icons.Material.Outlined.TaskAlt"
                 BadgeData="@(_pendingApprovals.Count > 0 ? _pendingApprovals.Count.ToString() : null)"
                 BadgeColor="Color.Warning">
        <div class="pa-4 animate-slide-in">
            @if (_loadingApprovals)
            {
                <LoadingSkeleton Variant="LoadingSkeleton.SkeletonVariant.Table" />
            }
            else if (_pendingApprovals.Count == 0)
            {
                <EmptyState Icon="@Icons.Material.Outlined.TaskAlt" Title="No pending approvals"
                            Description="All approvals are processed." MinHeight="200px" />
            }
            else
            {
                <div class="d-flex flex-column gap-3">
                    @foreach (var approval in _pendingApprovals)
                    {
                        var isOverdue = approval.DueAt.HasValue && approval.DueAt < DateTime.UtcNow;
                        <MudPaper Elevation="0" Class="@($"pa-4 inbox-item {(isOverdue ? "inbox-item--urgent" : "inbox-item--normal")}")">
                            <div class="d-flex justify-space-between align-start">
                                <div style="min-width: 0; flex: 1;">
                                    <div class="d-flex align-center gap-2">
                                        <MudText Typo="Typo.subtitle2" Style="font-weight: 600;">@approval.WorkflowName</MudText>
                                        @if (isOverdue)
                                        {
                                            <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Filled"
                                                     Style="font-size: 0.6rem; height: 18px;">
                                                OVERDUE
                                            </MudChip>
                                        }
                                    </div>
                                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-1">
                                        Requested by @approval.RequesterFirstName @approval.RequesterLastName
                                    </MudText>
                                    <div class="d-flex gap-3 mt-1 align-center flex-wrap">
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                                            <MudIcon Icon="@Icons.Material.Outlined.Schedule" Size="Size.Small" Style="font-size: 14px; vertical-align: middle; margin-right: 2px;" />
                                            @FormatRelativeTime(approval.RequestedAt)
                                        </MudText>
                                        @if (approval.DueAt.HasValue)
                                        {
                                            <MudText Typo="Typo.caption" Color="@(isOverdue ? Color.Error : Color.Secondary)">
                                                Due: @approval.DueAt.Value.ToString("MMM dd, HH:mm")
                                            </MudText>
                                        }
                                        @if (approval.EscalationLevel > 0)
                                        {
                                            <MudChip T="string" Color="Color.Warning" Size="Size.Small">
                                                Escalated L@(approval.EscalationLevel)
                                            </MudChip>
                                        }
                                    </div>
                                </div>
                                <div class="d-flex gap-2 flex-shrink-0">
                                    <MudButton Variant="Variant.Filled" Color="Color.Success" Size="Size.Small"
                                               StartIcon="@Icons.Material.Filled.Check"
                                               OnClick="@(() => OpenApprovalAction(approval, true))">
                                        Approve
                                    </MudButton>
                                    <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small"
                                               StartIcon="@Icons.Material.Filled.Close"
                                               OnClick="@(() => OpenApprovalAction(approval, false))">
                                        Reject
                                    </MudButton>
                                </div>
                            </div>
                        </MudPaper>
                    }
                </div>
            }
        </div>
    </MudTabPanel>

    @* Schedules Tab *@
    <MudTabPanel Text="Schedules" Icon="@Icons.Material.Outlined.Schedule">
        <div class="pa-4 animate-slide-in">
            <div class="d-flex justify-space-between align-center mb-3">
                <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">Workflow Triggers</MudText>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.Add" OnClick="AddSchedule">
                    New Schedule
                </MudButton>
            </div>

            @if (_schedules.Count == 0)
            {
                <EmptyState Icon="@Icons.Material.Outlined.Schedule" Title="No schedules configured"
                            Description="Set up automatic triggers to run workflows on a schedule, via webhook, or on events."
                            ActionText="Create Schedule"
                            OnAction="AddSchedule"
                            MinHeight="250px" />
            }
            else
            {
                <div class="d-flex flex-column gap-3">
                    @foreach (var schedule in _schedules)
                    {
                        <MudPaper Elevation="0" Class="pa-4" Style="border: 1px solid var(--mud-palette-divider); border-radius: 10px;">
                            <div class="d-flex justify-space-between align-center">
                                <div class="d-flex align-center gap-3">
                                    <div class="wf-stat-icon @(schedule.IsEnabled ? "wf-stat-icon--success" : "wf-stat-icon--default")">
                                        <MudIcon Icon="@GetTriggerIcon(schedule.TriggerType)" Size="Size.Small" />
                                    </div>
                                    <div>
                                        <div class="d-flex align-center gap-2">
                                            <MudText Typo="Typo.subtitle2" Style="font-weight: 600;">@schedule.WorkflowName</MudText>
                                            <MudChip T="string" Size="Size.Small"
                                                     Color="@(schedule.IsEnabled ? Color.Success : Color.Default)"
                                                     Variant="Variant.Filled" Style="font-size: 0.6rem; height: 20px;">
                                                @(schedule.IsEnabled ? "Active" : "Paused")
                                            </MudChip>
                                        </div>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                                            @GetTriggerDescription(schedule)
                                        </MudText>
                                        @if (schedule.NextRunAt.HasValue)
                                        {
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                Next run: @schedule.NextRunAt.Value.ToString("MMM dd, HH:mm")
                                            </MudText>
                                        }
                                    </div>
                                </div>
                                <div class="d-flex gap-1">
                                    <MudSwitch T="bool" Value="schedule.IsEnabled" Color="Color.Success" Size="Size.Small"
                                               ValueChanged="@(val => ToggleSchedule(schedule, val))" />
                                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                                   OnClick="@(() => EditSchedule(schedule))" aria-label="Edit schedule" />
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                                   OnClick="@(() => DeleteSchedule(schedule))" aria-label="Delete schedule" />
                                </div>
                            </div>
                        </MudPaper>
                    }
                </div>
            }
        </div>
    </MudTabPanel>

    @* Integrations Tab *@
    <MudTabPanel Text="Integrations" Icon="@Icons.Material.Outlined.Extension">
        <div class="pa-4 animate-slide-in">
            <div class="d-flex justify-end mb-3">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreateIntegrationDialog">
                    New Connector
                </MudButton>
            </div>

            <MudDataGrid T="IntegrationDto" Items="_integrations" Hover="true" Dense="true"
                         Loading="_loadingIntegrations" Elevation="0">
                <Columns>
                    <TemplateColumn Title="Name" SortBy="x => x.Name">
                        <CellTemplate>
                            <div class="d-flex align-center gap-2">
                                <MudIcon Icon="@GetIntegrationIcon(context.Item.Type)" Size="Size.Small"
                                         Color="@(context.Item.IsActive ? Color.Primary : Color.Default)" />
                                <MudText Typo="Typo.body2" Style="font-weight: 500;">@context.Item.Name</MudText>
                            </div>
                        </CellTemplate>
                    </TemplateColumn>
                    <TemplateColumn Title="Type">
                        <CellTemplate>
                            <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">
                                @context.Item.Type
                            </MudChip>
                        </CellTemplate>
                    </TemplateColumn>
                    <TemplateColumn Title="Status">
                        <CellTemplate>
                            <MudChip T="string" Size="Size.Small"
                                     Color="@(context.Item.IsActive ? Color.Success : Color.Default)"
                                     Variant="Variant.Filled">
                                @(context.Item.IsActive ? "Connected" : "Inactive")
                            </MudChip>
                        </CellTemplate>
                    </TemplateColumn>
                    <TemplateColumn Title="Actions" Sortable="false" Filterable="false">
                        <CellTemplate>
                            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small" Class="mr-1"
                                       OnClick="@(() => TestIntegration(context.Item))"
                                       StartIcon="@Icons.Material.Filled.ElectricalServices">
                                Test
                            </MudButton>
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                           OnClick="@(() => OpenEditIntegrationDialog(context.Item))" />
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                           OnClick="@(() => DeleteIntegration(context.Item))" />
                        </CellTemplate>
                    </TemplateColumn>
                </Columns>
                <NoRecordsContent>
                    <EmptyState Icon="@Icons.Material.Outlined.Extension" Title="No integrations"
                                Description="Add connectors to integrate with external systems." MinHeight="200px" />
                </NoRecordsContent>
            </MudDataGrid>
        </div>
    </MudTabPanel>
</MudTabs>

@code {
    private int _activeTab;
    private string _workflowSearch = string.Empty;
    private string _statusFilter = "All";
    private string _typeFilter = "All";
    private bool _viewAsList;

    // Runs filters
    private string _runSearch = string.Empty;
    private string _runStatusFilter = "All";

    // Generator
    private bool _showGenerator;
    private string _generatorPrompt = string.Empty;
    private bool _generating;
    private int _genStep;

    // Workflows
    private List<WorkflowDto> _workflows = new();
    private bool _loadingWorkflows = true;
    private bool _hasError;
    private string _error = string.Empty;

    // Runs
    private List<WorkflowInstanceDto> _instances = new();
    private bool _loadingInstances = true;

    // Approvals
    private List<PendingApprovalDto> _pendingApprovals = new();
    private bool _loadingApprovals = true;

    // Integrations
    private List<IntegrationDto> _integrations = new();
    private bool _loadingIntegrations = true;

    // Schedules
    private List<ScheduleDto> _schedules = new();

    private List<WorkflowDto> FilteredWorkflows
    {
        get
        {
            var result = _workflows.AsEnumerable();

            if (!string.IsNullOrWhiteSpace(_workflowSearch))
                result = result.Where(w =>
                    w.Name.Contains(_workflowSearch, StringComparison.OrdinalIgnoreCase) ||
                    (w.Description?.Contains(_workflowSearch, StringComparison.OrdinalIgnoreCase) ?? false));

            if (!string.IsNullOrWhiteSpace(_statusFilter) && _statusFilter != "All")
            {
                result = _statusFilter switch
                {
                    "Active" => result.Where(w => w.IsActive && !w.IsArchived),
                    "Draft" => result.Where(w => !w.IsActive && !w.IsArchived),
                    "Archived" => result.Where(w => w.IsArchived),
                    _ => result
                };
            }

            if (!string.IsNullOrWhiteSpace(_typeFilter) && _typeFilter != "All")
                result = result.Where(w => string.Equals(w.Type, _typeFilter, StringComparison.OrdinalIgnoreCase));

            return result.ToList();
        }
    }

    private List<WorkflowInstanceDto> FilteredInstances
    {
        get
        {
            var result = _instances.AsEnumerable();

            if (!string.IsNullOrWhiteSpace(_runSearch))
                result = result.Where(i => i.WorkflowName.Contains(_runSearch, StringComparison.OrdinalIgnoreCase));

            if (!string.IsNullOrWhiteSpace(_runStatusFilter) && _runStatusFilter != "All")
                result = result.Where(i => string.Equals(i.Status, _runStatusFilter, StringComparison.OrdinalIgnoreCase));

            return result.OrderByDescending(i => i.StartedAt).ToList();
        }
    }

    private record WorkflowStats(int TotalRuns, int SuccessCount, int FailedCount, double SuccessRate, DateTime? LastRun);

    private WorkflowStats GetWorkflowStats(Guid workflowId)
    {
        var runs = _instances.Where(i => i.WorkflowId == workflowId).ToList();
        var total = runs.Count;
        var success = runs.Count(r => r.Status == "Completed");
        var failed = runs.Count(r => r.Status == "Failed");
        var rate = total > 0 ? (double)success / total * 100 : 0;
        var lastRun = runs.OrderByDescending(r => r.StartedAt).FirstOrDefault()?.StartedAt;
        return new WorkflowStats(total, success, failed, rate, lastRun);
    }

    private static string FormatRelativeTime(DateTime dt)
    {
        var diff = DateTime.UtcNow - dt;
        if (diff.TotalSeconds < 60) return "Just now";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours}h ago";
        if (diff.TotalDays < 7) return $"{(int)diff.TotalDays}d ago";
        return dt.ToString("MMM dd");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Task.WhenAll(LoadWorkflows(), LoadInstances(), LoadApprovals(), LoadIntegrations());
            StateHasChanged();
        }
    }

    // --- Generator ---
    private void ApplyTemplate(string type)
    {
        _generatorPrompt = type switch
        {
            "invoice" => "Create an invoice approval workflow. Invoices under ₹50,000 auto-approve. ₹50,000 to ₹5,00,000 require manager approval. Above ₹5,00,000 require manager and finance director approval. Send email notification after each approval.",
            "leave" => "Create a leave request workflow. Employee submits leave request, manager approves or rejects. If approved, HR is notified and calendar is updated. If rejected, employee is notified with reason.",
            "expense" => "Create an expense report workflow. Employee submits expense with receipts. Under ₹10,000 auto-approved. Above ₹10,000 needs manager approval. Finance team processes reimbursement after approval.",
            "onboarding" => "Create an employee onboarding workflow. HR initiates, IT provisions accounts, manager assigns buddy, employee completes training modules. Send welcome email on day 1.",
            _ => _generatorPrompt
        };
    }

    private async Task GenerateWorkflow()
    {
        _generating = true;
        _genStep = 0;
        StateHasChanged();

        await Task.Delay(800);
        _genStep = 1;
        StateHasChanged();

        var prompt = _generatorPrompt.ToLowerInvariant();
        var type = "General";
        if (prompt.Contains("invoice") || prompt.Contains("payment")) type = "Finance";
        else if (prompt.Contains("leave") || prompt.Contains("vacation")) type = "HR";
        else if (prompt.Contains("expense") || prompt.Contains("reimbursement")) type = "Finance";
        else if (prompt.Contains("onboarding") || prompt.Contains("hiring")) type = "HR";

        var name = "AI Generated Workflow";
        if (prompt.Contains("invoice")) name = "Invoice Approval Flow";
        else if (prompt.Contains("leave")) name = "Leave Request Flow";
        else if (prompt.Contains("expense")) name = "Expense Report Flow";
        else if (prompt.Contains("onboarding")) name = "Employee Onboarding Flow";

        var steps = new List<object>();
        if (prompt.Contains("approval") || prompt.Contains("approve"))
        {
            steps.Add(new { Name = "Submit Request", Action = "Action", Order = 0 });
            steps.Add(new { Name = "Manager Review", Action = "Approval", AssignedRole = "Manager", Order = 1 });
            if (prompt.Contains("finance") || prompt.Contains("director"))
                steps.Add(new { Name = "Finance Approval", Action = "Approval", AssignedRole = "Finance", Order = 2 });
            steps.Add(new { Name = "Send Notification", Action = "Email", Order = steps.Count });
        }
        else
        {
            steps.Add(new { Name = "Initiate", Action = "Action", Order = 0 });
            steps.Add(new { Name = "Process", Action = "Action", Order = 1 });
            steps.Add(new { Name = "Complete", Action = "Action", Order = 2 });
        }

        await Task.Delay(600);
        _genStep = 2;
        StateHasChanged();

        try
        {
            var stepsJson = System.Text.Json.JsonSerializer.Serialize(steps);
            var response = await Http.PostAsJsonAsync("/api/v1/workflows", new
            {
                Name = name,
                Description = _generatorPrompt.Length > 300 ? _generatorPrompt[..300] : _generatorPrompt,
                Type = type,
                Steps = stepsJson
            });

            if (response.IsSuccessStatusCode)
            {
                _genStep = 3;
                StateHasChanged();
                await Task.Delay(500);

                Snackbar.Add($"Workflow '{name}' created! Open the designer to customize.", Severity.Success);
                _showGenerator = false;
                _generating = false;
                await LoadWorkflows();
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"Failed: {error}", Severity.Error);
                _generating = false;
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed: {ex.Message}", Severity.Error);
            _generating = false;
        }
        StateHasChanged();
    }

    // --- Workflows ---
    private async Task LoadWorkflows()
    {
        _loadingWorkflows = true;
        _hasError = false;
        try
        {
            var result = await Http.GetFromJsonAsync<ListResult<WorkflowDto>>("/api/v1/workflows");
            _workflows = result?.Items ?? new();
        }
        catch (Exception ex)
        {
            _hasError = true;
            _error = "Unable to load workflows. Please check your connection and try again.";
            Snackbar.Add($"Failed to load workflows: {ex.Message}", Severity.Error);
        }
        finally { _loadingWorkflows = false; }
    }

    private async Task OpenCreateWorkflowDialog()
    {
        var dialog = await Dialog.ShowAsync<CreateEditWorkflowDialog>("New Workflow");
        var result = await dialog.Result;
        if (result?.Canceled == false) await LoadWorkflows();
    }

    private async Task OpenEditWorkflowDialog(WorkflowDto w)
    {
        var parameters = new DialogParameters<CreateEditWorkflowDialog> { { x => x.EditId, w.Id.ToString() } };
        var dialog = await Dialog.ShowAsync<CreateEditWorkflowDialog>("Edit Workflow", parameters);
        var result = await dialog.Result;
        if (result?.Canceled == false) await LoadWorkflows();
    }

    private async Task ExecuteWorkflow(WorkflowDto workflow)
    {
        try
        {
            var response = await Http.PostAsJsonAsync($"/api/v1/workflows/{workflow.Id}/execute", new { });
            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("Workflow started", Severity.Success);
                _activeTab = 1;
                await LoadInstances();
                StateHasChanged();
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"Execute failed: {error}", Severity.Error);
            }
        }
        catch (Exception ex) { Snackbar.Add($"Execute failed: {ex.Message}", Severity.Error); }
    }

    private async Task DeleteWorkflow(WorkflowDto workflow)
    {
        var parameters = new DialogParameters<DeleteConfirmationDialog> { { x => x.ItemName, workflow.Name } };
        var dialog = await Dialog.ShowAsync<DeleteConfirmationDialog>("Confirm Delete", parameters);
        var result = await dialog.Result;
        if (result?.Canceled == true) return;

        try
        {
            await Http.DeleteAsync($"/api/v1/workflows/{workflow.Id}");
            Snackbar.Add("Workflow deleted", Severity.Success);
            await LoadWorkflows();
        }
        catch (Exception ex) { Snackbar.Add($"Delete failed: {ex.Message}", Severity.Error); }
    }

    private async Task PublishWorkflow(WorkflowDto workflow)
    {
        try
        {
            var response = await Http.PostAsync($"/api/v1/workflows/{workflow.Id}/publish", null);
            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add($"'{workflow.Name}' published", Severity.Success);
                await LoadWorkflows();
                StateHasChanged();
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"Publish failed: {error}", Severity.Error);
            }
        }
        catch (Exception ex) { Snackbar.Add($"Publish failed: {ex.Message}", Severity.Error); }
    }

    private async Task UnpublishWorkflow(WorkflowDto workflow)
    {
        try
        {
            var response = await Http.PostAsync($"/api/v1/workflows/{workflow.Id}/unpublish", null);
            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add($"'{workflow.Name}' unpublished", Severity.Success);
                await LoadWorkflows();
                StateHasChanged();
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"Unpublish failed: {error}", Severity.Error);
            }
        }
        catch (Exception ex) { Snackbar.Add($"Unpublish failed: {ex.Message}", Severity.Error); }
    }

    private async Task ArchiveWorkflow(WorkflowDto workflow)
    {
        try
        {
            var response = await Http.PostAsync($"/api/v1/workflows/{workflow.Id}/archive", null);
            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add($"'{workflow.Name}' archived", Severity.Success);
                await LoadWorkflows();
                StateHasChanged();
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
