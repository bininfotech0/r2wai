    private static string GetWorkflowStatusLabel(WorkflowDto wf)
    {
        if (wf.IsArchived) return "Archived";
        return wf.IsActive ? "Active" : "Draft";
    }

    private static Color GetWorkflowStatusColor(WorkflowDto wf)
    {
        if (wf.IsArchived) return Color.Default;
        return wf.IsActive ? Color.Success : Color.Warning;
    }

    // --- Runs ---
    private async Task LoadInstances()
    {
        _loadingInstances = true;
        try
        {
            var result = await Http.GetFromJsonAsync<ListResult<WorkflowInstanceDto>>("/api/v1/operations/workflow-instances?pageSize=50");
            _instances = result?.Items ?? new();
        }
        catch { Snackbar.Add("Failed to load workflow runs.", Severity.Warning); }
        finally { _loadingInstances = false; }
    }

    private static string FormatDuration(DateTime? start, DateTime? end)
    {
        if (start is null) return "—";
        var diff = (end ?? DateTime.UtcNow) - start.Value;
        if (diff.TotalMinutes < 1) return $"{diff.Seconds}s";
        if (diff.TotalHours < 1) return $"{(int)diff.TotalMinutes}m";
        return $"{(int)diff.TotalHours}h {diff.Minutes}m";
    }

