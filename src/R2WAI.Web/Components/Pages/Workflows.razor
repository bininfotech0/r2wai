    private async Task CloneWorkflow(WorkflowDto workflow)
    {
        try
        {
            var sourceWf = await Http.GetFromJsonAsync<WorkflowRawDto>($"/api/v1/workflows/{workflow.Id}");
            if (sourceWf is null) { Snackbar.Add("Failed to read workflow", Severity.Error); return; }

            var response = await Http.PostAsJsonAsync("/api/v1/workflows", new
            {
                Name = $"{sourceWf.Name} (Copy)",
                Description = sourceWf.Description,
                Type = sourceWf.Type,
                Steps = sourceWf.Steps
            });

            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add($"Workflow cloned as '{sourceWf.Name} (Copy)'", Severity.Success);
                await LoadWorkflows();
                StateHasChanged();
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"Clone failed: {error}", Severity.Error);
            }
        }
        catch (Exception ex) { Snackbar.Add($"Clone failed: {ex.Message}", Severity.Error); }
    }

