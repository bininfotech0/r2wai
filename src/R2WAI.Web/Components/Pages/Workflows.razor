    private async Task OpenCreateIntegrationDialog()
    {
        var dialog = await Dialog.ShowAsync<CreateEditIntegrationDialog>("New Connector");
        var result = await dialog.Result;
        if (result?.Canceled == false) await LoadIntegrations();
    }

    private async Task OpenEditIntegrationDialog(IntegrationDto integration)
    {
        var parameters = new DialogParameters<CreateEditIntegrationDialog> { { x => x.EditId, integration.Id.ToString() } };
        var dialog = await Dialog.ShowAsync<CreateEditIntegrationDialog>("Edit Connector", parameters);
        var result = await dialog.Result;
        if (result?.Canceled == false) await LoadIntegrations();
    }

    private async Task TestIntegration(IntegrationDto integration)
    {
        try
        {
            var response = await Http.PostAsync($"/api/v1/integrations/{integration.Id}/test", null);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<TestResult>();
                Snackbar.Add(result?.Success == true ? $"'{integration.Name}' connected!" : $"Failed: {result?.Message}", result?.Success == true ? Severity.Success : Severity.Error);
            }
            else Snackbar.Add("Connection test failed", Severity.Error);
        }
        catch (Exception ex) { Snackbar.Add($"Test failed: {ex.Message}", Severity.Error); }
    }

    private async Task DeleteIntegration(IntegrationDto integration)
    {
        var parameters = new DialogParameters<DeleteConfirmationDialog> { { x => x.ItemName, integration.Name } };
        var dialog = await Dialog.ShowAsync<DeleteConfirmationDialog>("Confirm Delete", parameters);
        var result = await dialog.Result;
        if (result?.Canceled != false) return;

        try
        {
            await Http.DeleteAsync($"/api/v1/integrations/{integration.Id}");
            Snackbar.Add("Integration deleted", Severity.Success);
            await LoadIntegrations();
        }
        catch (Exception ex) { Snackbar.Add($"Delete failed: {ex.Message}", Severity.Error); }
    }

