    // Quick Test
    private async Task HandleTestKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !_testSending) await SendTestMessage();
    }

    private async Task SendTestMessage()
    {
        if (string.IsNullOrWhiteSpace(_testMessage) || _selectedAssistant is null) return;

        var msg = _testMessage;
        _testMessages.Add(new TestChatMessage { IsUser = true, Content = msg });
        _testMessage = string.Empty;
        _testSending = true;
        StateHasChanged();

        try
        {
            var result = await Http.PostAsJsonAsync($"/api/v1/assistants/{_selectedAssistant.Id}/chat",
                new { Message = msg });

            if (result.IsSuccessStatusCode)
            {
                var response = await result.Content.ReadFromJsonAsync<ChatResponse>();
                _testMessages.Add(new TestChatMessage { IsUser = false, Content = response?.Reply ?? "No response" });
            }
            else
            {
                _testMessages.Add(new TestChatMessage
                {
                    IsUser = false,
                    Content = result.StatusCode == System.Net.HttpStatusCode.InternalServerError
                        ? "The AI service is unavailable. Check that an AI provider is configured in Settings > AI Models."
                        : $"Error: {result.StatusCode}"
                });
            }
        }
        catch (Exception ex)
        {
            _testMessages.Add(new TestChatMessage { IsUser = false, Content = $"Error: {ex.Message}" });
        }
        finally { _testSending = false; StateHasChanged(); }
    }

    private void ClearTestChat()
    {
        _testMessages.Clear();
        Snackbar.Add("Test chat cleared", Severity.Info);
    }

