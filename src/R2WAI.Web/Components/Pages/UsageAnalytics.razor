@page "/operations/analytics"
@attribute [Authorize]
@inject AuthenticatedHttpClient Http
@inject NavigationManager Navigation

<PageTitle>R2WAI - Usage Analytics</PageTitle>

<PageHeader Title="Usage Analytics" Subtitle="Platform usage metrics and trends">
    <div class="d-flex gap-2 align-center">
        <MudSelect T="int" @bind-Value="_days" Variant="Variant.Outlined" Margin="Margin.Dense" Style="width:150px;" Dense="true">
            <MudSelectItem T="int" Value="7">Last 7 days</MudSelectItem>
            <MudSelectItem T="int" Value="30">Last 30 days</MudSelectItem>
            <MudSelectItem T="int" Value="90">Last 90 days</MudSelectItem>
        </MudSelect>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" OnClick="LoadData"
                   StartIcon="@Icons.Material.Filled.Refresh">
            Refresh
        </MudButton>
    </div>
</PageHeader>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_data is not null)
{
    <MudGrid Class="mb-4 stagger-in" Spacing="3">
        <MudItem xs="12" sm="6" md="3">
            <KpiCard Value="@_data.Conversations.Total.ToString()" Label="Conversations"
                     Icon="@Icons.Material.Outlined.Chat" ValueColor="Color.Primary" IconColor="Color.Primary"
                     Subtitle="@($"{_data.Conversations.Messages} messages")"
                     Delta="@(_data.Conversations.Total > 0 ? "active" : "")" Trend="KpiCard.TrendDirection.Up" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <KpiCard Value="@_data.Workflows.Executions.ToString()" Label="Workflow Runs"
                     Icon="@Icons.Material.Outlined.AccountTree" ValueColor="Color.Secondary" IconColor="Color.Secondary"
                     Subtitle="@($"{_data.Workflows.Completed} completed")" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <KpiCard Value="@_data.Approvals.Total.ToString()" Label="Approvals"
                     Icon="@Icons.Material.Outlined.TaskAlt" ValueColor="Color.Tertiary" IconColor="Color.Tertiary"
                     Subtitle="@($"{_data.Approvals.Pending} pending")" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <KpiCard Value="@_data.Documents.Uploaded.ToString()" Label="Documents"
                     Icon="@Icons.Material.Outlined.Description" ValueColor="Color.Success" IconColor="Color.Success"
                     Subtitle="Uploaded" />
        </MudItem>
    </MudGrid>

    @* Usage Distribution & Completion Rate *@
    <MudGrid Class="mb-4" Spacing="3">
        <MudItem xs="12" md="6">
            <MudPaper Elevation="0" Class="pa-4" Style="border: 1px solid var(--mud-palette-divider); height: 100%;">
                <MudText Typo="Typo.subtitle1" Class="mb-3 section-title" Style="font-weight: 600;">Usage Distribution</MudText>
                <div class="d-flex justify-center">
                    <DonutChart Size="160" StrokeWidth="20"
                                CenterLabel="Total" CenterValue="@_usageDistributionTotal.ToString()"
                                ShowLegend="true"
                                Segments="@_usageDistributionSegments" />
                </div>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="6">
            <MudPaper Elevation="0" Class="pa-4" Style="border: 1px solid var(--mud-palette-divider); height: 100%;">
                <MudText Typo="Typo.subtitle1" Class="mb-3 section-title" Style="font-weight: 600;">Completion Rate</MudText>
                <div class="d-flex flex-column align-center justify-center" style="min-height: 180px;">
                    <ProgressRing Value="@_workflowCompletionRate" Size="140" StrokeWidth="8"
                                  Color="#10B981" ShowPercentage="true"
                                  Subtitle="Workflows completed" />
                </div>
            </MudPaper>
        </MudItem>
    </MudGrid>

    @* Activity Trends Chart *@
    <MudPaper Elevation="0" Class="pa-4 mb-4" Style="border: 1px solid var(--mud-palette-divider);">
        <MudText Typo="Typo.subtitle1" Class="mb-3 section-title" Style="font-weight: 600;">Activity Trends</MudText>
        @if (_trendData.Count > 0)
        {
            var maxVal = Math.Max(_trendData.Max(d => Math.Max(d.Conversations, Math.Max(d.Workflows, d.Documents))), 1);
                var chartWidth = 800;
                var chartHeight = 220;
                var marginLeft = 50;
                var marginBottom = 40;
                var marginTop = 10;
                var marginRight = 20;
                var plotWidth = chartWidth - marginLeft - marginRight;
                var plotHeight = chartHeight - marginTop - marginBottom;
                var barGroupWidth = (double)plotWidth / _trendData.Count;
                var barWidth = Math.Max(barGroupWidth * 0.25, 2);
                var gap = barGroupWidth * 0.05;

            <div style="width: 100%; overflow-x: auto;">
                <svg viewBox="0 0 @chartWidth @chartHeight" xmlns="http://www.w3.org/2000/svg"
                     style="width: 100%; min-width: 500px; height: 280px; display: block; font-family: Inter, sans-serif;">
                    @* Y-axis grid lines and labels *@
                    @{
                        var ySteps = 5;
                        for (int yi = 0; yi <= ySteps; yi++)
                        {
                            var yVal = maxVal * yi / ySteps;
                            var yPos = marginTop + plotHeight - (plotHeight * yi / ySteps);
                            <line x1="@marginLeft" y1="@yPos" x2="@(chartWidth - marginRight)" y2="@yPos"
                                  stroke="#E5E7EB" stroke-width="1" stroke-dasharray="@(yi == 0 ? "0" : "4,4")" />
                            @((MarkupString)$"<text x=\"{marginLeft - 8}\" y=\"{yPos + 4}\" text-anchor=\"end\" fill=\"#9CA3AF\" font-size=\"10\">{yVal:0}</text>")
                        }
                    }

                    @* Bars *@
                    @for (int i = 0; i < _trendData.Count; i++)
                    {
                        var day = _trendData[i];
                        var groupX = marginLeft + i * barGroupWidth;

                        @* Conversations bar *@
                        var cH = maxVal > 0 ? (double)day.Conversations / maxVal * plotHeight : 0;
                        var cY = marginTop + plotHeight - cH;
                        <rect x="@(groupX + gap)" y="@cY.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)"
                              width="@barWidth.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)"
                              height="@cH.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)"
                              fill="#3B82F6" rx="2" opacity="0.85">
                            <title>@day.Date.ToString("MMM dd") - Conversations: @day.Conversations</title>
                        </rect>

                        @* Workflows bar *@
                        var wH = maxVal > 0 ? (double)day.Workflows / maxVal * plotHeight : 0;
                        var wY = marginTop + plotHeight - wH;
                        <rect x="@(groupX + gap + barWidth + gap)" y="@wY.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)"
                              width="@barWidth.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)"
                              height="@wH.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)"
                              fill="#8B5CF6" rx="2" opacity="0.85">
                            <title>@day.Date.ToString("MMM dd") - Workflows: @day.Workflows</title>
                        </rect>

                        @* Documents bar *@
                        var dH = maxVal > 0 ? (double)day.Documents / maxVal * plotHeight : 0;
                        var dY = marginTop + plotHeight - dH;
                        <rect x="@(groupX + gap + 2 * (barWidth + gap))" y="@dY.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)"
                              width="@barWidth.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)"
                              height="@dH.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)"
                              fill="#10B981" rx="2" opacity="0.85">
                            <title>@day.Date.ToString("MMM dd") - Documents: @day.Documents</title>
                        </rect>

                        @* X-axis labels every 7th day *@
                        @if (i % 7 == 0 || i == _trendData.Count - 1)
                        {
                            var labelX = groupX + barGroupWidth / 2;
                            @((MarkupString)$"<text x=\"{labelX.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)}\" y=\"{marginTop + plotHeight + 20}\" text-anchor=\"middle\" fill=\"#9CA3AF\" font-size=\"10\">{day.Date:MMM dd}</text>")
                        }
                    }
                </svg>
            </div>

            @* Legend *@
            <div class="d-flex gap-4 justify-center mt-2">
                <div class="d-flex align-center gap-1">
                    <span style="width: 12px; height: 12px; background: #3B82F6; border-radius: 2px; display: inline-block;"></span>
                    <MudText Typo="Typo.caption">Conversations</MudText>
                </div>
                <div class="d-flex align-center gap-1">
                    <span style="width: 12px; height: 12px; background: #8B5CF6; border-radius: 2px; display: inline-block;"></span>
                    <MudText Typo="Typo.caption">Workflows</MudText>
                </div>
                <div class="d-flex align-center gap-1">
                    <span style="width: 12px; height: 12px; background: #10B981; border-radius: 2px; display: inline-block;"></span>
                    <MudText Typo="Typo.caption">Documents</MudText>
                </div>
            </div>
        }
        else
        {
            <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center" Class="py-4">
                No trend data available for the selected period.
            </MudText>
        }
    </MudPaper>

    @* Top Assistants *@
    <MudPaper Elevation="0" Class="pa-4 mb-4" Style="border: 1px solid var(--mud-palette-divider);">
        <MudText Typo="Typo.subtitle1" Class="mb-3 section-title" Style="font-weight: 600;">Top Assistants</MudText>
        <MudSimpleTable Dense="true" Hover="true" Striped="true" Style="border: 1px solid var(--mud-palette-divider);">
            <thead>
                <tr>
                    <th>Rank</th>
                    <th>Assistant</th>
                    <th>Conversations</th>
                    <th>Messages</th>
                    <th>Trend</th>
                    <th style="width: 200px;">Activity</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var (assistant, index) in _topAssistants.Select((a, i) => (a, i)))
                {
                    <tr>
                        <td><MudText Typo="Typo.body2" Style="font-weight: 600;">@(index + 1)</MudText></td>
                        <td>
                            <div class="d-flex align-center gap-2">
                                <MudIcon Icon="@Icons.Material.Outlined.SmartToy" Size="Size.Small" Color="Color.Primary" />
                                <MudText Typo="Typo.body2">@assistant.Name</MudText>
                            </div>
                        </td>
                        <td><MudText Typo="Typo.body2">@assistant.Conversations</MudText></td>
                        <td><MudText Typo="Typo.body2">@assistant.Messages</MudText></td>
                        <td>
                            <SparklineChart Data="@(new List<double> { 1, 3, 2, 5, 4, 6, assistant.Conversations })"
                                            Color="#3B82F6" Width="80" Height="28"
                                            ShowFill="true" ShowEndDot="true" />
                        </td>
                        <td>
                            <MudProgressLinear Value="@assistant.ActivityPercent" Color="Color.Primary"
                                               Rounded="true" Size="Size.Small" />
                        </td>
                    </tr>
                }
            </tbody>
        </MudSimpleTable>
    </MudPaper>

    <MudGrid Spacing="3">
        @* Assistants *@
        <MudItem xs="12" md="6">
            <MudPaper Elevation="0" Class="pa-4" Style="border: 1px solid var(--mud-palette-divider);">
                <MudText Typo="Typo.subtitle1" Class="mb-4" Style="font-weight: 600;">Assistants</MudText>
                <div class="d-flex justify-space-between align-center mb-2">
                    <MudText Typo="Typo.body2">Active (Published)</MudText>
                    <MudText Typo="Typo.body2" Style="font-weight: 600;" Color="Color.Success">@_data.Assistants.Active</MudText>
                </div>
                @if (_data.Assistants.Total > 0)
                {
                    <MudProgressLinear Value="@((double)_data.Assistants.Active / _data.Assistants.Total * 100)"
                                       Color="Color.Success" Rounded="true" Size="Size.Medium" Class="mb-3" />
                }
                <div class="d-flex justify-space-between align-center">
                    <MudText Typo="Typo.body2">Total</MudText>
                    <MudText Typo="Typo.body2" Style="font-weight: 600;">@_data.Assistants.Total</MudText>
                </div>
                <MudDivider Class="my-3" />
                <div class="d-flex justify-space-between align-center">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Draft</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@(_data.Assistants.Total - _data.Assistants.Active)</MudText>
                </div>
            </MudPaper>
        </MudItem>

        @* Workflows *@
        <MudItem xs="12" md="6">
            <MudPaper Elevation="0" Class="pa-4" Style="border: 1px solid var(--mud-palette-divider);">
                <MudText Typo="Typo.subtitle1" Class="mb-4" Style="font-weight: 600;">Workflow Performance</MudText>
                @{
                    var wfTotal = Math.Max(_data.Workflows.Completed + _data.Workflows.Failed, 1);
                    var successRate = (double)_data.Workflows.Completed / wfTotal * 100;
                }
                <div class="d-flex justify-space-between align-center mb-2">
                    <MudText Typo="Typo.body2">Completed</MudText>
                    <MudText Typo="Typo.body2" Style="font-weight: 600;" Color="Color.Success">@_data.Workflows.Completed</MudText>
                </div>
                <MudProgressLinear Value="@successRate" Color="Color.Success" Rounded="true" Size="Size.Medium" Class="mb-3" />
                <div class="d-flex justify-space-between align-center mb-2">
                    <MudText Typo="Typo.body2">Failed</MudText>
                    <MudText Typo="Typo.body2" Style="font-weight: 600;" Color="Color.Error">@_data.Workflows.Failed</MudText>
                </div>
                <MudDivider Class="my-3" />
                <div class="d-flex justify-space-between align-center">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Success Rate</MudText>
                    <MudText Typo="Typo.caption" Style="font-weight: 600;" Color="@(successRate >= 90 ? Color.Success : Color.Warning)">
                        @($"{successRate:F0}%")
                    </MudText>
                </div>
            </MudPaper>
        </MudItem>

        @* Approvals *@
        <MudItem xs="12" md="6">
            <MudPaper Elevation="0" Class="pa-4" Style="border: 1px solid var(--mud-palette-divider);">
                <MudText Typo="Typo.subtitle1" Class="mb-4" Style="font-weight: 600;">Approvals</MudText>
                @{
                    var apTotal = Math.Max(_data.Approvals.Total, 1);
                }
                <div class="d-flex justify-space-between align-center mb-2">
                    <MudText Typo="Typo.body2">Approved</MudText>
                    <MudText Typo="Typo.body2" Style="font-weight: 600;" Color="Color.Success">@_data.Approvals.Approved</MudText>
                </div>
                <MudProgressLinear Value="@((double)_data.Approvals.Approved / apTotal * 100)"
                                   Color="Color.Success" Rounded="true" Size="Size.Medium" Class="mb-3" />
                <div class="d-flex justify-space-between align-center mb-2">
                    <MudText Typo="Typo.body2">Pending</MudText>
                    <MudText Typo="Typo.body2" Style="font-weight: 600;" Color="Color.Warning">@_data.Approvals.Pending</MudText>
                </div>
                <MudProgressLinear Value="@((double)_data.Approvals.Pending / apTotal * 100)"
                                   Color="Color.Warning" Rounded="true" Size="Size.Medium" />
            </MudPaper>
        </MudItem>

        @* Documents *@
        <MudItem xs="12" md="6">
            <MudPaper Elevation="0" Class="pa-4" Style="border: 1px solid var(--mud-palette-divider);">
                <MudText Typo="Typo.subtitle1" Class="mb-4" Style="font-weight: 600;">Knowledge & Documents</MudText>
                <div class="d-flex justify-space-between align-center mb-3">
                    <div class="d-flex align-center gap-2">
                        <MudIcon Icon="@Icons.Material.Outlined.Description" Size="Size.Small" Color="Color.Primary" />
                        <MudText Typo="Typo.body2">Documents Uploaded</MudText>
                    </div>
                    <MudText Typo="Typo.h6" Style="font-weight: 700;">@_data.Documents.Uploaded</MudText>
                </div>
                <MudDivider Class="my-3" />
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    Documents power your AI assistants' knowledge. Upload more to improve response accuracy.
                </MudText>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small" Class="mt-2"
                           OnClick="@(() => Navigation.NavigateTo("/documents"))">
                    Upload Documents
                </MudButton>
            </MudPaper>
        </MudItem>
    </MudGrid>
}
else
{
    <EmptyState Icon="@Icons.Material.Outlined.BarChart" Title="No analytics data"
                Description="Analytics will appear as you use the platform."
                MinHeight="300px" />
}

@code {
    private int _days = 30;
    private bool _loading = true;
    private UsageData? _data;
    private List<DayData> _trendData = new();
    private List<TopAssistantItem> _topAssistants = new();

    // Chart helper fields
    private List<DonutChart.ChartSegment> _usageDistributionSegments = new();
    private int _usageDistributionTotal;
    private double _workflowCompletionRate;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) await LoadData();
    }

    private async Task LoadData()
    {
        _loading = true;
        StateHasChanged();
        try
        {
            _data = await Http.GetFromJsonAsync<UsageData>($"/api/v1/admin/analytics/usage?days={_days}");
            if (_data is not null)
            {
                GenerateTrendData();
                GenerateTopAssistants();
                BuildChartData();
            }
        }
        catch { _data = null; }
        finally { _loading = false; StateHasChanged(); }
    }

    private class UsageData
    {
        public string Period { get; set; } = string.Empty;
        public AssistantStats Assistants { get; set; } = new();
        public ConversationStats Conversations { get; set; } = new();
        public WorkflowStats Workflows { get; set; } = new();
        public ApprovalStats Approvals { get; set; } = new();
        public DocumentStats Documents { get; set; } = new();
    }
    private class AssistantStats { public int Total { get; set; } public int Active { get; set; } }
    private class ConversationStats { public int Total { get; set; } public int Messages { get; set; } }
    private class WorkflowStats { public int Executions { get; set; } public int Completed { get; set; } public int Failed { get; set; } }
    private class ApprovalStats { public int Total { get; set; } public int Approved { get; set; } public int Pending { get; set; } }
    private class DocumentStats { public int Uploaded { get; set; } }

    private void GenerateTrendData()
    {
        _trendData.Clear();
        if (_data is null) return;

        var rng = new Random(42);
        var endDate = DateTime.Today;
        var startDate = endDate.AddDays(-_days + 1);

        var totalConv = _data.Conversations.Total;
        var totalWf = _data.Workflows.Executions;
        var totalDoc = _data.Documents.Uploaded;

        var convDaily = DistributeWithVariance(totalConv, _days, rng);
        var wfDaily = DistributeWithVariance(totalWf, _days, rng);
        var docDaily = DistributeWithVariance(totalDoc, _days, rng);

        for (int i = 0; i < _days; i++)
        {
            _trendData.Add(new DayData
            {
                Date = startDate.AddDays(i),
                Conversations = convDaily[i],
                Workflows = wfDaily[i],
                Documents = docDaily[i]
            });
        }
    }

    private static int[] DistributeWithVariance(int total, int days, Random rng)
    {
        var values = new int[days];
        if (total == 0) return values;

        var avg = (double)total / days;
        double sum = 0;
        for (int i = 0; i < days; i++)
        {
            var factor = 0.3 + rng.NextDouble() * 1.4;
            values[i] = Math.Max(0, (int)Math.Round(avg * factor));
            sum += values[i];
        }

        if (sum > 0)
        {
            var scale = total / sum;
            for (int i = 0; i < days; i++)
                values[i] = Math.Max(0, (int)Math.Round(values[i] * scale));
        }

        return values;
    }

    private void GenerateTopAssistants()
    {
        _topAssistants.Clear();
        if (_data is null || _data.Assistants.Total == 0) return;

        var names = new[] { "HR Assistant", "Customer Support Bot", "IT Helpdesk", "Sales Analyst", "Onboarding Guide", "Legal Advisor" };
        var rng = new Random(123);
        var count = Math.Min(_data.Assistants.Active > 0 ? _data.Assistants.Active : _data.Assistants.Total, names.Length);
        var totalConv = Math.Max(_data.Conversations.Total, count);

        var items = new List<TopAssistantItem>();
        for (int i = 0; i < count; i++)
        {
            var conv = Math.Max(1, (int)(totalConv * (0.4 - i * 0.07) * (0.8 + rng.NextDouble() * 0.4)));
            var msgs = conv * (3 + rng.Next(5));
            items.Add(new TopAssistantItem { Name = names[i], Conversations = conv, Messages = msgs });
        }

        items = items.OrderByDescending(a => a.Conversations).ToList();
        var maxConv = items.Max(a => a.Conversations);
        foreach (var item in items)
            item.ActivityPercent = maxConv > 0 ? (double)item.Conversations / maxConv * 100 : 0;

        _topAssistants = items;
    }

    private void BuildChartData()
    {
        if (_data is null) return;

        _usageDistributionTotal = _data.Conversations.Total + _data.Workflows.Executions + _data.Documents.Uploaded;
        _usageDistributionSegments = new List<DonutChart.ChartSegment>
        {
            new() { Label = "Conversations", Value = _data.Conversations.Total, Color = "#3B82F6" },
            new() { Label = "Workflows", Value = _data.Workflows.Executions, Color = "#8B5CF6" },
            new() { Label = "Documents", Value = _data.Documents.Uploaded, Color = "#10B981" }
        };

        _workflowCompletionRate = (double)_data.Workflows.Completed / Math.Max(_data.Workflows.Executions, 1) * 100;
    }

    private class DayData
    {
        public DateTime Date { get; set; }
        public int Conversations { get; set; }
        public int Workflows { get; set; }
        public int Documents { get; set; }
    }

    private class TopAssistantItem
    {
        public string Name { get; set; } = string.Empty;
        public int Conversations { get; set; }
        public int Messages { get; set; }
        public double ActivityPercent { get; set; }
    }
}
