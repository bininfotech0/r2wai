@page "/admin/models"
@page "/settings/models"
@attribute [Authorize]
@inject AuthenticatedHttpClient Http
@inject ISnackbar Snackbar
@inject IDialogService Dialog

<PageTitle>R2WAI - AI Models</PageTitle>

<PageHeader Title="AI Models" Subtitle="Configure and monitor AI model providers">
    <MudButton Variant="Variant.Outlined" Size="Size.Small" Color="Color.Default"
               StartIcon="@Icons.Material.Outlined.NetworkCheck" OnClick="TestAllModels"
               Disabled="_testingAll" Class="mr-2">
        @if (_testingAll)
        {
            <MudProgressCircular Size="Size.Small" Indeterminate="true" Style="width:14px;height:14px;" Class="me-1" />
            <span>Testing All...</span>
        }
        else
        {
            <span>Test All</span>
        }
    </MudButton>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" Class="btn-gradient"
               StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreateModelDialog">
        Add Model
    </MudButton>
</PageHeader>

@* KPI Summary Cards *@
<MudGrid Class="mb-4" Spacing="3">
    <MudItem xs="12" sm="6" md="3">
        <KpiCard Value="@_models.Count.ToString()" Label="Total Models"
                 Icon="@Icons.Material.Outlined.ModelTraining" ValueColor="Color.Primary" IconColor="Color.Primary"
                 Subtitle="Configured" />
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <KpiCard Value="@_models.Select(m => m.Provider).Distinct().Count().ToString()" Label="Providers"
                 Icon="@Icons.Material.Outlined.Hub" ValueColor="Color.Secondary" IconColor="Color.Secondary"
                 Subtitle="@string.Join(", ", _models.Select(m => m.Provider).Distinct().Take(3))" />
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <KpiCard Value="@_models.Count(m => m.HasApiKey).ToString()" Label="Keys Configured"
                 Icon="@Icons.Material.Outlined.VpnKey" ValueColor="Color.Tertiary" IconColor="Color.Tertiary"
                 Subtitle="@($"{_models.Count(m => !m.HasApiKey && m.Provider != "Ollama")} missing")" />
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <KpiCard Value="@(_models.FirstOrDefault(m => m.IsDefault)?.Name ?? "None")" Label="Default Model"
                 Icon="@Icons.Material.Outlined.Star" ValueColor="Color.Warning" IconColor="Color.Warning"
                 Subtitle="Used when no model is specified" />
    </MudItem>
</MudGrid>

@* Search & Filter Bar *@
<MudPaper Elevation="0" Class="pa-3 mb-4" Style="border: 1px solid var(--mud-palette-divider); border-radius: 12px;">
    <div class="d-flex align-center gap-3 flex-wrap">
        <MudTextField @bind-Value="_searchText" Placeholder="Search models..." Variant="Variant.Outlined"
                      Margin="Margin.Dense" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                      Immediate="true" Style="max-width: 300px;" />
        <MudChipSet T="string" @bind-SelectedValue="_selectedProvider" SelectionMode="SelectionMode.SingleSelection"
                    CheckMark="false" Variant="Variant.Text" Color="Color.Primary">
            <MudChip T="string" Value="@("All")" Default="true">All</MudChip>
            @foreach (var provider in _models.Select(m => m.Provider).Distinct().OrderBy(p => p))
            {
                <MudChip T="string" Value="@provider">
                    <MudIcon Icon="@GetProviderIcon(provider)" Size="Size.Small" Class="me-1" />
                    @provider
                </MudChip>
            }
        </MudChipSet>
        <MudSpacer />
        <MudToggleIconButton @bind-Toggled="_showGridView"
                             Icon="@Icons.Material.Outlined.ViewList" ToggledIcon="@Icons.Material.Outlined.GridView"
                             Size="Size.Small" Color="Color.Default" ToggledColor="Color.Primary"
                             Title="Toggle view" />
    </div>
</MudPaper>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (FilteredModels.Count == 0 && _models.Count > 0)
{
    <EmptyState Icon="@Icons.Material.Outlined.SearchOff"
                Title="No models match your filter"
                Description="Try a different search term or provider filter."
                MinHeight="200px" />
}
else if (_models.Count == 0)
{
    <EmptyState Icon="@Icons.Material.Outlined.ModelTraining"
                Title="No AI models configured"
                Description="Add AI models to power your assistants, chatbots, and workflows."
                ActionText="Add Model"
                OnAction="OpenCreateModelDialog"
                MinHeight="300px" />
}
else if (_showGridView)
{
    @* Grid View *@
    <MudGrid Spacing="3" Class="stagger-in">
        @foreach (var model in FilteredModels)
        {
            <MudItem xs="12" sm="6" md="4">
                <MudPaper Elevation="0" Class="pa-0" Style="border: 1px solid var(--mud-palette-divider); border-radius: 12px; height: 100%; overflow: hidden;">
                    @* Provider Color Bar *@
                    <div style="height: 3px; background: @GetProviderColor(model.Provider);"></div>
                    <div class="pa-4">
                        @* Header *@
                        <div class="d-flex justify-space-between align-center mb-3">
                            <div class="d-flex align-center gap-2">
                                <MudAvatar Size="Size.Small" Style="@($"background: {GetProviderColor(model.Provider)}20; color: {GetProviderColor(model.Provider)};")">
                                    <MudIcon Icon="@GetProviderIcon(model.Provider)" Size="Size.Small" />
                                </MudAvatar>
                                <div>
                                    <MudText Typo="Typo.subtitle1" Style="font-weight: 600; line-height: 1.2;">@model.Name</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@model.Provider</MudText>
                                </div>
                            </div>
                            <div class="d-flex align-center gap-1">
                                @if (model.IsDefault)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled">Default</MudChip>
                                }
                            </div>
                        </div>

                        @* Details *@
                        <div class="d-flex flex-column gap-1 mb-3">
                            <div class="d-flex justify-space-between align-center">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Model ID</MudText>
                                <MudText Typo="Typo.body2" Style="font-weight: 500; font-family: 'Cascadia Code', 'Fira Code', monospace; font-size: 0.775rem;">@model.ModelId</MudText>
                            </div>
                            <div class="d-flex justify-space-between align-center">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Max Tokens</MudText>
                                <MudText Typo="Typo.body2" Style="font-weight: 500;">@(model.MaxTokens?.ToString("N0") ?? "—")</MudText>
                            </div>
                            @if (model.Temperature.HasValue)
                            {
                                <div class="d-flex justify-space-between align-center">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Temperature</MudText>
                                    <MudText Typo="Typo.body2" Style="font-weight: 500;">@model.Temperature.Value.ToString("F1")</MudText>
                                </div>
                            }
                            <div class="d-flex justify-space-between align-center">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Endpoint</MudText>
                                <MudText Typo="Typo.body2" Style="font-weight: 500; font-size: 0.75rem; max-width: 180px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;"
                                         title="@(model.Endpoint ?? "Default")">
                                    @(string.IsNullOrEmpty(model.Endpoint) ? "Default" : model.Endpoint)
                                </MudText>
                            </div>
                        </div>

                        @* Status Indicators *@
                        <div class="d-flex gap-2 mb-3">
                            @* API Key Status *@
                            <MudTooltip Text="@(model.HasApiKey ? "API key configured" : model.Provider == "Ollama" ? "No key required" : "No API key — click Configure to add one")">
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                                         Color="@(model.HasApiKey ? Color.Success : model.Provider == "Ollama" ? Color.Default : Color.Warning)"
                                         Style="font-size: 0.6875rem;">
                                    <MudIcon Icon="@(model.HasApiKey ? Icons.Material.Filled.VpnKey : Icons.Material.Outlined.VpnKeyOff)" Size="Size.Small" Class="me-1" />
                                    @(model.HasApiKey ? "Key Set" : model.Provider == "Ollama" ? "Local" : "No Key")
                                </MudChip>
                            </MudTooltip>
                            @* Connection Status *@
                            @{
                                var testState = GetTestState(model.Id);
                            }
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                                     Color="@(testState == "success" ? Color.Success : testState == "failed" ? Color.Error : Color.Default)"
                                     Style="font-size: 0.6875rem;">
                                @if (testState == "success")
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Color="Color.Success" Class="me-1" />
                                    <span>Connected</span>
                                }
                                else if (testState == "failed")
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.Cancel" Size="Size.Small" Color="Color.Error" Class="me-1" />
                                    <span>Failed</span>
                                }
                                else if (testState == "testing")
                                {
                                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Style="width:12px;height:12px;" Class="me-1" />
                                    <span>Testing</span>
                                }
                                else
                                {
                                    <MudIcon Icon="@Icons.Material.Outlined.HelpOutline" Size="Size.Small" Class="me-1" />
                                    <span>Untested</span>
                                }
                            </MudChip>
                        </div>

                        @* Error message *@
                        @{
                            var errorMsg = GetTestError(model.Id);
                        }
                        @if (!string.IsNullOrEmpty(errorMsg))
                        {
                            <MudAlert Severity="Severity.Error" Dense="true" Class="mb-3" Style="font-size: 0.75rem;">
                                @errorMsg
                            </MudAlert>
                        }

                        @* Actions *@
                        <div class="d-flex gap-2">
                            <MudButton Variant="Variant.Outlined" Size="Size.Small" Color="Color.Primary" FullWidth="true"
                                       StartIcon="@Icons.Material.Outlined.Settings"
                                       OnClick="@(() => OpenEditModelDialog(model))">
                                Configure
                            </MudButton>
                            <MudButton Variant="Variant.Outlined" Size="Size.Small"
                                       Color="@(testState == "success" ? Color.Success : testState == "failed" ? Color.Error : Color.Default)"
                                       OnClick="@(() => TestModel(model))"
                                       Disabled="@(testState == "testing")"
                                       Style="min-width: 85px;">
                                @if (testState == "testing")
                                {
                                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Style="width:14px;height:14px;" Class="me-1" />
                                    <span>Test</span>
                                }
                                else
                                {
                                    <MudIcon Icon="@Icons.Material.Outlined.NetworkCheck" Size="Size.Small" Class="me-1" />
                                    <span>Test</span>
                                }
                            </MudButton>
                            <MudMenu Icon="@Icons.Material.Filled.MoreVert" Size="Size.Small" Dense="true" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                                @if (!model.IsDefault)
                                {
                                    <MudMenuItem Icon="@Icons.Material.Outlined.Star" OnClick="@(() => SetAsDefault(model))">Set as Default</MudMenuItem>
                                }
                                <MudMenuItem Icon="@Icons.Material.Outlined.VpnKey" OnClick="@(() => OpenSetApiKeyDialog(model))">
                                    @(model.HasApiKey ? "Update API Key" : "Set API Key")
                                </MudMenuItem>
                                <MudMenuItem Icon="@Icons.Material.Filled.Delete" IconColor="Color.Error" OnClick="@(() => DeleteModel(model))" Style="color: var(--mud-palette-error);">
                                    Delete
                                </MudMenuItem>
                            </MudMenu>
                        </div>
                    </div>
                </MudPaper>
            </MudItem>
        }
    </MudGrid>
}
else
{
    @* Table View *@
    <MudPaper Elevation="0" Style="border: 1px solid var(--mud-palette-divider); border-radius: 12px; overflow: hidden;">
        <MudTable Items="FilteredModels" Hover="true" Dense="true" Breakpoint="Breakpoint.None"
                  Style="table-layout: fixed;">
            <HeaderContent>
                <MudTh Style="width: 220px;">Model</MudTh>
                <MudTh Style="width: 120px;">Provider</MudTh>
                <MudTh Style="width: 160px;">Model ID</MudTh>
                <MudTh Style="width: 180px;">Endpoint</MudTh>
                <MudTh Style="width: 90px;">Max Tokens</MudTh>
                <MudTh Style="width: 80px;">API Key</MudTh>
                <MudTh Style="width: 100px;">Status</MudTh>
                <MudTh Style="width: 180px; text-align: right;">Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>
                    <div class="d-flex align-center gap-2">
                        <MudAvatar Size="Size.Small" Style="@($"background: {GetProviderColor(context.Provider)}20; color: {GetProviderColor(context.Provider)}; width: 28px; height: 28px;")">
                            <MudIcon Icon="@GetProviderIcon(context.Provider)" Style="font-size: 0.875rem;" />
                        </MudAvatar>
                        <div>
                            <MudText Typo="Typo.body2" Style="font-weight: 600;">@context.Name</MudText>
                            @if (context.IsDefault)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Text" Style="font-size: 0.625rem; height: 18px;">Default</MudChip>
                            }
                        </div>
                    </div>
                </MudTd>
                <MudTd>
                    <MudText Typo="Typo.body2">@context.Provider</MudText>
                </MudTd>
                <MudTd>
                    <MudText Typo="Typo.body2" Style="font-family: monospace; font-size: 0.775rem;">@context.ModelId</MudText>
                </MudTd>
                <MudTd>
                    <MudText Typo="Typo.body2" Style="font-size: 0.75rem; max-width: 180px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;"
                             title="@(context.Endpoint ?? "Default")">
                        @(string.IsNullOrEmpty(context.Endpoint) ? "Default" : context.Endpoint)
                    </MudText>
                </MudTd>
                <MudTd>
                    <MudText Typo="Typo.body2">@(context.MaxTokens?.ToString("N0") ?? "—")</MudText>
                </MudTd>
                <MudTd>
                    @if (context.HasApiKey)
                    {
                        <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Color="Color.Success" />
                    }
                    else if (context.Provider == "Ollama")
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary">N/A</MudText>
                    }
                    else
                    {
                        <MudIcon Icon="@Icons.Material.Filled.Warning" Size="Size.Small" Color="Color.Warning" />
                    }
                </MudTd>
                <MudTd>
                    @if (GetTestState(context.Id) == "success")
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Text" Style="font-size: 0.6875rem;">Connected</MudChip>
                    }
                    else if (GetTestState(context.Id) == "failed")
                    {
                        <MudTooltip Text="@GetTestError(context.Id)">
                            <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Text" Style="font-size: 0.6875rem;">Failed</MudChip>
                        </MudTooltip>
                    }
                    else if (GetTestState(context.Id) == "testing")
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Style="width:14px;height:14px;" />
                    }
                    else
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary">—</MudText>
                    }
                </MudTd>
                <MudTd Style="text-align: right;">
                    <MudButtonGroup Size="Size.Small" Variant="Variant.Outlined">
                        <MudButton Size="Size.Small" OnClick="@(() => OpenEditModelDialog(context))">Configure</MudButton>
                        <MudButton Size="Size.Small" OnClick="@(() => TestModel(context))" Disabled="@(GetTestState(context.Id) == "testing")">Test</MudButton>
                        <MudMenu Icon="@Icons.Material.Filled.MoreVert" Size="Size.Small" Dense="true" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                            @if (!context.IsDefault)
                            {
                                <MudMenuItem Icon="@Icons.Material.Outlined.Star" OnClick="@(() => SetAsDefault(context))">Set as Default</MudMenuItem>
                            }
                            <MudMenuItem Icon="@Icons.Material.Outlined.VpnKey" OnClick="@(() => OpenSetApiKeyDialog(context))">
                                @(context.HasApiKey ? "Update API Key" : "Set API Key")
                            </MudMenuItem>
                            <MudMenuItem Icon="@Icons.Material.Filled.Delete" IconColor="Color.Error" OnClick="@(() => DeleteModel(context))" Style="color: var(--mud-palette-error);">Delete</MudMenuItem>
                        </MudMenu>
                    </MudButtonGroup>
                </MudTd>
            </RowTemplate>
        </MudTable>
    </MudPaper>
}

@code {
    private List<ModelDto> _models = new();
    private bool _loading = true;
    private bool _testingAll;
    private bool _showGridView = true;
    private string _searchText = string.Empty;
    private string _selectedProvider = "All";
    private Dictionary<Guid, string> _testStates = new();
    private Dictionary<Guid, string> _testErrors = new();

    private List<ModelDto> FilteredModels => _models
        .Where(m => string.IsNullOrEmpty(_searchText) ||
                    m.Name.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ||
                    m.ModelId.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ||
                    m.Provider.Contains(_searchText, StringComparison.OrdinalIgnoreCase))
        .Where(m => _selectedProvider == "All" || m.Provider == _selectedProvider)
        .ToList();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) await LoadData();
    }

    private async Task LoadData()
    {
        _loading = true;
        StateHasChanged();
        try
        {
            var result = await Http.GetFromJsonAsync<ModelsResult>("/api/v1/admin/models");
            _models = result?.Items ?? new();
        }
        catch { Snackbar.Add("Failed to load models", Severity.Warning); }
        finally { _loading = false; StateHasChanged(); }
    }

    private async Task OpenCreateModelDialog()
    {
        var dialog = await Dialog.ShowAsync<CreateEditModelDialog>("Add AI Model", new DialogOptions
        {
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            CloseOnEscapeKey = true
        });
        var result = await dialog.Result;
        if (result?.Canceled == false) await LoadData();
    }

    private async Task OpenEditModelDialog(ModelDto model)
    {
        var parameters = new DialogParameters<CreateEditModelDialog> { { x => x.EditId, model.Id.ToString() } };
        var dialog = await Dialog.ShowAsync<CreateEditModelDialog>("Edit Model", parameters, new DialogOptions
        {
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            CloseOnEscapeKey = true
        });
        var result = await dialog.Result;
        if (result?.Canceled == false) await LoadData();
    }

    private async Task OpenSetApiKeyDialog(ModelDto model)
    {
        var parameters = new DialogParameters<SetApiKeyDialog> { { x => x.ModelId, model.Id }, { x => x.ModelName, model.Name } };
        var dialog = await Dialog.ShowAsync<SetApiKeyDialog>("Set API Key", parameters, new DialogOptions
        {
            MaxWidth = MaxWidth.ExtraSmall,
            FullWidth = true,
            CloseOnEscapeKey = true
        });
        var result = await dialog.Result;
        if (result?.Canceled == false) await LoadData();
    }

    private string GetTestState(Guid modelId) =>
        _testStates.TryGetValue(modelId, out var state) ? state : "idle";

    private string GetTestError(Guid modelId) =>
        _testErrors.TryGetValue(modelId, out var error) ? error : string.Empty;

    private async Task TestModel(ModelDto model)
    {
        _testStates[model.Id] = "testing";
        _testErrors.Remove(model.Id);
        StateHasChanged();

        try
        {
            var response = await Http.PostAsync($"/api/v1/admin/models/{model.Id}/test", null);
            var json = await response.Content.ReadFromJsonAsync<TestResult>();

            if (json?.Success == true)
            {
                _testStates[model.Id] = "success";
                Snackbar.Add($"{model.Name}: Connection successful", Severity.Success);
            }
            else
            {
                _testStates[model.Id] = "failed";
                _testErrors[model.Id] = json?.Message ?? "Unknown error";
                Snackbar.Add($"{model.Name}: {json?.Message ?? "Test failed"}", Severity.Error);
            }
            StateHasChanged();

            _ = Task.Run(async () =>
            {
                await Task.Delay(8000);
                await InvokeAsync(() =>
                {
                    if (_testStates.TryGetValue(model.Id, out var s) && s == "success")
                    {
                        _testStates.Remove(model.Id);
                        StateHasChanged();
                    }
                });
            });
        }
        catch (Exception ex)
        {
            _testStates[model.Id] = "failed";
            _testErrors[model.Id] = ex.Message;
            Snackbar.Add($"{model.Name}: Connection test failed", Severity.Error);
            StateHasChanged();
        }
    }

    private async Task TestAllModels()
    {
        _testingAll = true;
        StateHasChanged();

        var tasks = _models.Select(TestModel);
        await Task.WhenAll(tasks);

        _testingAll = false;
        StateHasChanged();

        var passed = _testStates.Count(s => s.Value == "success");
        var failed = _testStates.Count(s => s.Value == "failed");
        Snackbar.Add($"Test complete: {passed} passed, {failed} failed", failed > 0 ? Severity.Warning : Severity.Success);
    }

    private async Task SetAsDefault(ModelDto model)
    {
        try
        {
            var payload = new
            {
                model.Name,
                model.Provider,
                model.ModelId,
                model.Endpoint,
                model.MaxTokens,
                model.Temperature,
                IsDefault = true
            };
            await Http.PutAsJsonAsync($"/api/v1/admin/models/{model.Id}", payload);
            Snackbar.Add($"{model.Name} set as default model", Severity.Success);
            await LoadData();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to set default: {ex.Message}", Severity.Error);
        }
    }

    private async Task DeleteModel(ModelDto model)
    {
        var parameters = new DialogParameters<DeleteConfirmationDialog>
        {
            { x => x.ItemName, model.Name },
            { x => x.Description, "Assistants using this model will need reconfiguration. This cannot be undone." }
        };
        var dialog = await Dialog.ShowAsync<DeleteConfirmationDialog>("Confirm Delete", parameters);
        var result = await dialog.Result;
        if (result?.Canceled != false) return;

        try
        {
            await Http.DeleteAsync($"/api/v1/admin/models/{model.Id}");
            Snackbar.Add("Model deleted", Severity.Success);
            await LoadData();
        }
        catch (Exception ex) { Snackbar.Add($"Delete failed: {ex.Message}", Severity.Error); }
    }

    private static string GetProviderIcon(string provider) => provider switch
    {
        "OpenAI" => Icons.Material.Outlined.AutoAwesome,
        "AzureOpenAI" => Icons.Material.Outlined.Cloud,
        "Ollama" => Icons.Material.Outlined.Memory,
        "Anthropic" => Icons.Material.Outlined.Psychology,
        "Google" => Icons.Material.Outlined.TravelExplore,
        "Mistral" => Icons.Material.Outlined.Air,
        "Cohere" => Icons.Material.Outlined.Waves,
        "AI21Labs" => Icons.Material.Outlined.Science,
        "Cerebras" => Icons.Material.Outlined.Dns,
        "DeepSeek" => Icons.Material.Outlined.Explore,
        "FireworksAI" => Icons.Material.Outlined.Flare,
        "GitHubModels" => Icons.Material.Outlined.Code,
        "Groq" => Icons.Material.Outlined.Bolt,
        "HuggingFace" => Icons.Material.Outlined.EmojiEmotions,
        "NovitaAI" => Icons.Material.Outlined.Rocket,
        "OpenRouter" => Icons.Material.Outlined.AccountTree,
        "Perplexity" => Icons.Material.Outlined.Search,
        "Replicate" => Icons.Material.Outlined.Loop,
        "SambaNova" => Icons.Material.Outlined.Hub,
        "TogetherAI" => Icons.Material.Outlined.Groups,
        "xAI" => Icons.Material.Outlined.BrightnessHigh,
        _ => Icons.Material.Outlined.SmartToy
    };

    private static string GetProviderColor(string provider) => provider switch
    {
        "OpenAI" => "#10a37f",
        "AzureOpenAI" => "#0078d4",
        "Ollama" => "#1a1a2e",
        "Anthropic" => "#d4a574",
        "Google" => "#4285f4",
        "Mistral" => "#ff7000",
        "Cohere" => "#39594d",
        "AI21Labs" => "#e91e63",
