@page "/conversations"
@attribute [Authorize]
@implements IAsyncDisposable
@inject AuthenticatedHttpClient Http
@inject ISnackbar Snackbar
@inject IDialogService Dialog
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>R2WAI - Conversations</PageTitle>

<PageHeader Title="Conversations" Subtitle="Your chat history with AI assistants">
    @if (_selectedConversation is not null && _conversationDetail is not null && !_pickingAssistant)
    {
        <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Small" Class="mr-2"
                   StartIcon="@Icons.Material.Filled.Download" OnClick="ExportConversation">
            Export
        </MudButton>
    }
    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" Class="btn-gradient"
               StartIcon="@Icons.Material.Filled.Add" OnClick="StartNewChat">
        New Chat
    </MudButton>
</PageHeader>

@if (_pickingAssistant)
{
    <MudPaper Class="pa-6 animate-slide-in" Elevation="0" Style="border: 1px solid var(--mud-palette-divider);">
        <div class="d-flex justify-space-between align-center mb-4">
            <div>
                <MudText Typo="Typo.h6" Style="font-weight: 700;">New Conversation</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">Choose an assistant to start chatting</MudText>
            </div>
            <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="CancelNewChat" Size="Size.Small" aria-label="Cancel" />
        </div>

        @if (_loadingAssistants)
        {
            <div class="d-flex justify-center pa-8">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
            </div>
        }
        else if (_availableAssistants.Count == 0)
        {
            <MudAlert Severity="Severity.Info" Icon="@Icons.Material.Outlined.SmartToy" Class="mb-4">
                <MudText Typo="Typo.body2">
                    No published assistants found. Open <strong>Assistant Studio</strong> to create and publish one first.
                </MudText>
                <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small" Class="mt-2"
                           OnClick="@(() => Navigation.NavigateTo("/assistant-studio"))">
                    Open Assistant Studio
                </MudButton>
            </MudAlert>
        }
        else
        {
            <MudText Typo="Typo.subtitle2" Class="mb-3" Style="font-weight: 600;">Select an Assistant</MudText>
            <MudGrid Spacing="2" Class="mb-4">
                @foreach (var asst in _availableAssistants)
                {
                    var asstId = asst.Id;
                    var isSelected = _newChatAssistantId == asstId;
                    <MudItem xs="12" sm="6" md="4">
                        <MudPaper Elevation="0"
                                  Style="@(isSelected
                                      ? "border: 2px solid #7C3AED; border-radius: 12px; background: rgba(124,58,237,0.06); cursor: pointer; padding: 12px;"
                                      : "border: 1px solid var(--mud-palette-divider); border-radius: 12px; cursor: pointer; padding: 12px;")"
                                  @onclick="@(() => SelectAssistant(asstId))">
                            <div class="d-flex align-center gap-3">
                                <MudAvatar Size="Size.Medium"
                                           Style="@(isSelected
                                               ? "background: linear-gradient(135deg, #7C3AED, #6D28D9);"
                                               : "background: var(--mud-palette-action-disabled-background);")">
                                    @(asst.Name.Length > 0 ? asst.Name[0].ToString().ToUpper() : "A")
                                </MudAvatar>
                                <div style="flex: 1; min-width: 0;">
                                    <MudText Typo="Typo.subtitle2" Style="font-weight: 600;">@asst.Name</MudText>
                                    @if (!string.IsNullOrEmpty(asst.Description))
                                    {
                                        <MudText Typo="Typo.caption" Color="Color.Secondary"
                                                 Style="overflow: hidden; text-overflow: ellipsis; white-space: nowrap; display: block;">
                                            @asst.Description
                                        </MudText>
                                    }
                                </div>
                                @if (isSelected)
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Primary" Size="Size.Small" />
                                }
                            </div>
                        </MudPaper>
                    </MudItem>
                }
            </MudGrid>

            <MudTextField @bind-Value="_newChatTitle"
                          Label="Conversation name (optional)"
                          Placeholder="@GetNewChatPlaceholder()"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Class="mb-4" />

            <div class="d-flex gap-2 justify-end">
                <MudButton Variant="Variant.Text" OnClick="CancelNewChat">Cancel</MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="btn-gradient"
                           StartIcon="@Icons.Material.Filled.Chat"
                           OnClick="CreateConversation"
                           Disabled="@(_newChatAssistantId is null || _creatingConversation)">
                    @(_creatingConversation ? "Starting..." : "Start Chat")
                </MudButton>
            </div>
        }
    </MudPaper>
}
else if (_loading)
{
    <MudPaper Class="pa-4 mb-4" Elevation="0" Style="border: 1px solid var(--mud-palette-divider);">
        <MudTextField @bind-Value="_searchTerm" Placeholder="Search conversations by title or assistant..."
                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                      Variant="Variant.Outlined" Margin="Margin.Dense"
                      Immediate="true" DebounceInterval="300" />
    </MudPaper>
    <LoadingSkeleton Variant="LoadingSkeleton.SkeletonVariant.Chat" />
}
else if (_hasError)
{
    <MudPaper Class="pa-4 mb-4" Elevation="0" Style="border: 1px solid var(--mud-palette-divider);">
        <MudTextField @bind-Value="_searchTerm" Placeholder="Search conversations by title or assistant..."
                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                      Variant="Variant.Outlined" Margin="Margin.Dense"
                      Immediate="true" DebounceInterval="300" />
    </MudPaper>
    <ErrorState ErrorMessage="@_error" OnRetry="LoadConversations" />
}
else if (!FilteredConversations.Any())
{
    <MudPaper Class="pa-4 mb-4" Elevation="0" Style="border: 1px solid var(--mud-palette-divider);">
        <MudTextField @bind-Value="_searchTerm" Placeholder="Search conversations by title or assistant..."
                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                      Variant="Variant.Outlined" Margin="Margin.Dense"
                      Immediate="true" DebounceInterval="300" />
    </MudPaper>
    <EmptyState Icon="@Icons.Material.Outlined.ChatBubbleOutline"
                Title="No conversations yet"
                Description="Start chatting with an assistant to see your history here."
                ActionText="Start a Chat"
                ActionIcon="@Icons.Material.Filled.Chat"
                OnAction="StartNewChat"
                MinHeight="300px" />
}
else
{
    <MudPaper Class="pa-4 mb-4" Elevation="0" Style="border: 1px solid var(--mud-palette-divider);">
        <MudTextField @bind-Value="_searchTerm" Placeholder="Search conversations by title or assistant..."
                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                      Variant="Variant.Outlined" Margin="Margin.Dense"
                      Immediate="true" DebounceInterval="300" />
    </MudPaper>

    <MudGrid Spacing="3">
        @* Left Panel: Conversation List *@
        <MudItem xs="12" md="4">
            <MudPaper Elevation="0" Class="pa-3" Style="border: 1px solid var(--mud-palette-divider);">
                <div class="d-flex justify-space-between align-center mb-3">
                    <div>
                        <MudText Typo="Typo.subtitle1" Style="font-weight: 700;">Chats</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@FilteredConversations.Count conversations</MudText>
                    </div>
                </div>

                <MudList T="ConversationListItem" Dense="true" Class="overflow-y-auto stagger-in mobile-list-collapsed" Style="max-height: 60vh;">
                    @foreach (var conversation in FilteredConversations)
                    {
                        <MudListItem T="ConversationListItem" OnClick="@(() => SelectConversation(conversation))"
                                     Style="@(_selectedConversation?.Id == conversation.Id ? "background: var(--r2-primary-subtle, rgba(124,58,237,0.08)); border-left: 3px solid #7C3AED; border-radius: 8px;" : "border-radius: 8px; border-left: 3px solid transparent;")">
                            <div class="d-flex align-center gap-3" style="width: 100%;">
                                <MudAvatar Size="Size.Small" Color="Color.Primary"
                                           Style="width: 36px; height: 36px; font-size: 0.75rem; background: linear-gradient(135deg, #7C3AED, #6D28D9);">
                                    @(conversation.AssistantName.Length > 0 ? conversation.AssistantName[0].ToString().ToUpper() : "A")
                                </MudAvatar>
                                <div style="flex: 1; min-width: 0;">
                                    <MudText Typo="Typo.subtitle2" Style="text-overflow: ellipsis; overflow: hidden; white-space: nowrap; font-weight: 600;">
                                        @conversation.Title
                                    </MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary" Style="text-overflow: ellipsis; overflow: hidden; white-space: nowrap; display: block;">
                                        @(conversation.LastMessagePreview.Length > 80
                                            ? conversation.LastMessagePreview[..80] + "..."
                                            : conversation.LastMessagePreview)
                                    </MudText>
                                    <div class="d-flex align-center gap-2 mt-1">
                                        <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Primary"
                                                 Style="font-size: 0.6rem; height: 16px;">
                                            @conversation.AssistantName
                                        </MudChip>
                                        <MudText Typo="Typo.caption" Color="Color.Tertiary" Style="font-size: 0.6rem;">
                                            @FormatRelativeTime(conversation.CreatedAt)
                                        </MudText>
                                    </div>
                                </div>
                                <div class="d-flex flex-column align-end gap-1">
                                    <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined"
                                             Style="font-size: 0.6rem; height: 18px;">
                                        @conversation.MessageCount msgs
                                    </MudChip>
                                    <MudIconButton Icon="@Icons.Material.Outlined.DeleteOutline" Size="Size.Small"
                                                   Color="Color.Error" Style="width: 24px; height: 24px; opacity: 0.5;"
                                                   OnClick="@(() => DeleteConversation(conversation))"
                                                   OnClickStopPropagation="true"
                                                   aria-label="Delete conversation" />
                                </div>
                            </div>
                        </MudListItem>
                    }
                </MudList>

                @if (_hasMore)
                {
                    <div class="d-flex justify-center mt-2">
                        <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small"
                                   OnClick="LoadMore" StartIcon="@Icons.Material.Filled.ExpandMore">
                            Load More (@(_totalCount - _conversations.Count) remaining)
                        </MudButton>
                    </div>
                }
            </MudPaper>
        </MudItem>

        @* Right Panel: Messages *@
        <MudItem xs="12" md="8">
            @if (_selectedConversation is null)
            {
                <MudPaper Elevation="0" Class="pa-8 d-flex flex-column align-center justify-center" Style="min-height: 400px; border: 1px solid var(--mud-palette-divider);">
                    <div class="empty-state-icon">
                        <MudIcon Icon="@Icons.Material.Outlined.ChatBubbleOutline" Size="Size.Large" Color="Color.Primary" Style="opacity: 0.6;" />
                    </div>
                    <MudText Typo="Typo.h6" Color="Color.Secondary" Style="font-weight: 600;">Select a conversation</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Tertiary" Class="mt-2" Style="max-width: 300px; text-align: center; line-height: 1.5;">
                        Choose a conversation from the list to see the full message history
                    </MudText>
                </MudPaper>
            }
            else if (_loadingMessages)
            {
                <MudPaper Elevation="0" Class="pa-4" Style="border: 1px solid var(--mud-palette-divider); min-height: 400px;">
                    <LoadingSkeleton Variant="LoadingSkeleton.SkeletonVariant.Chat" />
                </MudPaper>
            }
            else
            {
                <MudPaper Elevation="0" Class="editor-panel animate-slide-in" Style="display: flex; flex-direction: column; min-height: 400px;">
                    @* Header *@
                    <div class="d-flex justify-space-between align-center pa-4 editor-header">
                        <div class="d-flex align-center gap-3">
                            <MudAvatar Color="Color.Primary" Size="Size.Medium"
                                       Style="background: linear-gradient(135deg, #7C3AED, #6D28D9);">
                                @(_selectedConversation.AssistantName.Length > 0 ? _selectedConversation.AssistantName[0].ToString().ToUpper() : "A")
                            </MudAvatar>
                            <div>
                                <MudText Typo="Typo.h6" Style="font-weight: 700;">@_selectedConversation.Title</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    @_selectedConversation.AssistantName &middot; @_selectedConversation.MessageCount messages &middot; @_selectedConversation.CreatedAt.ToString("MMM dd, yyyy h:mm tt")
                                </MudText>
                            </div>
                        </div>
                        <MudIconButton Icon="@Icons.Material.Outlined.DeleteOutline" Color="Color.Error" Size="Size.Small"
                                       OnClick="@(() => DeleteConversation(_selectedConversation))"
                                       aria-label="Delete conversation" />
                    </div>

                    @* Messages *@
                    <div class="pa-4" style="flex: 1; overflow-y: auto; max-height: 55vh;">
                        @if (_conversationDetail is not null && _conversationDetail.Messages.Any())
                        {
                            @foreach (var msg in _conversationDetail.Messages)
                            {
                                var isUser = msg.Role.Equals("user", StringComparison.OrdinalIgnoreCase);
                                <div class="d-flex @(isUser ? "justify-end" : "justify-start") mb-3">
                                    <div class="chat-message @(isUser ? "chat-message--user" : "chat-message--assistant")">
                                        <MudText Typo="Typo.caption" Style="@(isUser ? "color: rgba(255,255,255,0.7);" : "")" Color="@(isUser ? Color.Inherit : Color.Secondary)" Class="mb-1">
                                            @(isUser ? "You" : "Assistant") &middot; @msg.CreatedAt.ToString("h:mm tt")
                                        </MudText>
                                        @if (isUser)
                                        {
                                            <MudText Typo="Typo.body2" Style="white-space: pre-wrap; line-height: 1.6;">@msg.Content</MudText>
                                        }
                                        else
                                        {
                                            <MarkdownRenderer Content="@msg.Content" Style="line-height: 1.6; font-size: 0.875rem;" />
                                            @if (_ttsSupported)
                                            {
                                                <div class="d-flex justify-end mt-1">
                                                    <MudIconButton Icon="@(_speakingMsgId == msg.Id ? Icons.Material.Filled.StopCircle : Icons.Material.Filled.VolumeUp)"
                                                                   Size="Size.Small"
                                                                   Color="@(_speakingMsgId == msg.Id ? Color.Primary : Color.Default)"
                                                                   OnClick="@(() => ToggleSpeakMessage(msg))"
                                                                   Style="width: 26px; height: 26px; opacity: 0.6;"
                                                                   aria-label="@(_speakingMsgId == msg.Id ? "Stop speaking" : "Read aloud")" />
                                                </div>
                                            }
                                        }
                                    </div>
                                </div>
                            }

                            @if (_streamingContent.Length > 0)
                            {
                                <div class="d-flex justify-start mb-3">
                                    <div class="chat-message chat-message--assistant">
                                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">
                                            Assistant &middot; typing...
                                        </MudText>
                                        <MarkdownRenderer Content="@_streamingContent.ToString()" Style="line-height: 1.6; font-size: 0.875rem;" />
                                    </div>
                                </div>
                            }
                            else if (_sendingReply)
                            {
                                <div class="d-flex justify-start mb-3">
                                    <div class="chat-message chat-message--assistant">
                                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">Assistant</MudText>
                                        <MudProgressLinear Indeterminate="true" Color="Color.Primary" Size="Size.Small" />
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="d-flex flex-column align-center justify-center pa-8">
                                <div class="empty-state-icon" style="width: 56px; height: 56px;">
                                    <MudIcon Icon="@Icons.Material.Outlined.SpeakerNotesOff" Size="Size.Medium" Color="Color.Primary" Style="opacity: 0.5;" />
                                </div>
                                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-2">No messages in this conversation</MudText>
                            </div>
                        }
                    </div>

                    @* Reply Input *@
                    <div class="pa-3" style="border-top: 1px solid var(--mud-palette-divider);">
                        @if (_isListening)
                        {
                            <div class="d-flex align-center gap-2 mb-2 pa-2" style="background: rgba(76,175,80,0.08); border-radius: 8px; border: 1px solid rgba(76,175,80,0.2);">
                                <div class="voice-pulse-dot"></div>
                                <MudText Typo="Typo.caption" Color="Color.Success" Style="font-weight: 600;">
                                    @(_interimTranscript.Length > 0 ? _interimTranscript : "Listening...")
                                </MudText>
                            </div>
                        }
                        <div class="d-flex gap-2 align-center">
                            @if (_sttSupported)
                            {
                                <MudTooltip Text="@(_isListening ? "Stop listening" : "Voice input")">
                                    <MudIconButton Icon="@(_isListening ? Icons.Material.Filled.MicOff : Icons.Material.Filled.Mic)"
                                                   Color="@(_isListening ? Color.Error : Color.Default)"
                                                   OnClick="ToggleVoiceInput" Disabled="_sendingReply"
                                                   Size="Size.Small"
                                                   Style="@(_isListening ? "animation: pulse-soft 1.5s infinite;" : "")"
                                                   aria-label="@(_isListening ? "Stop voice input" : "Voice input")" />
                                </MudTooltip>
                            }
                            <MudTextField @bind-Value="_replyInput" Placeholder="@(_isListening ? "Speak now..." : "Type a message...")"
                                          Variant="Variant.Outlined" Margin="Margin.Dense"
                                          OnKeyUp="HandleReplyKeyUp" Disabled="_sendingReply"
                                          Immediate="true" Style="flex: 1;" aria-label="Reply input" />
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                                       OnClick="SendReply" Disabled="@(_sendingReply || string.IsNullOrWhiteSpace(_replyInput))"
                                       Style="height: 40px; min-width: 80px;">
                                @if (_sendingReply)
                                {
                                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Surface" />
                                }
                                else
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.Send" Size="Size.Small" />
                                }
                            </MudButton>
                        </div>
                        @if (_sttSupported && _ttsSupported)
                        {
                            <div class="d-flex align-center justify-end mt-1" style="opacity: 0.7;">
                                <MudTooltip Text="Voice Chat: auto-listen after each reply is spoken aloud">
                                    <div class="d-flex align-center gap-1" style="cursor: pointer;" @onclick="ToggleVoiceChatMode">
                                        <MudIcon Icon="@Icons.Material.Filled.RecordVoiceOver" Size="Size.Small"
                                                 Color="@(_voiceChatActive ? Color.Success : Color.Default)" Style="font-size: 14px;" />
                                        <MudText Typo="Typo.caption" Color="@(_voiceChatActive ? Color.Success : Color.Secondary)"
                                                 Style="font-size: 0.65rem; font-weight: 600;">
                                            Voice Chat @(_voiceChatActive ? "ON" : "OFF")
                                        </MudText>
                                    </div>
                                </MudTooltip>
                            </div>
                        }
                    </div>
                </MudPaper>
            }
        </MudItem>
    </MudGrid>
}

@code {
    private List<ConversationListItem> _conversations = new();
    private ConversationListItem? _selectedConversation;
    private ConversationDetail? _conversationDetail;
    private string _searchTerm = string.Empty;
    private bool _loading = true;
    private bool _loadingMessages;
    private bool _hasError;
    private string _error = string.Empty;
    private string _replyInput = string.Empty;
    private bool _sendingReply;
    private System.Text.StringBuilder _streamingContent = new();
    private int _page = 1;
    private int _pageSize = 20;
    private int _totalCount;
    private bool _hasMore;

    // New chat picker state
    private bool _pickingAssistant;
    private bool _loadingAssistants;
    private List<AssistantOption> _availableAssistants = new();
    private Guid? _newChatAssistantId;
    private string _newChatTitle = string.Empty;
    private bool _creatingConversation;

    // Voice (STT + TTS)
    private IJSObjectReference? _voiceModule;
    private DotNetObjectReference<Conversations>? _dotNetRef;
    private bool _sttSupported;
    private bool _ttsSupported;
    private bool _isListening;
    private bool _voiceChatActive;
    private string _interimTranscript = string.Empty;
    private Guid _speakingMsgId = Guid.Empty;

    private List<ConversationListItem> FilteredConversations =>
        string.IsNullOrWhiteSpace(_searchTerm)
            ? _conversations
            : _conversations.Where(c => c.Title.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase)
                || c.AssistantName.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase))
              .ToList();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await LoadConversations();
        try
        {
            _voiceModule = await JS.InvokeAsync<IJSObjectReference>("import", "./js/voice.js");
            _dotNetRef = DotNetObjectReference.Create(this);
            var support = await _voiceModule.InvokeAsync<VoiceSupport>("isSupported");
            _sttSupported = support.Stt;
            _ttsSupported = support.Tts;
            StateHasChanged();
        }
        catch { }
    }

    private async Task LoadConversations()
    {
        _loading = true;
        _hasError = false;
        _page = 1;
        _conversations.Clear();
        StateHasChanged();
        await LoadConversationPage();
    }

    private async Task LoadConversationPage()
    {
        try
        {
            PagedResult<ConversationListItem>? result = null;
            try
            {
                result = await Http.GetFromJsonAsync<PagedResult<ConversationListItem>>(
                    $"/api/v1/chat/conversations?page={_page}&pageSize={_pageSize}");
            }
            catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.NotFound)
            {
                result = await Http.GetFromJsonAsync<PagedResult<ConversationListItem>>(
                    $"/api/v1/conversations?page={_page}&pageSize={_pageSize}");
            }

            var items = result?.Items ?? new();
            _conversations.AddRange(items);
            _totalCount = result?.TotalCount ?? _conversations.Count;
            _hasMore = _conversations.Count < _totalCount;
        }
        catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.NotFound)
        {
            _hasError = true;
            _error = "Conversations API is not available. This feature requires backend endpoints to be configured.";
        }
        catch (Exception ex)
        {
            _hasError = true;
            _error = "Unable to load conversations. Please check your connection and try again.";
            Snackbar.Add($"Failed to load conversations: {ex.Message}", Severity.Error);
        }
        finally { _loading = false; StateHasChanged(); }
    }

    private async Task LoadMore()
    {
        _page++;
        await LoadConversationPage();
    }

    private async Task StartNewChat()
    {
        _pickingAssistant = true;
        _loadingAssistants = true;
        _newChatAssistantId = null;
        _newChatTitle = string.Empty;
        StateHasChanged();

        try
        {
            var result = await Http.GetFromJsonAsync<AssistantListResult>("/api/v1/assistants?pageSize=100");
            var all = result?.Items ?? new();
            _availableAssistants = all.Where(a => a.PublishStatus == "Published").ToList();
        }
        catch { Snackbar.Add("Failed to load assistants.", Severity.Warning); }
        finally { _loadingAssistants = false; StateHasChanged(); }
    }

    private void CancelNewChat()
    {
        _pickingAssistant = false;
        _newChatAssistantId = null;
        _newChatTitle = string.Empty;
    }

    private void SelectAssistant(Guid id)
    {
        _newChatAssistantId = id;
    }

    private string GetNewChatPlaceholder()
    {
        if (_newChatAssistantId is null) return "Give this chat a name...";
        var name = _availableAssistants.FirstOrDefault(a => a.Id == _newChatAssistantId)?.Name ?? "AI";
        return $"{name} — {DateTime.Now:MMM d}";
    }

    private async Task CreateConversation()
    {
        if (_newChatAssistantId is null)
        {
            Snackbar.Add("Please select an assistant.", Severity.Warning);
            return;
        }

        var assistant = _availableAssistants.FirstOrDefault(a => a.Id == _newChatAssistantId);
        var title = string.IsNullOrWhiteSpace(_newChatTitle)
            ? $"{assistant?.Name ?? "AI"} — {DateTime.Now:MMM d, h:mm tt}"
            : _newChatTitle.Trim();

        _creatingConversation = true;
        StateHasChanged();

        try
        {
            var payload = new { Title = title, ReferenceId = _newChatAssistantId.ToString() };
            var response = await Http.PostAsJsonAsync("/api/v1/chat/conversations", payload);

            if (response.IsSuccessStatusCode)
            {
                var created = await response.Content.ReadFromJsonAsync<ConversationCreatedResult>();
                if (created is not null)
                {
                    var newItem = new ConversationListItem
                    {
                        Id = created.Id,
                        Title = title,
                        AssistantName = assistant?.Name ?? string.Empty,
                        MessageCount = 0,
                        CreatedAt = DateTime.UtcNow,
                        LastMessagePreview = string.Empty
                    };
                    _conversations.Insert(0, newItem);
                    _pickingAssistant = false;
                    await SelectConversation(newItem);
                }
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"Failed to create conversation: {response.StatusCode}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to create conversation: {ex.Message}", Severity.Error);
        }
        finally { _creatingConversation = false; StateHasChanged(); }
    }

    private async Task SelectConversation(ConversationListItem conversation)
    {
        _selectedConversation = conversation;
        _loadingMessages = true;
        _conversationDetail = null;
        StateHasChanged();

        try
        {
            ConversationDetail? detail = null;
            try
            {
                detail = await Http.GetFromJsonAsync<ConversationDetail>($"/api/v1/chat/conversations/{conversation.Id}");
            }
            catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.NotFound)
            {
                detail = await Http.GetFromJsonAsync<ConversationDetail>($"/api/v1/conversations/{conversation.Id}");
            }

            _conversationDetail = detail;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load messages: {ex.Message}", Severity.Error);
            _conversationDetail = new ConversationDetail { Id = conversation.Id, Title = conversation.Title, Messages = new() };
        }
        finally { _loadingMessages = false; StateHasChanged(); }
    }

    private async Task DeleteConversation(ConversationListItem conversation)
    {
        var parameters = new DialogParameters<DeleteConfirmationDialog>
        {
            { x => x.ItemName, conversation.Title },
            { x => x.Description, "This conversation and all its messages will be permanently removed." }
        };
        var dialog = await Dialog.ShowAsync<DeleteConfirmationDialog>("Confirm Delete", parameters);
        var result = await dialog.Result;
        if (result?.Canceled == true) return;

        try
        {
            try
            {
                await Http.DeleteAsync($"/api/v1/chat/conversations/{conversation.Id}");
            }
            catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.NotFound)
            {
                await Http.DeleteAsync($"/api/v1/conversations/{conversation.Id}");
            }

            Snackbar.Add("Conversation deleted", Severity.Success);
            _conversations.Remove(conversation);
            if (_selectedConversation?.Id == conversation.Id)
            {
                _selectedConversation = null;
                _conversationDetail = null;
            }
            StateHasChanged();
        }
        catch (Exception ex) { Snackbar.Add($"Delete failed: {ex.Message}", Severity.Error); }
    }

    private async Task ExportConversation()
    {
        if (_conversationDetail is null || _selectedConversation is null) return;

        try
        {
            var sb = new System.Text.StringBuilder();
            sb.AppendLine($"# {_selectedConversation.Title}");
            sb.AppendLine($"Assistant: {_selectedConversation.AssistantName}");
            sb.AppendLine($"Date: {_selectedConversation.CreatedAt:yyyy-MM-dd HH:mm}");
            sb.AppendLine($"Messages: {_conversationDetail.Messages.Count}");
            sb.AppendLine(new string('-', 60));
            sb.AppendLine();

            foreach (var msg in _conversationDetail.Messages)
            {
                var role = msg.Role.Equals("user", StringComparison.OrdinalIgnoreCase) ? "You" : "Assistant";
                sb.AppendLine($"**{role}** ({msg.CreatedAt:HH:mm}):");
                sb.AppendLine(msg.Content);
                sb.AppendLine();
            }

            var bytes = System.Text.Encoding.UTF8.GetBytes(sb.ToString());
            var base64 = Convert.ToBase64String(bytes);
            var fileName = $"conversation-{_selectedConversation.Title.Replace(' ', '-').ToLowerInvariant()}.md";

            await JS.InvokeVoidAsync("eval",
                $"var a=document.createElement('a');a.href='data:text/markdown;base64,{base64}';a.download='{fileName}';document.body.appendChild(a);a.click();a.remove();");

            Snackbar.Add("Conversation exported", Severity.Success);
        }
        catch (Exception ex) { Snackbar.Add($"Export failed: {ex.Message}", Severity.Error); }
    }

    private async Task HandleReplyKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey && !_sendingReply && !string.IsNullOrWhiteSpace(_replyInput))
            await SendReply();
    }

    private async Task SendReply()
    {
        if (_selectedConversation is null || string.IsNullOrWhiteSpace(_replyInput)) return;

        var message = _replyInput.Trim();
        _replyInput = string.Empty;
        _sendingReply = true;
        _streamingContent.Clear();

        _conversationDetail?.Messages.Add(new MessageItem
        {
            Id = Guid.NewGuid(),
            Role = "User",
            Content = message,
            CreatedAt = DateTime.Now
        });
        _selectedConversation.MessageCount++;
        StateHasChanged();

        try
        {
            using var content = new MultipartFormDataContent();
            content.Add(new StringContent(message), "content");

            var response = await Http.PostAsync(
                $"/api/v1/chat/conversations/{_selectedConversation.Id}/messages", content);

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<MessageReplyResult>();
                if (result is not null)
                {
                    var replyMsg = new MessageItem
                    {
                        Id = result.Id,
                        Role = "Assistant",
                        Content = result.Content,
                        CreatedAt = result.CreatedAt
                    };
                    _conversationDetail?.Messages.Add(replyMsg);
                    _selectedConversation.MessageCount++;
                    _selectedConversation.LastMessagePreview = result.Content.Length > 80
                        ? result.Content[..80] + "..." : result.Content;

                    if (_voiceChatActive && _voiceModule is not null && _dotNetRef is not null)
                    {
                        _speakingMsgId = replyMsg.Id;
                        StateHasChanged();
                        await _voiceModule.InvokeAsync<bool>("speak", replyMsg.Content, "en-US", 1.0, 1.0, _dotNetRef, "OnSpeakDone");
                    }
                }
            }
            else
            {
                Snackbar.Add($"Failed to send: {response.StatusCode}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to send message: {ex.Message}", Severity.Error);
        }
        finally
        {
            _sendingReply = false;
            _streamingContent.Clear();
            StateHasChanged();
        }
    }

    // ── Voice helpers ──────────────────────────────────────────────────────────

    private async Task ToggleVoiceInput()
    {
        if (_isListening) await StopListening();
        else await StartListening();
    }

    private async Task StartListening()
    {
        if (_voiceModule is null || _dotNetRef is null) return;
        _interimTranscript = string.Empty;
        await _voiceModule.InvokeAsync<bool>("startListening", _dotNetRef, "OnVoiceResult", "OnVoiceStatus", "en-US");
    }

    private async Task StopListening()
    {
        if (_voiceModule is null) return;
        _isListening = false;
        _interimTranscript = string.Empty;
        await _voiceModule.InvokeVoidAsync("stopListening");
        StateHasChanged();
    }

    [JSInvokable]
    public async Task OnVoiceResult(string transcript, bool isFinal)
    {
        if (isFinal)
        {
            _replyInput = transcript;
            _interimTranscript = string.Empty;
            _isListening = false;
            StateHasChanged();
            if (_voiceChatActive)
                await SendReply();
        }
        else
        {
            _interimTranscript = transcript;
            await InvokeAsync(StateHasChanged);
        }
    }

    [JSInvokable]
    public void OnVoiceStatus(string status)
    {
        _isListening = status == "listening";
        if (status == "not-allowed")
            Snackbar.Add("Microphone access denied.", Severity.Warning);
        else if (status == "no-speech")
            _interimTranscript = string.Empty;
        InvokeAsync(StateHasChanged);
    }

    private async Task ToggleSpeakMessage(MessageItem msg)
    {
        if (_voiceModule is null || _dotNetRef is null) return;

        if (_speakingMsgId == msg.Id)
        {
            await _voiceModule.InvokeVoidAsync("stopSpeaking");
            _speakingMsgId = Guid.Empty;
            StateHasChanged();
            return;
        }

        _speakingMsgId = msg.Id;
        StateHasChanged();
        await _voiceModule.InvokeAsync<bool>("speak", msg.Content, "en-US", 1.0, 1.0, _dotNetRef, "OnSpeakDone");
    }

    [JSInvokable]
    public async Task OnSpeakDone()
    {
        _speakingMsgId = Guid.Empty;
        await InvokeAsync(StateHasChanged);
        if (_voiceChatActive)
            await InvokeAsync(StartListening);
    }

    private async Task ToggleVoiceChatMode()
    {
        if (_voiceChatActive)
        {
            _voiceChatActive = false;
            if (_voiceModule is not null)
                await _voiceModule.InvokeVoidAsync("setVoiceChatMode", false);
            _isListening = false;
            _interimTranscript = string.Empty;
            StateHasChanged();
        }
        else
        {
            _voiceChatActive = true;
            if (_voiceModule is not null)
                await _voiceModule.InvokeVoidAsync("setVoiceChatMode", true);
            Snackbar.Add("Voice Chat enabled — speak to reply!", Severity.Success);
            StateHasChanged();
            await StartListening();
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_voiceModule is not null)
        {
            try { await _voiceModule.InvokeVoidAsync("dispose"); } catch { }
            await _voiceModule.DisposeAsync();
        }
        _dotNetRef?.Dispose();
    }

