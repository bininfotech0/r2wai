@inject IJSRuntime JS
@inject ISnackbar Snackbar

<span class="d-inline-flex align-center gap-1">
    <span style="@Style">@Text</span>
    <MudIconButton Icon="@Icons.Material.Filled.ContentCopy" Size="Size.Small" Color="Color.Default"
                   OnClick="CopyText" aria-label="Copy to clipboard" />
</span>

@code {
    [Parameter] public string Text { get; set; } = string.Empty;
    [Parameter] public string? Style { get; set; }

    private async Task CopyText()
    {
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", Text);
            Snackbar.Add("Copied to clipboard", Severity.Info);
        }
        catch
        {
            Snackbar.Add("Copy failed", Severity.Warning);
        }
    }
}
