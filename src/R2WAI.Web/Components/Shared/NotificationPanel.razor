@inject ISnackbar Snackbar

<MudPaper Style="max-height: 400px; overflow-y: auto; min-width: 350px;" Elevation="0">
    <div class="d-flex justify-space-between align-center pa-2">
        <MudText Typo="Typo.subtitle1" Class="ml-2">Notifications</MudText>
        @if (_notifications.Any(n => !n.IsRead))
        {
            <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small"
                       OnClick="MarkAllRead">
                Mark All Read
            </MudButton>
        }
    </div>
    <MudDivider />

    @if (_notifications.Count == 0)
    {
        <MudText Align="Align.Center" Class="pa-4" Typo="Typo.body2" Color="Color.Tertiary">
            No notifications
        </MudText>
    }
    else
    {
        <MudList T="NotificationItem" Dense="true">
            @foreach (var notification in _notifications)
            {
                <MudListItem T="NotificationItem" OnClick="@(() => MarkAsRead(notification))"
                             Style="@(notification.IsRead ? "" : "background-color: var(--mud-palette-background-gray);")">
                    <div class="d-flex align-start gap-2">
                        <MudIcon Icon="@GetTypeIcon(notification.Type)" Size="Size.Small"
                                 Color="@GetTypeColor(notification.Type)" Class="mt-1" />
                        <div class="d-flex flex-column flex-grow-1">
                            <MudText Typo="Typo.subtitle2"
                                     Style="@(notification.IsRead ? "" : "font-weight: bold;")">
                                @notification.Title
                            </MudText>
                            <MudText Typo="Typo.body2" Color="Color.Tertiary">@notification.Message</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Tertiary">
                                @FormatTimestamp(notification.Timestamp)
                            </MudText>
                        </div>
                    </div>
                </MudListItem>
                <MudDivider />
            }
        </MudList>

        <MudButton Variant="Variant.Text" Color="Color.Error" FullWidth="true" Size="Size.Small"
                   OnClick="ClearAll" Class="mt-1">
            Clear All
        </MudButton>
    }
</MudPaper>

@code {
    [Parameter] public List<NotificationItem> Notifications { get; set; } = new();
    [Parameter] public EventCallback OnChanged { get; set; }

    private List<NotificationItem> _notifications => Notifications;

    private async Task MarkAsRead(NotificationItem notification)
    {
        notification.IsRead = true;
        await OnChanged.InvokeAsync();
    }

    private async Task MarkAllRead()
    {
        foreach (var n in _notifications)
            n.IsRead = true;
        await OnChanged.InvokeAsync();
    }

    private async Task ClearAll()
    {
        Notifications.Clear();
        await OnChanged.InvokeAsync();
    }

    private static string GetTypeIcon(string? type) => type switch
    {
        "success" => Icons.Material.Filled.CheckCircle,
        "error" => Icons.Material.Filled.Error,
        "warning" => Icons.Material.Filled.Warning,
        "approval" => Icons.Material.Filled.Approval,
        "workflow" => Icons.Material.Filled.AccountTree,
        _ => Icons.Material.Filled.Info,
    };

    private static Color GetTypeColor(string? type) => type switch
    {
        "success" => Color.Success,
        "error" => Color.Error,
        "warning" => Color.Warning,
        "approval" => Color.Primary,
        "workflow" => Color.Secondary,
        _ => Color.Info,
    };

    private static string FormatTimestamp(DateTime timestamp)
    {
        var diff = DateTime.Now - timestamp;
        if (diff.TotalMinutes < 1) return "Just now";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours}h ago";
        return timestamp.ToString("MMM dd, hh:mm tt");
    }

    public class NotificationItem
    {
        public string Title { get; set; } = string.Empty;
        public string Message { get; set; } = string.Empty;
        public string? Type { get; set; }
        public DateTime Timestamp { get; set; } = DateTime.Now;
        public bool IsRead { get; set; }
    }
}
