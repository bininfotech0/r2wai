@inject IDialogService Dialog

<MudDialog>
    <TitleContent>
        <div class="d-flex align-center gap-2">
            <MudIcon Icon="@Icons.Material.Outlined.Keyboard" Color="Color.Primary" />
            <MudText Typo="Typo.h6">Keyboard Shortcuts</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <MudSimpleTable Dense="true" Hover="true" Elevation="0">
            <thead>
                <tr>
                    <th>Shortcut</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                <tr><td><kbd>Ctrl</kbd> + <kbd>K</kbd></td><td>Open Command Palette</td></tr>
                <tr><td><kbd>Ctrl</kbd> + <kbd>/</kbd></td><td>Toggle AI Copilot</td></tr>
                <tr><td><kbd>Ctrl</kbd> + <kbd>N</kbd></td><td>New item (context-aware)</td></tr>
                <tr><td><kbd>?</kbd></td><td>Show this help</td></tr>
                <tr><td><kbd>G</kbd> then <kbd>H</kbd></td><td>Go to Home</td></tr>
                <tr><td><kbd>G</kbd> then <kbd>A</kbd></td><td>Go to Assistants</td></tr>
                <tr><td><kbd>G</kbd> then <kbd>W</kbd></td><td>Go to Workflows</td></tr>
                <tr><td><kbd>G</kbd> then <kbd>D</kbd></td><td>Go to Documents</td></tr>
                <tr><td><kbd>G</kbd> then <kbd>I</kbd></td><td>Go to Inbox</td></tr>
                <tr><td><kbd>G</kbd> then <kbd>O</kbd></td><td>Go to Operations</td></tr>
                <tr><td><kbd>G</kbd> then <kbd>S</kbd></td><td>Go to Settings</td></tr>
                <tr><td><kbd>Esc</kbd></td><td>Close dialog / panel</td></tr>
            </tbody>
        </MudSimpleTable>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-3" Align="Align.Center">
            Press <kbd>?</kbd> anywhere to show this help
        </MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Close">Close</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    private void Close() => MudDialog.Close();
}
