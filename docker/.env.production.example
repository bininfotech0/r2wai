# R2WAI Production Environment Variables
# Copy this file to .env and fill in the values

# Database
DB_PASSWORD=CHANGE_ME_strong_password_here

# JWT Authentication (min 32 characters)
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_64

# Encryption (32-byte base64 key: openssl rand -base64 32)
ENCRYPTION_KEY=CHANGE_ME_generate_with_openssl_rand_base64_32

# AI Provider
OPENAI_API_KEY=sk-your-openai-api-key

# Email (optional — approval notifications won't send without this)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASSWORD=your-smtp-password
EMAIL_FROM=noreply@yourcompany.com

# Entra ID (optional — for SSO)
# ENTRA_TENANT_ID=your-azure-tenant-id
# ENTRA_CLIENT_ID=your-azure-client-id
# ENTRA_CLIENT_SECRET=your-azure-client-secret
